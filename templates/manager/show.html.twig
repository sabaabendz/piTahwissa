{% extends 'base.html.twig' %}

{% block title %}Manager{% endblock %}

{% block body %}
    <h1>Manager</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>IdUser</th>
                <td>{{ manager.idUser }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ manager.name }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ manager.email }}</td>
            </tr>
            <tr>
                <th>Password</th>
                <td>{{ manager.password }}</td>
            </tr>
            <tr>
                <th>Levem</th>
                <td>{{ manager.levem }}</td>
            </tr>
            <tr>
                <th>Department</th>
                <td>{{ manager.department }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_manager_index') }}">back to list</a>

    <a href="{{ path('app_manager_edit', {'idUser': manager.idUser}) }}">edit</a>

    {{ include('manager/_delete_form.html.twig') }}
{% endblock %}
