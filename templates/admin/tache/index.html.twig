{% extends 'baseback.html.twig' %}

{% block title %}Tâches - Backoffice{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12 mb-3">
        <h1 class="h3 mb-2 mb-sm-0">Tâches (consultation et suppression)</h1>
    </div>
</div>
<div class="row mb-4">
    <div class="col-12">
        <form method="get" action="{{ path('app_admin_tache_index') }}" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label small mb-0">Recherche</label>
                <input type="text" name="search" value="{{ search ?? '' }}" class="form-control" placeholder="Libellé ou projet">
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Rechercher</button>
            </div>
        </form>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card shadow">
            <div class="card-body">
                {% if taches is empty %}
                    <p class="mb-0">Aucune tâche.</p>
                {% else %}
                    {% set nextOrder = order == 'ASC' ? 'DESC' : 'ASC' %}
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th><a href="{{ path('app_admin_tache_index', { search: search, projet: projetId, sort: 'id', order: sortBy == 'id' ? nextOrder : 'ASC' }) }}">ID</a></th>
                                    <th><a href="{{ path('app_admin_tache_index', { search: search, projet: projetId, sort: 'libelle', order: sortBy == 'libelle' ? nextOrder : 'ASC' }) }}">Libellé</a></th>
                                    <th>Projet</th>
                                    <th><a href="{{ path('app_admin_tache_index', { search: search, projet: projetId, sort: 'priorite', order: sortBy == 'priorite' ? nextOrder : 'ASC' }) }}">Priorité</a></th>
                                    <th><a href="{{ path('app_admin_tache_index', { search: search, projet: projetId, sort: 'dateLimite', order: sortBy == 'dateLimite' ? nextOrder : 'ASC' }) }}">Date limite</a></th>
                                    <th><a href="{{ path('app_admin_tache_index', { search: search, projet: projetId, sort: 'etat', order: sortBy == 'etat' ? nextOrder : 'ASC' }) }}">État</a></th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for t in taches %}
                                    <tr>
                                        <td>{{ t.id }}</td>
                                        <td><a href="{{ path('app_admin_tache_show', { id: t.id }) }}">{{ t.libelle }}</a></td>
                                        <td><a href="{{ path('app_admin_projet_show', { id: t.projet.id }) }}">{{ t.projet.nom }}</a></td>
                                        <td><span class="badge bg-{{ t.priorite == 'haute' ? 'danger' : (t.priorite == 'moyenne' ? 'warning' : 'secondary') }}">{{ t.priorite|capitalize }}</span></td>
                                        <td>{{ t.dateLimite ? t.dateLimite|date('d/m/Y') : '-' }}</td>
                                        <td>{% if t.etat == 'a_faire' %}<span class="badge bg-secondary">À faire</span>{% elseif t.etat == 'en_cours' %}<span class="badge bg-info">En cours</span>{% else %}<span class="badge bg-success">Terminé</span>{% endif %}</td>
                                        <td class="text-end">
                                            <a href="{{ path('app_admin_tache_show', { id: t.id }) }}" class="btn btn-sm btn-light">Voir</a>
                                            <form method="post" action="{{ path('app_admin_tache_delete', { id: t.id }) }}" class="d-inline" onsubmit="return confirm('Supprimer cette tâche ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('admin_delete' ~ t.id) }}">
                                                <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                                            </form>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
