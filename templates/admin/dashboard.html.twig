{% extends 'baseback.html.twig' %}

{% block title %}Dashboard - Backoffice{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12 mb-3">
        <h1 class="h3 mb-2 mb-sm-0">Dashboard</h1>
        <p class="text-muted mb-0">User administration overview.</p>
    </div>
</div>
<div class="row g-4 mb-4">
    <div class="col-md-6 col-xxl-3">
        <div class="card card-body bg-primary bg-opacity-10 p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-0 fw-bold">{{ totalUsers }}</h2>
                    <span class="mb-0 h6 fw-light">Users</span>
                </div>
                <div class="icon-lg rounded-circle bg-primary text-white mb-0"><i class="bi bi-people"></i></div>
            </div>
            <a href="{{ path('app_admin_users_index') }}" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-md-6 col-xxl-3">
        <div class="card card-body bg-success bg-opacity-10 p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-0 fw-bold">{{ totalAgents }}</h2>
                    <span class="mb-0 h6 fw-light">Agents</span>
                </div>
                <div class="icon-lg rounded-circle bg-success text-white mb-0"><i class="bi bi-person-badge"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xxl-3">
        <div class="card card-body bg-info bg-opacity-10 p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-0 fw-bold">{{ totalRegularUsers }}</h2>
                    <span class="mb-0 h6 fw-light">Users</span>
                </div>
                <div class="icon-lg rounded-circle bg-info text-white mb-0"><i class="bi bi-person-lines-fill"></i></div>
            </div>
        </div>
    </div>
</div>
<div class="row g-4">
    <div class="col-lg-12">
        <div class="card shadow h-100">
            <div class="card-header border-bottom d-flex justify-content-between align-items-center p-4">
                <h5 class="card-header-title mb-0">Latest Users</h5>
                <a href="{{ path('app_admin_users_index') }}" class="btn btn-link p-0 mb-0">View all</a>
            </div>
            <div class="card-body p-4">
                {% if users is empty %}
                    <p class="mb-0">No users found.</p>
                {% else %}
                    <ul class="list-group list-group-flush">
                        {% for user in users %}
                            <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                <span>{{ (user.firstName ?: '') ~ ' ' ~ (user.lastName ?: '')|trim ?: user.email }} <small class="text-muted">({{ user.email }})</small></span>
                                <span class="badge bg-{{ user.isActive ? 'success' : 'secondary' }}">{{ user.isActive ? 'Enabled' : 'Disabled' }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}{% endblock %}
