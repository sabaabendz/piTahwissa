{% extends 'baseback.html.twig' %}

{% block title %}Dashboard - Backoffice{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12 mb-3">
        <h1 class="h3 mb-2 mb-sm-0">Dashboard</h1>
    </div>
</div>
<div class="row g-4 mb-4">
    <div class="col-md-6 col-xxl-3">
        <div class="card card-body bg-primary bg-opacity-10 p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-0 fw-bold">{{ totalProjets }}</h2>
                    <span class="mb-0 h6 fw-light">Projets</span>
                </div>
                <div class="icon-lg rounded-circle bg-primary text-white mb-0"><i class="bi bi-folder"></i></div>
            </div>
            <a href="{{ path('app_admin_projet_index') }}" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-md-6 col-xxl-3">
        <div class="card card-body bg-success bg-opacity-10 p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-0 fw-bold">{{ totalTaches }}</h2>
                    <span class="mb-0 h6 fw-light">Tâches</span>
                </div>
                <div class="icon-lg rounded-circle bg-success text-white mb-0"><i class="bi bi-list-task"></i></div>
            </div>
            <a href="{{ path('app_admin_tache_index') }}" class="stretched-link"></a>
        </div>
    </div>
</div>
<div class="row g-4">
    <div class="col-lg-6">
        <div class="card shadow h-100">
            <div class="card-header border-bottom d-flex justify-content-between align-items-center p-4">
                <h5 class="card-header-title mb-0">Derniers projets</h5>
                <a href="{{ path('app_admin_projet_index') }}" class="btn btn-link p-0 mb-0">Voir tout</a>
            </div>
            <div class="card-body p-4">
                {% if projets is empty %}
                    <p class="mb-0">Aucun projet.</p>
                {% else %}
                    <ul class="list-group list-group-flush">
                        {% for p in projets %}
                            <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                <a href="{{ path('app_admin_projet_show', { id: p.id }) }}">{{ p.nom }}</a>
                                <span class="badge bg-{{ p.statut == 'termine' ? 'success' : (p.statut == 'actif' ? 'primary' : 'secondary') }}">{{ p.statut == 'termine' ? 'Terminé' : (p.statut == 'actif' ? 'Actif' : 'En attente') }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card shadow h-100">
            <div class="card-header border-bottom d-flex justify-content-between align-items-center p-4">
                <h5 class="card-header-title mb-0">Dernières tâches</h5>
                <a href="{{ path('app_admin_tache_index') }}" class="btn btn-link p-0 mb-0">Voir tout</a>
            </div>
            <div class="card-body p-4">
                {% if taches is empty %}
                    <p class="mb-0">Aucune tâche.</p>
                {% else %}
                    <ul class="list-group list-group-flush">
                        {% for t in taches %}
                            <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                <a href="{{ path('app_admin_tache_show', { id: t.id }) }}">{{ t.libelle }}</a>
                                <span class="badge bg-secondary">{{ t.projet.nom }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
