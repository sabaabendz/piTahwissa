{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
<div class="row g-3">
    <div class="col-md-6">
        {{ form_row(form.email) }}
    </div>
    <div class="col-md-6">
        {{ form_row(form.role) }}
    </div>

    <div class="col-md-6">
        {{ form_row(form.plainPassword.first) }}
    </div>
    <div class="col-md-6">
        {{ form_row(form.plainPassword.second) }}
    </div>

    <div class="col-md-6">
        {{ form_row(form.firstName) }}
    </div>
    <div class="col-md-6">
        {{ form_row(form.lastName) }}
    </div>

    <div class="col-md-6">
        {{ form_row(form.phone) }}
    </div>
    <div class="col-md-6 d-flex align-items-center gap-4 mt-4">
        <div class="form-check">
            {{ form_widget(form.isActive) }}
            {{ form_label(form.isActive) }}
        </div>
        <div class="form-check">
            {{ form_widget(form.isVerified) }}
            {{ form_label(form.isVerified) }}
        </div>
    </div>

    <div class="col-12">
        {{ form_row(form.description) }}
    </div>

    <div class="col-md-6">
        {{ form_row(form.address) }}
    </div>
    <div class="col-md-3">
        {{ form_row(form.city) }}
    </div>
    <div class="col-md-3">
        {{ form_row(form.country) }}
    </div>

    <div class="col-md-6">
        {{ form_row(form.latitude) }}
    </div>
    <div class="col-md-6">
        {{ form_row(form.longitude) }}
    </div>

    {% if user.id %}
        <div class="col-md-6">
            <label class="form-label">Created at</label>
            <input type="text" class="form-control" value="{{ user.createdAt ? user.createdAt|date('Y-m-d H:i:s') : '-' }}" readonly>
        </div>
        <div class="col-md-6">
            <label class="form-label">Updated at</label>
            <input type="text" class="form-control" value="{{ user.updatedAt ? user.updatedAt|date('Y-m-d H:i:s') : '-' }}" readonly>
        </div>
    {% endif %}
</div>

<div class="d-flex gap-2 mt-4">
    <button type="submit" class="btn btn-primary">{{ button_label|default('Save') }}</button>
    <a href="{{ path('app_admin_users_index') }}" class="btn btn-outline-secondary">Back to list</a>
    {% if user.id %}
        <a href="{{ path('app_admin_users_show', {'id': user.id}) }}" class="btn btn-outline-info">Show</a>
    {% endif %}
</div>
{{ form_end(form) }}
