<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Email</th>
                        <th>First name</th>
                        <th>Last name</th>
                        <th>Phone</th>
                        <th>Role</th>
                        <th>Active</th>
                        <th>Verified</th>
                        <th>Created at</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                        <tr>
                            <td>{{ user.id }}</td>
                            <td>{{ user.email }}</td>
                            <td>{{ user.firstName ?: '-' }}</td>
                            <td>{{ user.lastName ?: '-' }}</td>
                            <td>{{ user.phone ?: '-' }}</td>
                            <td>
                                {% set roleName = user.role ? user.role.name : 'USER' %}
                                {% if roleName == 'ADMIN' %}
                                    <span class="badge bg-danger">Admin</span>
                                {% elseif roleName == 'AGENT' %}
                                    <span class="badge bg-primary">Agent</span>
                                {% else %}
                                    <span class="badge bg-secondary">User</span>
                                {% endif %}
                            </td>
                            <td>
                                <span class="badge bg-{{ user.isActive ? 'success' : 'secondary' }}">{{ user.isActive ? 'Yes' : 'No' }}</span>
                            </td>
                            <td>
                                <span class="badge bg-{{ user.isVerified ? 'info' : 'warning' }}">{{ user.isVerified ? 'Yes' : 'No' }}</span>
                            </td>
                            <td>
                                {{ user.createdAt ? user.createdAt|date('Y-m-d H:i') : '-' }}
                            </td>
                            <td class="text-end">
                                {% if app.user and user.id != app.user.id %}
                                    <div class="btn-group" role="group">
                                        <a href="{{ path('app_admin_users_show', {'id': user.id}) }}" class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-eye me-1"></i>Show
                                        </a>

                                        <a href="{{ path('app_admin_users_edit', {'id': user.id}) }}" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil-square me-1"></i>Edit
                                        </a>

                                        <form method="post" action="{{ path('app_admin_users_toggle_active', {'id': user.id}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle-active-' ~ user.id) }}">
                                            <button type="submit" class="btn btn-sm {{ user.isActive ? 'btn-warning' : 'btn-success' }}" onclick="return confirm('Are you sure you want to {{ user.isActive ? 'disable' : 'enable' }} this user?')">
                                                <i class="bi bi-{{ user.isActive ? 'pause-circle' : 'play-circle' }} me-1"></i>{{ user.isActive ? 'Disable' : 'Enable' }}
                                            </button>
                                        </form>

                                        <form method="post" action="{{ path('app_admin_users_toggle_verified', {'id': user.id}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle-verified-' ~ user.id) }}">
                                            <button type="submit" class="btn btn-sm {{ user.isVerified ? 'btn-outline-warning' : 'btn-outline-info' }}">
                                                <i class="bi bi-patch-check me-1"></i>{{ user.isVerified ? 'Unverify' : 'Verify' }}
                                            </button>
                                        </form>

                                        <form method="post" action="{{ path('app_admin_users_change_role', {'id': user.id}) }}" class="d-inline d-flex gap-1 align-items-center">
                                            <input type="hidden" name="_token" value="{{ csrf_token('change-role-' ~ user.id) }}">
                                            <select class="form-select form-select-sm" name="role_id">
                                                {% for role in roles %}
                                                    <option value="{{ role.id }}" {{ user.role and user.role.id == role.id ? 'selected' : '' }}>{{ role.name }}</option>
                                                {% endfor %}
                                            </select>
                                            <button type="submit" class="btn btn-sm btn-outline-primary">Set role</button>
                                        </form>

                                        <form method="post" action="{{ path('app_admin_users_delete', {'id': user.id}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete-user-' ~ user.id) }}">
                                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete {{ user.email }}? This action cannot be undone.')">
                                                <i class="bi bi-trash me-1"></i>Delete
                                            </button>
                                        </form>
                                    </div>
                                {% else %}
                                    <span class="badge bg-info">You</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="10" class="text-center py-4 text-muted">No users found</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>