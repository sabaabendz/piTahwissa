{% extends 'base_admin.html.twig' %}

{% block title %}User Management - Admin{% endblock %}

{% block body %}
<div class="container-fluid p-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="h3 mb-2">User Management</h1>
            <p class="text-muted">Manage all users, enable/disable accounts, and control access</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar avatar-sm bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 35px; height: 35px;">
                                            {{ user.name|first|upper }}
                                        </div>
                                        <strong>{{ user.name }}</strong>
                                    </div>
                                </td>
                                <td>{{ user.email }}</td>
                                <td>
                                    {% if 'ROLE_ADMIN' in user.roles %}
                                        <span class="badge bg-danger">Admin</span>
                                    {% elseif 'ROLE_MANAGER' in user.roles %}
                                        <span class="badge bg-primary">Manager</span>
                                    {% elseif 'ROLE_COLLABORATOR' in user.roles %}
                                        <span class="badge bg-success">Collaborator</span>
                                    {% else %}
                                        <span class="badge bg-secondary">User</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if user.isEnabled %}
                                        <span class="badge bg-success-soft text-success">
                                            <i class="bi bi-check-circle me-1"></i>Active
                                        </span>
                                    {% else %}
                                        <span class="badge bg-danger-soft text-danger">
                                            <i class="bi bi-x-circle me-1"></i>Disabled
                                        </span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    {% if user.idUser != app.user.idUser %}
                                        <div class="btn-group" role="group">
                                            <!-- Enable/Disable Toggle -->
                                            <form method="post" action="{{ path('app_admin_users_toggle_status', {'id': user.idUser}) }}" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('toggle-status-' ~ user.idUser) }}">
                                                <button type="submit" class="btn btn-sm {{ user.isEnabled ? 'btn-warning' : 'btn-success' }}" 
                                                        onclick="return confirm('Are you sure you want to {{ user.isEnabled ? 'disable' : 'enable' }} this user?')">
                                                    <i class="bi bi-{{ user.isEnabled ? 'pause-circle' : 'play-circle' }} me-1"></i>
                                                    {{ user.isEnabled ? 'Disable' : 'Enable' }}
                                                </button>
                                            </form>

                                            <!-- Delete Button -->
                                            <form method="post" action="{{ path('app_admin_users_delete', {'id': user.idUser}) }}" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete-user-' ~ user.idUser) }}">
                                                <button type="submit" class="btn btn-sm btn-danger" 
                                                        onclick="return confirm('Are you sure you want to delete {{ user.name }}? This action cannot be undone.')">
                                                    <i class="bi bi-trash me-1"></i>Delete
                                                </button>
                                            </form>
                                        </div>
                                    {% else %}
                                        <span class="badge bg-info">You</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    No users found
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-success-soft {
        background-color: rgba(25, 135, 84, 0.1);
    }
    .bg-danger-soft {
        background-color: rgba(220, 53, 69, 0.1);
    }
</style>
{% endblock %}
