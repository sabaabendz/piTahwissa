{% extends 'baseback.html.twig' %}

{% block title %}{{ projet.nom }} - Backoffice{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12 d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">{{ projet.nom }}</h1>
        <form method="post" action="{{ path('app_admin_projet_delete', { id: projet.id }) }}" class="d-inline" onsubmit="return confirm('Supprimer ce projet ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('admin_delete' ~ projet.id) }}">
            <button type="submit" class="btn btn-danger">Supprimer</button>
        </form>
    </div>
</div>
<div class="row">
    <div class="col-lg-8">
        <div class="card shadow mb-4">
            <div class="card-body">
                <p class="text-muted small mb-1">Description</p>
                <p class="mb-0">{{ projet.description ?: 'Aucune description.' }}</p>
            </div>
        </div>
        <div class="card shadow">
            <div class="card-header"><h5 class="mb-0">Tâches du projet</h5></div>
            <div class="card-body">
                {% if projet.taches is empty %}
                    <p class="mb-0">Aucune tâche.</p>
                {% else %}
                    <ul class="list-group list-group-flush">
                        {% for t in projet.taches %}
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <a href="{{ path('app_admin_tache_show', { id: t.id }) }}">{{ t.libelle }}</a>
                                <span class="badge bg-{{ t.etat == 'termine' ? 'success' : (t.etat == 'en_cours' ? 'info' : 'secondary') }}">{{ t.etat == 'termine' ? 'Terminé' : (t.etat == 'en_cours' ? 'En cours' : 'À faire') }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow">
            <div class="card-body">
                <p class="mb-1"><strong>Date de début</strong><br>{{ projet.dateDebut ? projet.dateDebut|date('d/m/Y') : '-' }}</p>
                <p class="mb-1"><strong>Date d'échéance</strong><br>{{ projet.dateEcheance ? projet.dateEcheance|date('d/m/Y') : '-' }}</p>
                <p class="mb-0"><strong>Statut</strong><br>{% if projet.statut == 'en_attente' %}<span class="badge bg-secondary">En attente</span>{% elseif projet.statut == 'actif' %}<span class="badge bg-primary">Actif</span>{% else %}<span class="badge bg-success">Terminé</span>{% endif %}</p>
            </div>
        </div>
        <a href="{{ path('app_admin_projet_index') }}" class="btn btn-outline-secondary mt-3">Retour à la liste</a>
    </div>
</div>
{% endblock %}
