{% extends 'baseback.html.twig' %}

{% block title %}Projets - Backoffice{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12 mb-3">
        <h1 class="h3 mb-2 mb-sm-0">Projets (consultation et suppression)</h1>
    </div>
</div>
<div class="row mb-4">
    <div class="col-12">
        <form method="get" action="{{ path('app_admin_projet_index') }}" class="row g-2">
            <div class="col-auto">
                <input type="text" name="search" value="{{ search ?? '' }}" class="form-control" placeholder="Rechercher (nom, description)">
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Rechercher</button>
            </div>
        </form>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card shadow">
            <div class="card-body">
                {% if projets is empty %}
                    <p class="mb-0">Aucun projet.</p>
                {% else %}
                    {% set nextOrder = order == 'ASC' ? 'DESC' : 'ASC' %}
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th><a href="{{ path('app_admin_projet_index', { search: search, sort: 'id', order: sortBy == 'id' ? nextOrder : 'ASC' }) }}">ID</a></th>
                                    <th><a href="{{ path('app_admin_projet_index', { search: search, sort: 'nom', order: sortBy == 'nom' ? nextOrder : 'ASC' }) }}">Nom</a></th>
                                    <th>Description</th>
                                    <th><a href="{{ path('app_admin_projet_index', { search: search, sort: 'dateDebut', order: sortBy == 'dateDebut' ? nextOrder : 'ASC' }) }}">Date début</a></th>
                                    <th><a href="{{ path('app_admin_projet_index', { search: search, sort: 'dateEcheance', order: sortBy == 'dateEcheance' ? nextOrder : 'ASC' }) }}">Échéance</a></th>
                                    <th><a href="{{ path('app_admin_projet_index', { search: search, sort: 'statut', order: sortBy == 'statut' ? nextOrder : 'ASC' }) }}">Statut</a></th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for p in projets %}
                                    <tr>
                                        <td>{{ p.id }}</td>
                                        <td><a href="{{ path('app_admin_projet_show', { id: p.id }) }}">{{ p.nom }}</a></td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="text-muted small">{{ p.description|length > 50 ? p.description|slice(0, 50) ~ '...' : (p.description ?: 'Aucune description') }}</span>
                                                {% if p.description %}
                                                    <button type="button" 
                                                            class="btn btn-sm btn-outline-primary vocal-briefing-btn" 
                                                            data-projet-id="{{ p.id }}"
                                                            data-projet-nom="{{ p.nom }}"
                                                            data-projet-description="{{ p.description|e('js') }}"
                                                            title="Morning Briefing Vocal">
                                                        <i class="bi bi-play-circle"></i>
                                                    </button>
                                                {% endif %}
                                            </div>
                                        </td>
                                        <td>{{ p.dateDebut ? p.dateDebut|date('d/m/Y') : '-' }}</td>
                                        <td>{{ p.dateEcheance ? p.dateEcheance|date('d/m/Y') : '-' }}</td>
                                        <td>
                                            {% if p.statut == 'en_attente' %}<span class="badge bg-secondary">En attente</span>
                                            {% elseif p.statut == 'actif' %}<span class="badge bg-primary">Actif</span>
                                            {% else %}<span class="badge bg-success">Terminé</span>{% endif %}
                                        </td>
                                        <td class="text-end">
                                            <a href="{{ path('app_admin_projet_show', { id: p.id }) }}" class="btn btn-sm btn-light">Voir</a>
                                            <form method="post" action="{{ path('app_admin_projet_delete', { id: p.id }) }}" class="d-inline" onsubmit="return confirm('Supprimer ce projet ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('admin_delete' ~ p.id) }}">
                                                <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                                            </form>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
class MorningBriefingVocal {
    constructor() {
        this.synthesis = window.speechSynthesis;
        this.currentUtterance = null;
        this.isPlaying = false;
        this.voices = [];
        this.voicesLoaded = false;
        this.loadVoicesPromise = null;
        this.startTimeoutId = null;
        this.engineAvailabilityChecked = false;
        this.engineAvailable = false;
        this.engineErrorNotified = false;
        this.init();
    }

    init() {
        // Vérifier si l'API Web Speech est supportée
        if (!this.synthesis) {
            console.warn('L\'API Web Speech n\'est pas supportée par ce navigateur');
            return;
        }

        this.loadVoicesPromise = this.loadVoices();

        // Attacher les événements aux boutons
        this.attachEventListeners();
    }

    attachEventListeners() {
        document.querySelectorAll('.vocal-briefing-btn').forEach(button => {
            button.addEventListener('click', (e) => {
                e.preventDefault();
                const projetId = button.dataset.projetId;
                const projetNom = button.dataset.projetNom;
                const projetDescription = button.dataset.projetDescription;

                if (this.isPlaying && this.currentProjetId === projetId) {
                    this.stop();
                } else {
                    this.speak(projetId, projetNom, projetDescription, button);
                }
            });
        });
    }

    async speak(projetId, projetNom, projetDescription, button, attempt = 0) {
        const engineOk = await this.ensureEngineAvailable();
        if (!engineOk) {
            return;
        }

        // Arrêter toute lecture en cours
        this.stop();

        await this.loadVoicesPromise;

        // Mettre à jour l'UI
        this.updateButtonUI(button, true);
        this.isPlaying = true;
        this.currentProjetId = projetId;

        // Créer le message vocal
        const message = this.createBriefingMessage(projetNom, projetDescription);
        
        // Créer l'utterance
        this.currentUtterance = new SpeechSynthesisUtterance(message);
        
        // Configurer la voix (français si disponible)
        this.configureVoice(attempt);
        
        // Événements
        this.currentUtterance.onstart = () => {
            if (this.startTimeoutId) {
                clearTimeout(this.startTimeoutId);
                this.startTimeoutId = null;
            }
        };

        this.currentUtterance.onend = () => {
            this.reset();
            this.updateButtonUI(button, false);
        };

        this.currentUtterance.onerror = async (event) => {
            console.error('Erreur de synthèse vocale:', event);

            if (event?.error === 'synthesis-failed' && attempt < 2) {
                await this.reloadVoices();
                this.speak(projetId, projetNom, projetDescription, button, attempt + 1);
                return;
            }

            this.reset();
            this.updateButtonUI(button, false);
            const detail = event?.error ? ` (${event.error})` : '';
            this.showNotification(`Erreur lors de la lecture vocale${detail}`, 'danger');
        };

        // Démarrer la lecture
        try {
            if (this.synthesis.paused) {
                this.synthesis.resume();
            }

            this.synthesis.speak(this.currentUtterance);

            this.startTimeoutId = setTimeout(async () => {
                if (!this.synthesis.speaking && attempt < 2) {
                    await this.reloadVoices();
                    this.speak(projetId, projetNom, projetDescription, button, attempt + 1);
                } else if (!this.synthesis.speaking) {
                    this.reset();
                    this.updateButtonUI(button, false);
                    this.showNotification('La synthèse vocale ne démarre pas. Vérifiez la sortie audio/voix du système.', 'warning');
                }
            }, 1500);
        } catch (error) {
            console.error('Erreur speak():', error);
            this.reset();
            this.updateButtonUI(button, false);
            this.showNotification('Lecture vocale indisponible sur ce navigateur.', 'warning');
        }
    }

    async ensureEngineAvailable() {
        if (this.engineAvailabilityChecked) {
            if (!this.engineAvailable && !this.engineErrorNotified) {
                this.showNotification('Synthèse vocale indisponible sur ce navigateur/système.', 'warning');
                this.engineErrorNotified = true;
            }
            return this.engineAvailable;
        }

        this.engineAvailabilityChecked = true;

        try {
            await this.loadVoicesPromise;

            this.engineAvailable = await new Promise((resolve) => {
                const probe = new SpeechSynthesisUtterance('test');
                probe.lang = 'en-US';
                probe.volume = 0;
                let settled = false;

                const done = (value) => {
                    if (settled) {
                        return;
                    }
                    settled = true;
                    resolve(value);
                };

                probe.onstart = () => {
                    this.synthesis.cancel();
                    done(true);
                };

                probe.onerror = () => {
                    done(false);
                };

                try {
                    this.synthesis.speak(probe);
                } catch (e) {
                    done(false);
                }

                setTimeout(() => done(false), 1200);
            });
        } catch (e) {
            this.engineAvailable = false;
        }

        if (!this.engineAvailable) {
            this.disableTtsButtons();
            if (!this.engineErrorNotified) {
                this.showNotification('Synthèse vocale indisponible sur ce navigateur/système.', 'warning');
                this.engineErrorNotified = true;
            }
        }

        return this.engineAvailable;
    }

    disableTtsButtons() {
        document.querySelectorAll('.vocal-briefing-btn').forEach((button) => {
            button.disabled = true;
            button.classList.remove('btn-outline-primary', 'btn-outline-danger');
            button.classList.add('btn-outline-secondary');
            button.title = 'Synthèse vocale indisponible';
            button.innerHTML = '<i class="bi bi-volume-mute"></i>';
        });
    }

    createBriefingMessage(nom, description) {
        const date = new Date().toLocaleDateString('fr-FR', { 
            weekday: 'long', 
            year: 'numeric', 
            month: 'long', 
            day: 'numeric' 
        });

        let message = `Briefing du ${date}. `;
        message += `Projet : ${nom}. `;
        
        if (description) {
            message += `Description : ${description}. `;
        }
        
        message += `Voilà le résumé de ce projet.`;

        return message;
    }

    async reloadVoices() {
        this.voicesLoaded = false;
        this.loadVoicesPromise = this.loadVoices();
        await this.loadVoicesPromise;
    }

    loadVoices() {
        return new Promise((resolve) => {
            const complete = () => {
                this.voices = this.synthesis.getVoices() || [];
                this.voicesLoaded = true;
                resolve(this.voices);
            };

            const immediateVoices = this.synthesis.getVoices() || [];
            if (immediateVoices.length > 0) {
                this.voices = immediateVoices;
                this.voicesLoaded = true;
                resolve(this.voices);
                return;
            }

            const onVoicesChanged = () => {
                this.synthesis.removeEventListener('voiceschanged', onVoicesChanged);
                complete();
            };

            this.synthesis.addEventListener('voiceschanged', onVoicesChanged);
            setTimeout(() => {
                if (!this.voicesLoaded) {
                    this.synthesis.removeEventListener('voiceschanged', onVoicesChanged);
                    complete();
                }
            }, 1200);
        });
    }

    selectBestVoice(attempt = 0) {
        const voices = this.voices.length > 0 ? this.voices : (this.synthesis.getVoices() || []);
        if (voices.length === 0) {
            return null;
        }

        if (attempt === 0 || attempt === 1) {
            const preferredFrench = voices.find(v => {
                const lname = (v.name || '').toLowerCase();
                const llang = (v.lang || '').toLowerCase();

                return llang === 'fr-fr'
                    || llang.startsWith('fr-')
                    || llang === 'fr'
                    || lname.includes('french')
                    || lname.includes('français');
            });

            if (preferredFrench) {
                return preferredFrench;
            }
        }

        const anyLocal = voices.find(v => v.localService);
        if (anyLocal) {
            return anyLocal;
        }

        const anyDefault = voices.find(v => v.default);
        if (anyDefault) {
            return anyDefault;
        }

        return voices[0] || null;
    }

    isValidSpeechVoice(candidate) {
        if (!candidate || typeof candidate !== 'object') {
            return false;
        }

        return typeof candidate.name === 'string'
            && typeof candidate.lang === 'string'
            && typeof candidate.localService === 'boolean';
    }

    configureVoice(attempt = 0) {
        // Configurer les paramètres vocaux
        this.currentUtterance.lang = attempt === 0 ? 'fr-FR' : (navigator.language || 'en-US');
        this.currentUtterance.rate = attempt === 2 ? 1 : 0.9;
        this.currentUtterance.pitch = 1;   // Ton normal
        this.currentUtterance.volume = 1;   // Volume maximum

        const selectedVoice = this.selectBestVoice(attempt);
        if (this.isValidSpeechVoice(selectedVoice)) {
            this.currentUtterance.voice = selectedVoice;
            this.currentUtterance.lang = selectedVoice.lang || this.currentUtterance.lang;
        } else if (attempt === 2) {
            this.currentUtterance.voice = null;
            this.currentUtterance.lang = 'en-US';
        }
    }

    stop() {
        if (this.synthesis && this.synthesis.speaking) {
            this.synthesis.cancel();
        }

        if (this.startTimeoutId) {
            clearTimeout(this.startTimeoutId);
            this.startTimeoutId = null;
        }

        this.reset();
    }

    reset() {
        this.isPlaying = false;
        this.currentProjetId = null;
        this.currentUtterance = null;
    }

    updateButtonUI(button, isPlaying) {
        if (isPlaying) {
            button.innerHTML = '<i class="bi bi-stop-circle"></i>';
            button.classList.remove('btn-outline-primary');
            button.classList.add('btn-outline-danger');
            button.title = 'Arrêter la lecture';
        } else {
            button.innerHTML = '<i class="bi bi-play-circle"></i>';
            button.classList.remove('btn-outline-danger');
            button.classList.add('btn-outline-primary');
            button.title = 'Morning Briefing Vocal';
        }
    }

    showNotification(message, type = 'info') {
        // Créer une notification temporaire
        const notification = document.createElement('div');
        notification.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
        notification.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
        notification.innerHTML = `
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        
        document.body.appendChild(notification);
        
        // Auto-suppression après 3 secondes
        setTimeout(() => {
            if (notification.parentNode) {
                notification.remove();
            }
        }, 3000);
    }
}

// Initialiser le système quand le DOM est chargé
document.addEventListener('DOMContentLoaded', () => {
    new MorningBriefingVocal();
});
</script>
{% endblock %}
