{% extends 'basefront.html.twig' %}

{% block title %}Modifier {{ tache.libelle }}{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12">
        <h1 class="h3 mb-4">Modifier la tâche</h1>
        <div class="card shadow">
            <div class="card-body">
                {{ form_start(form) }}
                {{ form_row(form.libelle) }}
                {{ form_row(form.projet) }}
                {{ form_row(form.priorite) }}
                {{ form_row(form.dateLimite) }}
                {{ form_row(form.etat) }}
                {{ form_rest(form) }}
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                    <a href="{{ path('app_tache_show', { id: tache.id }) }}" class="btn btn-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
