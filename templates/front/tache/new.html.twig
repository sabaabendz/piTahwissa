{% extends 'base_admin.html.twig' %}

{% block title %}Nouvelle tâche{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12">
        <h1 class="h3 mb-4">Nouvelle tâche</h1>
        <div class="card shadow">
            <div class="card-body">
                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                <div class="mb-3">
                    {{ form_label(form.libelle) }}
                    {{ form_widget(form.libelle) }}
                    {{ form_errors(form.libelle) }}
                </div>
                <div class="mb-3">
                    {{ form_label(form.projet) }}
                    {{ form_widget(form.projet) }}
                    {{ form_errors(form.projet) }}
                </div>
                <div class="mb-3">
                    {{ form_label(form.priorite) }}
                    {{ form_widget(form.priorite) }}
                    {{ form_errors(form.priorite) }}
                </div>
                <div class="mb-3">
                    {{ form_label(form.dateLimite) }}
                    {{ form_widget(form.dateLimite) }}
                    {{ form_errors(form.dateLimite) }}
                </div>
                <div class="mb-3">
                    {{ form_label(form.etat) }}
                    {{ form_widget(form.etat) }}
                    {{ form_errors(form.etat) }}
                </div>
                {{ form_rest(form) }}
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Créer</button>
                    <a href="{{ path('app_tache_index') }}" class="btn btn-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
