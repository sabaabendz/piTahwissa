{% extends 'basefront.html.twig' %}

{% block title %}Tâches{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12 d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Tâches</h1>
        <a href="{{ path('app_tache_new') }}" class="btn btn-primary">Nouvelle tâche</a>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card shadow">
            <div class="card-body">
                {% if taches is empty %}
                    <p class="mb-0">Aucune tâche. <a href="{{ path('app_tache_new') }}">Créer une tâche</a> (liée à un projet).</p>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Libellé</th>
                                    <th>Projet</th>
                                    <th>Priorité</th>
                                    <th>Date limite</th>
                                    <th>État</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for t in taches %}
                                    <tr>
                                        <td><a href="{{ path('app_tache_show', { id: t.id }) }}">{{ t.libelle }}</a></td>
                                        <td><a href="{{ path('app_projet_show', { id: t.projet.id }) }}">{{ t.projet.nom }}</a></td>
                                        <td>
                                            <span class="badge bg-{{ t.priorite == 'haute' ? 'danger' : (t.priorite == 'moyenne' ? 'warning' : 'secondary') }}">{{ t.priorite|capitalize }}</span>
                                        </td>
                                        <td>{{ t.dateLimite ? t.dateLimite|date('d/m/Y') : '-' }}</td>
                                        <td>
                                            {% if t.etat == 'a_faire' %}<span class="badge bg-secondary">À faire</span>
                                            {% elseif t.etat == 'en_cours' %}<span class="badge bg-info">En cours</span>
                                            {% else %}<span class="badge bg-success">Terminé</span>{% endif %}
                                        </td>
                                        <td class="text-end">
                                            <a href="{{ path('app_tache_show', { id: t.id }) }}" class="btn btn-sm btn-light">Voir</a>
                                            <a href="{{ path('app_tache_edit', { id: t.id }) }}" class="btn btn-sm btn-outline-primary">Modifier</a>
                                            <form method="post" action="{{ path('app_tache_delete', { id: t.id }) }}" class="d-inline" onsubmit="return confirm('Supprimer cette tâche ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ t.id) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                                            </form>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
