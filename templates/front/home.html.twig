{% extends 'basefront.html.twig' %}

{% block title %}Accueil - Gestion des projets{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12">
        <h1 class="h3 mb-4">Gestion des projets</h1>
        <p class="lead">Bienvenue. Gérez vos projets et tâches depuis le frontoffice.</p>
        <div class="row g-4 mt-2">
            <div class="col-md-6">
                <div class="card card-body bg-primary bg-opacity-10 p-4 h-100">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-1">Projets</h5>
                            <p class="mb-0 small">Créer, modifier, consulter et supprimer des projets.</p>
                            <a href="{{ path('app_projet_index') }}" class="btn btn-primary btn-sm mt-2">Voir les projets</a>
                            <a href="{{ path('app_projet_new') }}" class="btn btn-outline-primary btn-sm mt-2">Nouveau projet</a>
                        </div>
                        <div class="icon-lg rounded-circle bg-primary text-white"><i class="bi bi-folder"></i></div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card card-body bg-success bg-opacity-10 p-4 h-100">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-1">Tâches</h5>
                            <p class="mb-0 small">Chaque tâche est liée à un projet. Gérez vos tâches ici.</p>
                            <a href="{{ path('app_tache_index') }}" class="btn btn-success btn-sm mt-2">Voir les tâches</a>
                            <a href="{{ path('app_tache_new') }}" class="btn btn-outline-success btn-sm mt-2">Nouvelle tâche</a>
                        </div>
                        <div class="icon-lg rounded-circle bg-success text-white"><i class="bi bi-list-task"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
