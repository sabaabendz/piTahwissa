{% extends 'base_admin.html.twig' %}

{% block title %}{{ projet.nom }}{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12 d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">{{ projet.nom }}</h1>
        <div>
            <a href="{{ path('app_projet_edit', { id: projet.id }) }}" class="btn btn-primary">Modifier</a>
            <form method="post" action="{{ path('app_projet_delete', { id: projet.id }) }}" class="d-inline" onsubmit="return confirm('Supprimer ce projet ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ projet.id) }}">
                <button type="submit" class="btn btn-danger">Supprimer</button>
            </form>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-lg-8">
        <div class="card shadow mb-4">
            <div class="card-body">
                <p class="text-muted small mb-1">Description</p>
                <p class="mb-0">{{ projet.description ?: 'Aucune description.' }}</p>
            </div>
        </div>
        <div class="card shadow">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Tâches du projet</h5>
                <a href="{{ path('app_tache_new') }}?projet={{ projet.id }}" class="btn btn-sm btn-primary">Ajouter une tâche</a>
            </div>
            <div class="card-body">
                {% if projet.taches is empty %}
                    <p class="mb-0">Aucune tâche. <a href="{{ path('app_tache_new') }}">Créer une tâche</a> pour ce projet.</p>
                {% else %}
                    <ul class="list-group list-group-flush">
                        {% for t in projet.taches %}
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <a href="{{ path('app_tache_show', { id: t.id }) }}">{{ t.libelle }}</a>
                                <span class="badge bg-{{ t.priorite == 'haute' ? 'danger' : (t.priorite == 'moyenne' ? 'warning' : 'secondary') }}">{{ t.priorite|capitalize }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow">
            <div class="card-body">
                <p class="mb-1"><strong>Date de début</strong><br>{{ projet.dateDebut ? projet.dateDebut|date('d/m/Y') : '-' }}</p>
                <p class="mb-1"><strong>Date d'échéance</strong><br>{{ projet.dateEcheance ? projet.dateEcheance|date('d/m/Y') : '-' }}</p>
                <p class="mb-0">
                    <strong>Statut</strong><br>
                    {% if projet.statut == 'en_attente' %}<span class="badge bg-secondary">En attente</span>
                    {% elseif projet.statut == 'actif' %}<span class="badge bg-primary">Actif</span>
                    {% else %}<span class="badge bg-success">Terminé</span>{% endif %}
                </p>
            </div>
        </div>
        <a href="{{ path('app_projet_index') }}" class="btn btn-outline-secondary mt-3">Retour à la liste</a>
    </div>
</div>
{% endblock %}
