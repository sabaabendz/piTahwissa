{% extends 'basefront.html.twig' %}

{% block title %}Projets{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12 d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Projets</h1>
        <a href="{{ path('app_projet_new') }}" class="btn btn-primary">Nouveau projet</a>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card shadow">
            <div class="card-body">
                {% if projets is empty %}
                    <div class="text-center py-5">
                        <div class="mb-3">
                            <i class="bi bi-folder-x display-1 text-muted"></i>
                        </div>
                        <h4 class="text-muted">Aucun projet trouvé</h4>
                        <p class="text-muted mb-4">Commencez par créer votre premier projet.</p>
                        <a href="{{ path('app_projet_new') }}" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-2"></i>Nouveau projet
                        </a>
                    </div>
                {% else %}
                    <div class="row g-4">
                        {% for p in projets %}
                            <div class="col-lg-4 col-md-6">
                                <div class="card h-100 shadow-sm border-0">
                                    <div class="card-body d-flex flex-column">
                                        <!-- Header avec statut -->
                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <h5 class="card-title mb-0">
                                                <a href="{{ path('app_projet_show', { id: p.id }) }}" class="text-decoration-none text-dark">
                                                    {{ p.nom|length > 30 ? p.nom|slice(0, 30) ~ '...' : p.nom }}
                                                </a>
                                            </h5>
                                            {% if p.statut == 'en_attente' %}
                                                <span class="badge bg-secondary">En attente</span>
                                            {% elseif p.statut == 'actif' %}
                                                <span class="badge bg-primary">Actif</span>
                                            {% else %}
                                                <span class="badge bg-success">Terminé</span>
                                            {% endif %}
                                        </div>
                                        
                                        <!-- Description si présente -->
                                        {% if p.description %}
                                            <p class="card-text text-muted small mb-3">
                                                {{ p.description|length > 100 ? p.description|slice(0, 100) ~ '...' : p.description }}
                                            </p>
                                        {% endif %}
                                        
                                        <!-- Informations principales -->
                                        <div class="row g-2 mb-3">
                                            <div class="col-6">
                                                <div class="d-flex align-items-center">
                                                    <i class="bi bi-calendar-event text-primary me-2"></i>
                                                    <div>
                                                        <small class="text-muted d-block">Début</small>
                                                        <strong>{{ p.dateDebut ? p.dateDebut|date('d/m/Y') : '-' }}</strong>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-6">
                                                <div class="d-flex align-items-center">
                                                    <i class="bi bi-calendar-check text-danger me-2"></i>
                                                    <div>
                                                        <small class="text-muted d-block">Échéance</small>
                                                        <strong>{{ p.dateEcheance ? p.dateEcheance|date('d/m/Y') : '-' }}</strong>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <!-- Nombre de tâches -->
                                        <div class="mb-3">
                                            <small class="text-muted">
                                                <i class="bi bi-list-task me-1"></i>
                                                {{ p.taches|length }} tâche{{ p.taches|length > 1 ? 's' : '' }}
                                            </small>
                                        </div>
                                        
                                        <!-- Actions -->
                                        <div class="mt-auto">
                                            <div class="btn-group w-100" role="group">
                                                <a href="{{ path('app_projet_show', { id: p.id }) }}" class="btn btn-outline-primary btn-sm">
                                                    <i class="bi bi-eye me-1"></i>Voir
                                                </a>
                                                <a href="{{ path('app_projet_edit', { id: p.id }) }}" class="btn btn-outline-secondary btn-sm">
                                                    <i class="bi bi-pencil me-1"></i>Modifier
                                                </a>
                                                <form method="post" action="{{ path('app_projet_delete', { id: p.id }) }}" class="d-inline" onsubmit="return confirm('Supprimer ce projet ?');">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ p.id) }}">
                                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                                        <i class="bi bi-trash me-1"></i>Supprimer
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
