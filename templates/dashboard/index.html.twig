{% extends 'base_admin.html.twig' %}

{% block title %}Dashboard - SmartTask Manager{% endblock %}

{% block body %}
	<!-- Title -->
	<div class="row">
		<div class="col-12 mb-3">
			<h1 class="h3 mb-2 mb-sm-0">Dashboard</h1>
		</div>
	</div>

	<!-- Counter boxes START -->
	<div class="row g-4 mb-4">
		<!-- Counter item - Managers -->
		<div class="col-md-6 col-xxl-3">
			<div class="card card-body bg-warning bg-opacity-15 p-4 h-100">
				<div class="d-flex justify-content-between align-items-center">
					<!-- Digit -->
					<div>
						<h2 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="{{ managers_count }}" data-purecounter-delay="200">0</h2>
						<span class="mb-0 h6 fw-light">Total Managers</span>
					</div>
					<!-- Icon -->
					<div class="icon-lg rounded-circle bg-warning text-white mb-0"><i class="fas fa-user-tie fa-fw"></i></div>
				</div>
			</div>
		</div>

		<!-- Counter item - Collaborators -->
		<div class="col-md-6 col-xxl-3">
			<div class="card card-body bg-purple bg-opacity-10 p-4 h-100">
				<div class="d-flex justify-content-between align-items-center">
					<!-- Digit -->
					<div>
						<h2 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="{{ collaborators_count }}" data-purecounter-delay="200">0</h2>
						<span class="mb-0 h6 fw-light">Total Collaborators</span>
					</div>
					<!-- Icon -->
					<div class="icon-lg rounded-circle bg-purple text-white mb-0"><i class="fas fa-user-graduate fa-fw"></i></div>
				</div>
			</div>
		</div>

		<!-- Counter item - Projects -->
		<div class="col-md-6 col-xxl-3">
			<div class="card card-body bg-primary bg-opacity-10 p-4 h-100">
				<div class="d-flex justify-content-between align-items-center">
					<!-- Digit -->
					<div>
						<h2 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="{{ projects_count }}" data-purecounter-delay="200">0</h2>
						<span class="mb-0 h6 fw-light">Total Projects</span>
					</div>
					<!-- Icon -->
					<div class="icon-lg rounded-circle bg-primary text-white mb-0"><i class="fas fa-project-diagram fa-fw"></i></div>
				</div>
			</div>
		</div>

		<!-- Counter item - Tasks -->
		<div class="col-md-6 col-xxl-3">
			<div class="card card-body bg-info bg-opacity-10 p-4 h-100">
				<div class="d-flex justify-content-between align-items-center">
					<!-- Digit -->
					<div>
						<h2 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="{{ tasks_count }}" data-purecounter-delay="200">0</h2>
						<span class="mb-0 h6 fw-light">Total Tasks</span>
					</div>
					<!-- Icon -->
					<div class="icon-lg rounded-circle bg-info text-white mb-0"><i class="fas fa-tasks fa-fw"></i></div>
				</div>
			</div>
		</div>

		<!-- Counter item - Meetings -->
		<div class="col-md-6 col-xxl-3">
			<div class="card card-body bg-success bg-opacity-10 p-4 h-100">
				<div class="d-flex justify-content-between align-items-center">
					<!-- Digit -->
					<div>
						<h2 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="0" data-purecounter-delay="200">0</h2>
						<span class="mb-0 h6 fw-light">Upcoming Meetings</span>
					</div>
					<!-- Icon -->
					<div class="icon-lg rounded-circle bg-success text-white mb-0"><i class="bi bi-calendar-event fa-fw"></i></div>
				</div>
			</div>
		</div>
	</div>
	<!-- Counter boxes END -->

	<!-- Quick Actions START -->
	<div class="row g-4 mb-4">
		<div class="col-12">
			<div class="card shadow">
				<div class="card-header border-bottom p-4">
					<h5 class="card-header-title mb-0">Quick Actions</h5>
				</div>
				<div class="card-body p-4">
					<div class="row g-3">
						<div class="col-md-3">
							<a href="{{ path('app_manager_new') }}" class="btn btn-outline-warning w-100">
								<i class="fas fa-user-tie me-2"></i>New Manager
							</a>
						</div>
						<div class="col-md-3">
							<a href="{{ path('app_collaborator_new') }}" class="btn btn-outline-purple w-100">
								<i class="fas fa-user-graduate me-2"></i>New Collaborator
							</a>
						</div>
						<div class="col-md-3">
							<a href="{{ path('app_projet_new') }}" class="btn btn-primary w-100">
								<i class="fas fa-project-diagram me-2"></i>New Project
							</a>
						</div>
						<div class="col-md-3">
							<a href="{{ path('app_tache_new') }}" class="btn btn-info w-100">
								<i class="fas fa-tasks me-2"></i>New Task
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- Quick Actions END -->

	<!-- Recent Activity START -->
	<div class="row g-4">
		<div class="col-lg-6">
			<div class="card shadow h-100">
				<div class="card-header border-bottom p-4">
					<h5 class="card-header-title mb-0">Recent Managers</h5>
				</div>
				<div class="card-body p-4">
					<p class="text-muted">No recent managers to display.</p>
				</div>
			</div>
		</div>
		<div class="col-lg-6">
			<div class="card shadow h-100">
				<div class="card-header border-bottom p-4">
					<h5 class="card-header-title mb-0">Recent Collaborators</h5>
				</div>
				<div class="card-body p-4">
					<p class="text-muted">No recent collaborators to display.</p>
				</div>
			</div>
		</div>
	</div>
	<!-- Recent Activity END -->
{% endblock %}

{% block javascripts %}
	<script>
		// Initialize purecounter if available
		if (typeof PureCounter !== 'undefined') {
			new PureCounter();
		}
	</script>
{% endblock %}
