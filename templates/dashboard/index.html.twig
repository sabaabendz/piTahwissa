{% extends 'base_admin.html.twig' %}

{% block title %}Dashboard - Tahwissa Manager{% endblock %}

{% block body %}
	<div class="row g-4 align-items-stretch mb-4">
		<div class="col-xl-8">
			<div class="card border-0 shadow-sm h-100">
				<div class="card-body p-4">
					<h1 class="h3 mb-2">Welcome back{% if app.user %}, {{ ((app.user.firstName ?: '') ~ ' ' ~ (app.user.lastName ?: ''))|trim ?: app.user.email }}{% endif %}</h1>
					<p class="text-muted mb-0">Your workspace overview is ready. Use the sidebar to navigate quickly between dashboard, profile and user management.</p>
				</div>
			</div>
		</div>
		<div class="col-xl-4">
			<div class="card border-0 shadow-sm h-100">
				<div class="card-body p-4 d-grid gap-2">
					<a href="{{ path('app_front_profile_edit') }}" class="btn btn-outline-primary">
						<i class="bi bi-person-gear me-2"></i>Edit Profile
					</a>
					{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_AGENT') %}
						<a href="{{ path('app_admin_users_index') }}" class="btn btn-primary">
							<i class="fas fa-users me-2"></i>Open User Management
						</a>
					{% endif %}
				</div>
			</div>
		</div>
	</div>

	<!-- Counter boxes START -->
	<div class="row g-4 mb-4">
		<!-- Counter item - Agents -->
		<div class="col-md-6 col-xxl-3">
			<div class="card card-body bg-warning bg-opacity-15 p-4 h-100">
				<div class="d-flex justify-content-between align-items-center">
					<!-- Digit -->
					<div>
						<h2 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="{{ agents_count }}" data-purecounter-delay="200">0</h2>
						<span class="mb-0 h6 fw-light">Total Agents</span>
					</div>
					<!-- Icon -->
					<div class="icon-lg rounded-circle bg-warning text-white mb-0"><i class="fas fa-user-tie fa-fw"></i></div>
				</div>
			</div>
		</div>

		<!-- Counter item - Users -->
		<div class="col-md-6 col-xxl-3">
			<div class="card card-body bg-purple bg-opacity-10 p-4 h-100">
				<div class="d-flex justify-content-between align-items-center">
					<!-- Digit -->
					<div>
						<h2 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="{{ users_count }}" data-purecounter-delay="200">0</h2>
						<span class="mb-0 h6 fw-light">Total Users</span>
					</div>
					<!-- Icon -->
					<div class="icon-lg rounded-circle bg-purple text-white mb-0"><i class="fas fa-user-graduate fa-fw"></i></div>
				</div>
			</div>
		</div>

		<!-- Counter item - Meetings -->
		<div class="col-md-6 col-xxl-3">
			<div class="card card-body bg-success bg-opacity-10 p-4 h-100">
				<div class="d-flex justify-content-between align-items-center">
					<!-- Digit -->
					<div>
						<h2 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="0" data-purecounter-delay="200">0</h2>
						<span class="mb-0 h6 fw-light">Upcoming Meetings</span>
					</div>
					<!-- Icon -->
					<div class="icon-lg rounded-circle bg-success text-white mb-0"><i class="bi bi-calendar-event fa-fw"></i></div>
				</div>
			</div>
		</div>
	</div>
	<!-- Counter boxes END -->

	<!-- Quick Actions START -->
	{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_AGENT') %}
		<div class="row g-4 mb-4">
			<div class="col-12">
				<div class="card shadow">
					<div class="card-header border-bottom p-4">
						<h5 class="card-header-title mb-0">Quick Actions</h5>
					</div>
					<div class="card-body p-4">
						<div class="row g-3">
							<div class="col-md-12">
								<a href="{{ path('app_admin_users_index') }}" class="btn btn-primary w-100">
									<i class="fas fa-users me-2"></i>Manage Users
								</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	{% endif %}
	<!-- Quick Actions END -->

{% endblock %}

{% block javascripts %}
	<script>
		// Initialize purecounter if available
		if (typeof PureCounter !== 'undefined') {
			new PureCounter();
		}
	</script>
{% endblock %}
