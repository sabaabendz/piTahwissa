{% extends 'base_admin.html.twig' %}

{% block title %}Collaborators - SmartTask Manager{% endblock %}

{% block body %}
	<!-- Title -->
	<div class="row">
		<div class="col-12">
			<div class="d-flex justify-content-between align-items-center">
				<h1 class="h3 mb-2 mb-sm-0">Collaborators</h1>
				<a href="{{ path('app_collaborator_new') }}" class="btn btn-primary mb-0">
					<i class="fas fa-plus me-2"></i>Add Collaborator
				</a>
			</div>
		</div>
	</div>
		
	<div class="card bg-transparent mt-4">
		<!-- Card header START -->
		<div class="card-header bg-transparent border-bottom px-0">
			<!-- Search and select START -->
			<div class="row g-3 align-items-center justify-content-between">
				<!-- Search bar -->
				<div class="col-md-8">
					<form class="rounded position-relative" id="collaboratorSearchForm">
						<input
							id="collaboratorSearchInput"
							class="form-control bg-transparent"
							type="search"
							name="q"
							placeholder="Search collaborators..."
							value="{{ query|default('') }}"
							aria-label="Search"
						>
						<button class="bg-transparent p-2 position-absolute top-50 end-0 translate-middle-y border-0 text-primary-hover text-reset" type="submit">
							<i class="fas fa-search fs-6"></i>
						</button>
					</form>
				</div>
			</div>
			<!-- Search and select END -->
		</div>
		<!-- Card header END -->

		<!-- Card body START -->
		<div class="card-body px-0" id="collaboratorListContainer">
			{% include 'collaborator/_list.html.twig' with {'collaborators': collaborators} %}
		</div>
		<!-- Card body END -->
	</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(() => {
    const form = document.getElementById('collaboratorSearchForm');
    const input = document.getElementById('collaboratorSearchInput');
    const container = document.getElementById('collaboratorListContainer');

    if (!form || !input || !container) {
        return;
    }

    let timer;
    const fetchResults = async () => {
        const params = new URLSearchParams({ q: input.value.trim() });

        try {
            const response = await fetch(`{{ path('app_collaborator_index') }}?${params.toString()}`, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            if (!response.ok) {
                return;
            }

            container.innerHTML = await response.text();
        } catch (error) {
            console.error('Collaborator search failed:', error);
        }
    };

    form.addEventListener('submit', (event) => {
        event.preventDefault();
        fetchResults();
    });

    input.addEventListener('input', () => {
        clearTimeout(timer);
        timer = setTimeout(fetchResults, 300);
    });
})();
</script>
{% endblock %}
