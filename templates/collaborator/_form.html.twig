{{ form_start(form, {'attr': {'class': 'row g-3', 'novalidate': 'novalidate'}}) }}
	<div class="col-md-6">
		{{ form_label(form.name, null, {'label_attr': {'class': 'form-label'}}) }}
		{{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
		{{ form_errors(form.name) }}
	</div>
	<div class="col-md-6">
		{{ form_label(form.email, null, {'label_attr': {'class': 'form-label'}}) }}
		{{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
		{{ form_errors(form.email) }}
	</div>
	<div class="col-md-6">
		{{ form_label(form.password, null, {'label_attr': {'class': 'form-label'}}) }}
		{{ form_widget(form.password, {'attr': {'class': 'form-control'}}) }}
		{{ form_errors(form.password) }}
		{% if form.password.vars.help is defined %}
			<div class="form-text">{{ form.password.vars.help }}</div>
		{% endif %}
	</div>
	<div class="col-md-6">
		{{ form_label(form.enterpriseCode, null, {'label_attr': {'class': 'form-label'}}) }}
		{{ form_widget(form.enterpriseCode, {'attr': {'class': 'form-control', 'placeholder': 'Enter enterprise code'}}) }}
		{{ form_errors(form.enterpriseCode) }}
		<div class="form-text">Enter the enterprise code provided by your manager.</div>
	</div>
	<div class="col-md-6">
		{{ form_label(form.post, null, {'label_attr': {'class': 'form-label'}}) }}
		{{ form_widget(form.post, {'attr': {'class': 'form-control'}}) }}
		{{ form_errors(form.post) }}
	</div>
	<div class="col-md-6">
		{{ form_label(form.team, null, {'label_attr': {'class': 'form-label'}}) }}
		{{ form_widget(form.team, {'attr': {'class': 'form-control'}}) }}
		{{ form_errors(form.team) }}
	</div>
	<div class="col-12">
		<button type="submit" class="btn btn-primary">
			<i class="bi bi-check-lg me-2"></i>{{ button_label|default('Save') }}
		</button>
		<a href="{{ path('app_collaborator_index') }}" class="btn btn-light">
			<i class="bi bi-x-lg me-2"></i>Cancel
		</a>
	</div>
{{ form_end(form) }}
