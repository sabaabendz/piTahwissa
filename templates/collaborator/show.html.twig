{% extends 'base.html.twig' %}

{% block title %}Collaborator{% endblock %}

{% block body %}
    <h1>Collaborator</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>IdUser</th>
                <td>{{ collaborator.idUser }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ collaborator.name }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ collaborator.email }}</td>
            </tr>
            <tr>
                <th>Password</th>
                <td>{{ collaborator.password }}</td>
            </tr>
            <tr>
                <th>Post</th>
                <td>{{ collaborator.post }}</td>
            </tr>
            <tr>
                <th>Team</th>
                <td>{{ collaborator.team }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_collaborator_index') }}">back to list</a>

    <a href="{{ path('app_collaborator_edit', {'idUser': collaborator.idUser}) }}">edit</a>

    {{ include('collaborator/_delete_form.html.twig') }}
{% endblock %}
