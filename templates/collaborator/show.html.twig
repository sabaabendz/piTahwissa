{% extends 'base_admin.html.twig' %}

{% block title %}Collaborator Details - SmartTask Manager{% endblock %}

{% block body %}
	<!-- Title -->
	<div class="row">
		<div class="col-12">
			<div class="d-flex justify-content-between align-items-center">
				<h1 class="h3 mb-2 mb-sm-0">Collaborator Details</h1>
				<div>
					<a href="{{ path('app_collaborator_edit', {'idUser': collaborator.idUser}) }}" class="btn btn-primary mb-0 me-2">
						<i class="bi bi-pencil me-2"></i>Edit
					</a>
					<a href="{{ path('app_collaborator_index') }}" class="btn btn-light mb-0">
						<i class="bi bi-arrow-left me-2"></i>Back to list
					</a>
				</div>
			</div>
		</div>
	</div>

	<div class="card shadow mt-4">
		<div class="card-header border-bottom p-4">
			<div class="d-flex align-items-center">
				<div class="avatar avatar-lg me-3">
					<div class="avatar-img rounded-circle bg-success bg-opacity-10">
						<span class="text-success position-absolute top-50 start-50 translate-middle fw-bold fs-4">{{ collaborator.name|first|upper }}</span>
					</div>
				</div>
				<div>
					<h5 class="mb-0">{{ collaborator.name }}</h5>
					<p class="text-muted mb-0">{{ collaborator.email }}</p>
				</div>
			</div>
		</div>
		<div class="card-body p-4">
			<div class="row g-4">
				<div class="col-md-6">
					<div class="border-bottom pb-3 mb-3">
						<h6 class="text-muted mb-2">ID</h6>
						<p class="mb-0 fw-bold">#{{ collaborator.idUser }}</p>
					</div>
					<div class="border-bottom pb-3 mb-3">
						<h6 class="text-muted mb-2">Post</h6>
						<p class="mb-0 fw-bold">{{ collaborator.post ?? 'N/A' }}</p>
					</div>
				</div>
				<div class="col-md-6">
					<div class="border-bottom pb-3 mb-3">
						<h6 class="text-muted mb-2">Team</h6>
						<p class="mb-0 fw-bold">{{ collaborator.team ?? 'N/A' }}</p>
					</div>
					<div class="border-bottom pb-3 mb-3">
						<h6 class="text-muted mb-2">Enterprise Code</h6>
						<p class="mb-0">
							<span class="badge bg-primary bg-opacity-10 text-primary fs-6">{{ collaborator.enterpriseCode }}</span>
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
