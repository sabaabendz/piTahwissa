{% extends 'base_auth.html.twig' %}

{% block title %}Reset Password - Tahwissa{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/tahwissa-auth.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
{% endblock %}

{% block body %}
<div class="sky-bg">
    <div class="sun"></div>
    <div class="cloud cloud-1"></div>
    <div class="cloud cloud-2"></div>
    <div class="cloud cloud-3"></div>
    <div class="cloud cloud-4"></div>
    <div class="plane plane-1">✈️</div>
    <div class="plane plane-2">🛩️</div>
    <div class="particles" id="particles"></div>

    <div class="auth-page">
        <div class="auth-container">
            <div class="auth-card">
                <div class="auth-header">
                    <div style="width:72px;height:72px;background:linear-gradient(135deg,rgba(124,77,255,0.1),rgba(179,136,255,0.1));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;margin:0 auto 16px;">🔒</div>
                    <h2>Nouveau Mot de Passe</h2>
                    <p>Choisissez un nouveau mot de passe sécurisé</p>
                </div>

                {% for message in app.flashes('error') %}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>{{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}

                <form method="post" novalidate>
                    <div class="form-group">
                        <label for="password">New Password *</label>
                        <div style="position:relative;">
                            <i class="fas fa-lock form-icon" style="top:50%;transform:translateY(-50%);"></i>
                            <input type="password" name="password" class="form-input password-field" placeholder="Min. 8 characters" id="password" required>
                        </div>

                        <div class="password-strength-wrapper mt-2" style="display: none;">
                            <div class="progress" style="height: 6px;">
                                <div id="strengthBar" class="progress-bar" role="progressbar" style="width: 0%"></div>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-1">
                                <small class="text-muted">Strength: <span id="strengthLabel" class="fw-bold">-</span></small>
                            </div>
                            <ul id="strengthSuggestions" class="small text-danger mt-1 mb-0 ps-3" style="display: none;"></ul>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="confirm_password">Confirm New Password *</label>
                        <div style="position:relative;">
                            <i class="fas fa-shield-alt form-icon" style="top:50%;transform:translateY(-50%);"></i>
                            <input type="password" name="confirm_password" class="form-input" placeholder="Retype password" id="confirm_password" required>
                        </div>
                    </div>

                    <button class="btn btn-primary" type="submit" style="width:100%;justify-content:center;padding:14px;">
                        <i class="fas fa-save"></i> Update Password
                    </button>
                </form>

                <div class="auth-footer">
                    <a href="{{ path('app_login') }}"><i class="fas fa-arrow-left"></i> Back to login</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="{{ asset('js/tahwissa-auth.js') }}"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const passwordField = document.querySelector('.password-field');
    const strengthWrapper = document.querySelector('.password-strength-wrapper');
    const strengthBar = document.getElementById('strengthBar');
    const strengthLabel = document.getElementById('strengthLabel');
    const strengthSuggestions = document.getElementById('strengthSuggestions');

    let debounceTimer;

    if (passwordField) {
        passwordField.addEventListener('input', function() {
            const password = this.value;
            
            clearTimeout(debounceTimer);
            if (!password) {
                strengthWrapper.style.display = 'none';
                return;
            }

            strengthWrapper.style.display = 'block';
            
            debounceTimer = setTimeout(() => {
                checkPasswordStrength(password);
            }, 300);
        });
    }

    async function checkPasswordStrength(password) {
        try {
            const response = await fetch('{{ path('api_password_strength') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ password: password })
            });

            if (response.ok) {
                const data = await response.json();
                updateStrengthUI(data);
            }
        } catch (error) {
            console.error('Error checking password strength:', error);
        }
    }

    function updateStrengthUI(data) {
        const { score, label, suggestions } = data;
        
        // Progress bar and label
        let width = '0%';
        let colorClass = 'bg-danger';
        
        if (label === 'weak') {
            width = '33%';
            colorClass = 'bg-danger';
        } else if (label === 'medium') {
            width = '66%';
            colorClass = 'bg-warning';
        } else if (label === 'strong') {
            width = '100%';
            colorClass = 'bg-success';
        }

        strengthBar.style.width = width;
        strengthBar.className = 'progress-bar ' + colorClass;
        strengthLabel.textContent = label.charAt(0).toUpperCase() + label.slice(1);
        strengthLabel.className = 'fw-bold ' + colorClass.replace('bg-', 'text-');

        // Suggestions
        if (suggestions && suggestions.length > 0 && label !== 'strong') {
            strengthSuggestions.innerHTML = '';
            suggestions.forEach(suggestion => {
                const li = document.createElement('li');
                li.textContent = suggestion;
                strengthSuggestions.appendChild(li);
            });
            strengthSuggestions.style.display = 'block';
        } else {
            strengthSuggestions.style.display = 'none';
        }
    }
});
</script>
{% endblock %}
