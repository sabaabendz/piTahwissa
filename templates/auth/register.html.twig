{% extends 'base_auth.html.twig' %}

{% block title %}Sign Up - Tahwissa{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/tahwissa-auth.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
{% endblock %}

{% block body %}
<div class="sky-bg">
    <div class="sun"></div>
    <div class="cloud cloud-1"></div>
    <div class="cloud cloud-2"></div>
    <div class="cloud cloud-3"></div>
    <div class="cloud cloud-4"></div>
    <div class="plane plane-1">✈️</div>
    <div class="plane plane-2">🛩️</div>
    <div class="particles" id="particles"></div>

    <div class="auth-page">
        <div class="auth-container" style="max-width: 640px;">
            <div class="auth-card">
                <div class="auth-header">
                    <div class="logo"><span>✈️ Tahwissa</span></div>
                    <h2>Créer un Compte 🚀</h2>
                    <p>Rejoignez la plateforme Tahwissa Manager</p>
                </div>

                <div id="oauthSignUpContainer" class="d-grid gap-2 mb-4">
                    <a href="{{ path('connect_google_start') }}" data-turbo="false" id="googleSignUpBtn" class="btn btn-outline" style="justify-content: center;">
                        <svg width="20" height="20" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z"/><path fill="#34A853" d="M9 18c2.43 0 4.467-.806 6.168-2.172l-2.908-2.258c-.806.54-1.837.86-3.26.86-2.51 0-4.656-1.696-5.424-4.07H.638v2.331C2.33 15.98 5.5 18 9 18z"/><path fill="#FBBC05" d="M3.576 10.711c-.18-.54-.282-1.117-.282-1.71 0-.593.102-1.17.282-1.71V4.96H.638C.232 6.46 0 7.988 0 9.5s.232 3.04.638 4.54l2.938-2.258 3.04 2.318z"/><path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0 5.5 0 2.33 2.02.638 4.96l2.938 2.258C4.344 5.276 6.49 3.58 9 3.58z"/></svg>
                        Continue with Google
                    </a>
                    <a href="{{ path('connect_github_start') }}" data-turbo="false" id="githubSignUpBtn" class="btn btn-outline" style="justify-content: center;">
                        <i class="fab fa-github"></i>
                        Continue with GitHub
                    </a>
                </div>

                <div class="auth-divider">ou s'inscrire avec email</div>

                <p class="text-center text-muted mb-0">Cette vue est conservée pour compatibilite des templates. Utilisez la page principale d'inscription si necessaire.</p>

                <div class="auth-footer">
                    Already have an account? <a href="{{ path('app_login') }}">Sign in here</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="{{ asset('js/tahwissa-auth.js') }}"></script>
{% endblock %}
