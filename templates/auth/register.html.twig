{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const roleManager = document.getElementById('roleManager');
    const roleCollaborator = document.getElementById('roleCollaborator');

    // Handle role selection functions
    function updateOAuthLinks(role) {
        const googleBtn = document.getElementById('googleSignUpBtn');
        const githubBtn = document.getElementById('githubSignUpBtn');
        const oauthContainer = document.getElementById('oauthSignUpContainer');
        
        if (oauthContainer) {
            if (googleBtn) {
                const googleBaseUrl = '{{ path('connect_google_start') }}';
                googleBtn.href = googleBaseUrl + '?role=' + role;
            }
            if (githubBtn) {
                const githubBaseUrl = '{{ path('connect_github_start') }}';
                githubBtn.href = githubBaseUrl + '?role=' + role;
            }
            oauthContainer.style.display = 'block';
        }
    }

    if (roleManager && roleCollaborator) {
        // Initial check
        if (roleManager.checked) updateOAuthLinks('manager');
        if (roleCollaborator.checked) updateOAuthLinks('collaborator');

        roleManager.addEventListener('change', function() {
            if (this.checked) {
                updateOAuthLinks('manager');
                submitForm('manager');
            }
        });

        roleCollaborator.addEventListener('change', function() {
            if (this.checked) {
                updateOAuthLinks('collaborator');
                submitForm('collaborator');
            }
        });

        function submitForm(role) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '{{ path('app_register') }}';
            const roleInput = document.createElement('input');
            roleInput.type = 'hidden';
            roleInput.name = 'role';
            roleInput.value = role;
            form.appendChild(roleInput);
            const csrfToken = document.querySelector('input[name*="_token"]');
            if (csrfToken) {
                const csrfInput = document.createElement('input');
                csrfInput.type = 'hidden';
                csrfInput.name = csrfToken.name;
                csrfInput.value = csrfToken.value;
                form.appendChild(csrfInput);
            }
            document.body.appendChild(form);
            form.submit();
        }
    }

    // ==========================================
    // PASSWORD STRENGTH LOGIC - UPDATED
    // ==========================================
    const passwordField = document.querySelector('.password-field');
    const strengthWrapper = document.querySelector('.password-strength-wrapper');
    const strengthBar = document.getElementById('strengthBar');
    const strengthLabel = document.getElementById('strengthLabel');
    const strengthSuggestions = document.getElementById('strengthSuggestions');

    let debounceTimer;

    if (passwordField) {
        passwordField.addEventListener('input', function() {
            const password = this.value;
            
            clearTimeout(debounceTimer);
            if (!password) {
                if (strengthWrapper) {
                    strengthWrapper.style.display = 'none';
                }
                return;
            }

            if (strengthWrapper) {
                strengthWrapper.style.display = 'block';
            }
            
            debounceTimer = setTimeout(() => {
                checkPasswordStrength(password);
            }, 300);
        });
    }

    async function checkPasswordStrength(password) {
        try {
            const response = await fetch('{{ path('api_password_strength') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ password: password })
            });

            if (response.ok) {
                const data = await response.json();
                updateStrengthUI(data);
            } else {
                // Handle error gracefully
                console.warn('Password strength check failed:', response.status);
                updateStrengthUI({
                    score: 50,
                    label: 'medium',
                    suggestions: ['Unable to check password strength']
                });
            }
        } catch (error) {
            console.error('Error checking password strength:', error);
            // Show fallback UI instead of breaking
            updateStrengthUI({
                score: 50,
                label: 'medium',
                suggestions: ['Password strength check unavailable']
            });
        }
    }

    function updateStrengthUI(data) {
        if (!strengthBar || !strengthLabel || !strengthSuggestions) {
            return;
        }

        // NEW: Handle both old and new API response formats
        const score = data.score || 0;
        const label = data.label || 'weak';
        const suggestions = data.suggestions || [];
        const confidence = data.confidence || 0;
        
        // Calculate progress bar width based on NEW 0-100 scale
        let width = '0%';
        let colorClass = 'bg-danger';
        let textColorClass = 'text-danger';
        let icon = '🔴';
        
        if (score < 40) {
            // Weak
            width = '33%';
            colorClass = 'bg-danger';
            textColorClass = 'text-danger';
            icon = '🔴';
        } else if (score < 70) {
            // Medium
            width = '66%';
            colorClass = 'bg-warning';
            textColorClass = 'text-warning';
            icon = '🟡';
        } else {
            // Strong
            width = '100%';
            colorClass = 'bg-success';
            textColorClass = 'text-success';
            icon = '🟢';
        }

        // Update progress bar
        strengthBar.style.width = width;
        strengthBar.className = 'progress-bar ' + colorClass;
        
        // Update label with icon and capitalized text
        const labelText = label.charAt(0).toUpperCase() + label.slice(1);
        strengthLabel.innerHTML = icon + ' ' + labelText;
        strengthLabel.className = 'fw-bold ' + textColorClass;

        // Update suggestions
        if (suggestions && suggestions.length > 0 && label !== 'strong') {
            strengthSuggestions.innerHTML = '';
            suggestions.forEach(suggestion => {
                const li = document.createElement('li');
                // NEW: Suggestions now include emojis, render as HTML
                li.innerHTML = suggestion;
                strengthSuggestions.appendChild(li);
            });
            strengthSuggestions.style.display = 'block';
            strengthSuggestions.className = 'small mt-2 mb-0 ps-3 ' + textColorClass;
        } else if (label === 'strong') {
            // Show success message for strong passwords
            strengthSuggestions.innerHTML = '<li>✅ Password meets all security requirements!</li>';
            strengthSuggestions.className = 'small text-success mt-2 mb-0 ps-3';
            strengthSuggestions.style.display = 'block';
        } else {
            strengthSuggestions.style.display = 'none';
        }
    }
});
</script>
{% endblock %}