{% extends 'base_auth.html.twig' %}

{% block title %}Login - SmartTask Manager{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/tahwissa-auth.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
{% endblock %}

{% block body %}
<div class="sky-bg">
    <div class="sun"></div>
    <div class="cloud cloud-1"></div>
    <div class="cloud cloud-2"></div>
    <div class="cloud cloud-3"></div>
    <div class="cloud cloud-4"></div>
    <div class="plane plane-1">✈️</div>
    <div class="plane plane-2">🛩️</div>
    <div class="particles" id="particles"></div>

    <div class="auth-page">
        <div class="auth-container" style="max-width: 560px;">
            <div class="auth-card">
                <div class="auth-header">
                    <div class="logo">
                        <span>✈️ SmartTask</span>
                    </div>
                    <h2>Bon Retour ! 👋</h2>
                    <p>Connectez-vous pour continuer votre session</p>
                </div>

                <div id="faceLoginMessage"></div>
                <input type="hidden" id="faceLoginCsrf" value="{{ csrf_token('face_login') }}">

                <form method="post" novalidate>
                    {% if error %}
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>{{ error.messageKey|trans(error.messageData, 'security') }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endif %}

                    <div class="form-group">
                        <label for="inputEmail">Email</label>
                        <div style="position: relative;">
                            <i class="fas fa-envelope form-icon" style="top: 50%; transform: translateY(-50%);"></i>
                            <input
                                type="text"
                                id="inputEmail"
                                name="_username"
                                class="form-input"
                                placeholder="votre@email.com"
                                value="{{ last_username }}"
                                autocomplete="email"
                                autofocus
                            >
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="inputPassword">Mot de passe</label>
                        <div style="position: relative;">
                            <i class="fas fa-lock form-icon" style="top: 50%; transform: translateY(-50%);"></i>
                            <input
                                type="password"
                                id="inputPassword"
                                name="_password"
                                class="form-input"
                                placeholder="••••••••"
                                autocomplete="current-password"
                            >
                            <button type="button" class="password-toggle" id="togglePasswordBtn" aria-label="Afficher le mot de passe">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4" style="margin-top: -8px;">
                        <div class="form-check m-0">
                            <input type="checkbox" class="form-check-input" id="remember_me" name="_remember_me" value="on">
                            <label class="form-check-label" for="remember_me">Remember me</label>
                        </div>
                        <a href="{{ path('app_forgot_password') }}" class="forgot-link" style="margin: 0;">Mot de passe oublié ?</a>
                    </div>

                    <div class="mb-3 d-flex justify-content-center">
                        <div class="g-recaptcha" data-sitekey="{{ recaptcha_site_key }}"></div>
                    </div>

                    <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 14px;">
                        <i class="fas fa-sign-in-alt"></i> Se Connecter
                    </button>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <input type="hidden" name="_target_path" value="{{ path('app_dashboard_index') }}">
                </form>

                <div class="auth-divider">ou continuer avec</div>

                <div class="d-grid gap-2">
                    <a href="{{ path('connect_google_start') }}" data-turbo="false" class="btn btn-outline" style="justify-content: center;">
                        <svg width="18" height="18" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z"/><path fill="#34A853" d="M9 18c2.43 0 4.467-.806 6.168-2.172l-2.908-2.258c-.806.54-1.837.86-3.26.86-2.51 0-4.656-1.696-5.424-4.07H.638v2.331C2.33 15.98 5.5 18 9 18z"/><path fill="#FBBC05" d="M3.576 10.711c-.18-.54-.282-1.117-.282-1.71 0-.593.102-1.17.282-1.71V4.96H.638C.232 6.46 0 7.988 0 9.5s.232 3.04.638 4.54l2.938-2.258 3.04 2.318z"/><path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0 5.5 0 2.33 2.02.638 4.96l2.938 2.258C4.344 5.276 6.49 3.58 9 3.58z"/></svg>
                        Continue with Google
                    </a>
                    <a href="{{ path('connect_github_start') }}" data-turbo="false" class="btn btn-outline" style="justify-content: center;">
                        <i class="fab fa-github"></i>
                        Continue with GitHub
                    </a>
                </div>

                <div class="auth-divider">ou utiliser Face ID</div>

                <div class="glass-card-solid p-3" style="border-radius: 14px;">
                    <h6 class="mb-3"><i class="bi bi-person-bounding-box me-2"></i>Face ID Login</h6>
                    <video id="faceLoginVideo" class="w-100 rounded border mb-2" autoplay playsinline style="max-height: 220px; object-fit: cover;"></video>
                    <canvas id="faceLoginCanvas" class="d-none"></canvas>
                    <div class="d-grid gap-2">
                        <button type="button" id="faceLoginStart" class="btn btn-outline">Start Camera</button>
                        <button type="button" id="faceLoginSubmit" class="btn btn-primary" disabled>Login with Face ID</button>
                    </div>
                    <div id="faceLoginStatus" class="small text-muted mt-2">Start camera to continue.</div>
                </div>

                <div class="auth-footer">
                    Don't have an account? <a href="{{ path('app_register') }}">Signup here</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="{{ asset('js/tahwissa-auth.js') }}"></script>
<script src="https://www.google.com/recaptcha/api.js" async defer></script>
<script>
    (() => {
        const video = document.getElementById('faceLoginVideo');
        const canvas = document.getElementById('faceLoginCanvas');
        const startButton = document.getElementById('faceLoginStart');
        const submitButton = document.getElementById('faceLoginSubmit');
        const status = document.getElementById('faceLoginStatus');
        const message = document.getElementById('faceLoginMessage');
        const emailInput = document.getElementById('inputEmail');
        const csrfInput = document.getElementById('faceLoginCsrf');
        const passwordInput = document.getElementById('inputPassword');
        const togglePasswordBtn = document.getElementById('togglePasswordBtn');

        if (togglePasswordBtn && passwordInput) {
            togglePasswordBtn.addEventListener('click', () => {
                const icon = togglePasswordBtn.querySelector('i');
                if (passwordInput.type === 'password') {
                    passwordInput.type = 'text';
                    if (icon) {
                        icon.classList.remove('fa-eye');
                        icon.classList.add('fa-eye-slash');
                    }
                } else {
                    passwordInput.type = 'password';
                    if (icon) {
                        icon.classList.remove('fa-eye-slash');
                        icon.classList.add('fa-eye');
                    }
                }
            });
        }

        if (!video || !canvas || !startButton || !submitButton || !status || !message || !emailInput || !csrfInput) {
            return;
        }

        let stream;

        const showMessage = (text, level = 'danger') => {
            message.innerHTML = `<div class="alert alert-${level} alert-dismissible fade show" role="alert">${text}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`;
        };

        startButton.addEventListener('click', async () => {
            try {
                stream = await navigator.mediaDevices.getUserMedia({ video: true });
                video.srcObject = stream;
                submitButton.disabled = false;
                status.textContent = 'Camera ready. Look at the camera and click login.';
                status.className = 'small text-success mt-2';
            } catch (error) {
                status.textContent = 'Unable to access camera.';
                status.className = 'small text-danger mt-2';
            }
        });

        submitButton.addEventListener('click', async () => {
            const email = emailInput.value.trim();
            if (!email) {
                showMessage('Please enter your email first.', 'warning');
                return;
            }

            if (!video.videoWidth || !video.videoHeight) {
                showMessage('Camera is not ready yet.', 'warning');
                return;
            }

            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            const ctx = canvas.getContext('2d');
            if (!ctx) {
                showMessage('Camera capture is unavailable in this browser.', 'danger');
                return;
            }
            ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
            const image = canvas.toDataURL('image/jpeg', 0.92);

            status.textContent = 'Verifying face...';
            status.className = 'small text-primary mt-2';

            try {
                const response = await fetch('{{ path('app_face_login') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        email,
                        image,
                        _csrf_token: csrfInput.value
                    })
                });

                const data = await response.json();

                if (!response.ok) {
                    showMessage(data.message || 'Face login failed.', 'danger');
                    status.textContent = 'Face login failed.';
                    status.className = 'small text-danger mt-2';
                    return;
                }

                showMessage('Face login successful. Redirecting...', 'success');
                status.textContent = 'Face detected and matched.';
                status.className = 'small text-success mt-2';
                window.location.href = data.redirect || '{{ path('app_dashboard_index') }}';
            } catch (error) {
                showMessage('Face ID service timeout/unavailable. Use password login.', 'warning');
                status.textContent = 'Service unavailable.';
                status.className = 'small text-warning mt-2';
            }
        });
    })();
</script>
{% endblock %}
