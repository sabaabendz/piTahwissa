{% extends 'base_auth.html.twig' %}

{% block title %}Sign Up - Tahwissa Manager{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/tahwissa-auth.css') }}">
{% endblock %}

{% block body %}
<div class="sky-bg">
    <div class="auth-page">
        <div class="auth-container" style="max-width: 560px;">
            <div class="auth-card">
                <div class="auth-header">
                    <div class="logo"><span>Tahwissa</span></div>
                    <h2>Create Account</h2>
                    <p>Register with your email to continue</p>
                </div>

                {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}
                    {{ form_errors(registrationForm) }}

                    <div class="form-group">
                        {{ form_label(registrationForm.email) }}
                        {{ form_widget(registrationForm.email, {'attr': {'class': 'form-input', 'placeholder': 'you@example.com'}}) }}
                        {{ form_errors(registrationForm.email) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(registrationForm.firstName) }}
                        {{ form_widget(registrationForm.firstName, {'attr': {'class': 'form-input', 'placeholder': 'First name'}}) }}
                        {{ form_errors(registrationForm.firstName) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(registrationForm.lastName) }}
                        {{ form_widget(registrationForm.lastName, {'attr': {'class': 'form-input', 'placeholder': 'Last name'}}) }}
                        {{ form_errors(registrationForm.lastName) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(registrationForm.phone) }}
                        {{ form_widget(registrationForm.phone, {'attr': {'class': 'form-input', 'placeholder': '+213 ...'}}) }}
                        {{ form_errors(registrationForm.phone) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(registrationForm.plainPassword.first) }}
                        {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-input', 'placeholder': 'Password'}}) }}
                        {{ form_errors(registrationForm.plainPassword.first) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(registrationForm.plainPassword.second) }}
                        {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-input', 'placeholder': 'Confirm password'}}) }}
                        {{ form_errors(registrationForm.plainPassword.second) }}
                    </div>

                    <div class="mb-3 d-flex align-items-start gap-2">
                        {{ form_widget(registrationForm.terms, {'attr': {'class': 'form-check-input mt-1'}}) }}
                        {{ form_label(registrationForm.terms, 'I agree to the terms of service', {'label_attr': {'class': 'form-check-label'}}) }}
                    </div>
                    {{ form_errors(registrationForm.terms) }}

                    <div class="mb-4 d-flex justify-content-center">
                        <div class="g-recaptcha" data-sitekey="{{ recaptcha_site_key }}"></div>
                    </div>
                    {{ form_widget(registrationForm.recaptcha) }}
                    {{ form_errors(registrationForm.recaptcha) }}

                    <button class="btn btn-primary" type="submit" style="width: 100%; justify-content: center; padding: 14px;">
                        Create account
                    </button>
                {{ form_end(registrationForm) }}

                <div class="auth-footer">
                    Already have an account? <a href="{{ path('app_login') }}">Sign in</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://www.google.com/recaptcha/api.js" async defer></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('form');
    const recaptchaInput = document.getElementById('registration_form_recaptcha');
    if (!form || !recaptchaInput) {
        return;
    }

    form.addEventListener('submit', function() {
        const recaptchaResponseInput = document.querySelector('textarea[name="g-recaptcha-response"]');
        recaptchaInput.value = recaptchaResponseInput ? recaptchaResponseInput.value : '';
    });
});
</script>
{% endblock %}
