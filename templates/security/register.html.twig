{% extends 'base_auth.html.twig' %}

{% block title %}Sign Up - SmartTask Manager{% endblock %}

{% block body %}
<section class="p-0 d-flex align-items-center position-relative overflow-hidden">
    <div class="container-fluid">
        <div class="row">
            <!-- left -->
            <div class="col-12 col-lg-6 d-md-flex align-items-center justify-content-center bg-primary bg-opacity-10 vh-lg-100">
                <div class="p-3 p-lg-5">
                    <div class="text-center">
                        <h2 class="fw-bold">Welcome to SmartTask Manager</h2>
                        <p class="mb-0 h6 fw-light">Intelligent Task & Meeting Management Platform</p>
                    </div>
                    <img src="{{ asset('assets/images/element/02.svg') }}" class="mt-5" alt="">
                    <div class="d-sm-flex mt-5 align-items-center justify-content-center">
                        <ul class="avatar-group mb-2 mb-sm-0">
                            <li class="avatar avatar-sm"><img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="avatar"></li>
                            <li class="avatar avatar-sm"><img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/02.jpg') }}" alt="avatar"></li>
                            <li class="avatar avatar-sm"><img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/03.jpg') }}" alt="avatar"></li>
                            <li class="avatar avatar-sm"><img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/04.jpg') }}" alt="avatar"></li>
                        </ul>
                        <p class="mb-0 h6 fw-light ms-0 ms-sm-3">Join our team of managers and collaborators!</p>
                    </div>
                </div>
            </div>

            <!-- Right -->
            <div class="col-12 col-lg-6 m-auto">
                <div class="row my-5">
                    <div class="col-sm-10 col-xl-8 m-auto">
                        <img src="{{ asset('assets/images/element/03.svg') }}" class="h-40px mb-2" alt="">
                        <h2>Sign up for your account!</h2>
                        <p class="lead mb-4">Nice to see you! Please fill in the form below.</p>

                        <!-- OAuth Sign Up -->
                        <div class="mb-4" id="oauthSignUpContainer">
                            <a href="{{ path('connect_google_start') }}" id="googleSignUpBtn" class="btn btn-outline-secondary btn-lg w-100 mb-2" type="button">
                                <svg width="20" height="20" xmlns="http://www.w3.org/2000/svg" class="me-2"><path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z"/><path fill="#34A853" d="M9 18c2.43 0 4.467-.806 6.168-2.172l-2.908-2.258c-.806.54-1.837.86-3.26.86-2.51 0-4.656-1.696-5.424-4.07H.638v2.331C2.33 15.98 5.5 18 9 18z"/><path fill="#FBBC05" d="M3.576 10.711c-.18-.54-.282-1.117-.282-1.71 0-.593.102-1.17.282-1.71V4.96H.638C.232 6.46 0 7.988 0 9.5s.232 3.04.638 4.54l2.938-2.258 3.04 2.318z"/><path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0 5.5 0 2.33 2.02.638 4.96l2.938 2.258C4.344 5.276 6.49 3.58 9 3.58z"/></svg>
                                Continue with Google
                            </a>
                            <a href="{{ path('connect_linkedin_start') }}" id="linkedinSignUpBtn" class="btn btn-outline-secondary btn-lg w-100" type="button">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="#0077b5" xmlns="http://www.w3.org/2000/svg" class="me-2"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                                Continue with LinkedIn
                            </a>
                            <div class="text-center my-3"><span class="text-muted">— or —</span></div>
                        </div>

                        <!-- Flash Messages -->
                        {% for message in app.flashes('success') %}
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <i class="bi bi-check-circle me-2"></i>{{ message }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endfor %}

                        {{ form_start(registrationForm, {'attr': {'id': 'registrationForm', 'novalidate': 'novalidate'}}) }}
                            
                            <!-- Role Selection -->
                            <div class="mb-4">
                                <label class="form-label">I am a: *</label>
                                <div class="d-flex gap-3">
                                    {% for child in registrationForm.role %}
                                        <div class="form-check form-check-inline">
                                            {{ form_widget(child, {'attr': {'class': 'form-check-input role-toggle'}}) }}
                                            {{ form_label(child, null, {'label_attr': {'class': 'form-check-label'}}) }}
                                        </div>
                                    {% endfor %}
                                </div>
                                {{ form_errors(registrationForm.role) }}
                            </div>

                            <!-- Name -->
                            <div class="mb-4">
                                {{ form_label(registrationForm.name, null, {'label_attr': {'class': 'form-label'}}) }}
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light rounded-start border-0 text-secondary px-3"><i class="bi bi-person-fill"></i></span>
                                    {{ form_widget(registrationForm.name, {'attr': {'class': 'form-control border-0 bg-light rounded-end ps-1', 'placeholder': 'Full Name'}}) }}
                                </div>
                                {{ form_errors(registrationForm.name) }}
                            </div>

                            <!-- Email -->
                            <div class="mb-4">
                                {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'form-label'}}) }}
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light rounded-start border-0 text-secondary px-3"><i class="bi bi-envelope-fill"></i></span>
                                    {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control border-0 bg-light rounded-end ps-1', 'placeholder': 'E-mail'}}) }}
                                </div>
                                {{ form_errors(registrationForm.email) }}
                            </div>

                            <!-- Password -->
                            <div class="mb-4">
                                {{ form_label(registrationForm.password, null, {'label_attr': {'class': 'form-label'}}) }}
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light rounded-start border-0 text-secondary px-3"><i class="fas fa-lock"></i></span>
                                    {{ form_widget(registrationForm.password, {'attr': {'class': 'form-control border-0 bg-light rounded-end ps-1 password-field', 'placeholder': 'Password'}}) }}
                                </div>
                                
                                <!-- Password Strength Indicator -->
                                <div class="password-strength-wrapper mt-2" style="display: none;">
                                    <div class="progress" style="height: 6px;">
                                        <div id="strengthBar" class="progress-bar" role="progressbar" style="width: 0%"></div>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mt-1">
                                        <small class="text-muted">Strength: <span id="strengthLabel" class="fw-bold">-</span></small>
                                    </div>
                                    <ul id="strengthSuggestions" class="small text-danger mt-1 mb-0 ps-3" style="display: none;"></ul>
                                </div>

                                {{ form_errors(registrationForm.password) }}
                            </div>

                            <!-- Manager Fields -->
                            <div id="manager-fields">
                                <div class="mb-4">
                                    {{ form_label(registrationForm.level, null, {'label_attr': {'class': 'form-label'}}) }}
                                    <div class="input-group input-group-lg">
                                        <span class="input-group-text bg-light rounded-start border-0 text-secondary px-3"><i class="bi bi-award-fill"></i></span>
                                        {{ form_widget(registrationForm.level, {'attr': {'class': 'form-control border-0 bg-light rounded-end ps-1', 'placeholder': 'e.g., Senior, Junior'}}) }}
                                    </div>
                                    {{ form_errors(registrationForm.level) }}
                                </div>
                                <div class="mb-4">
                                    {{ form_label(registrationForm.department, null, {'label_attr': {'class': 'form-label'}}) }}
                                    <div class="input-group input-group-lg">
                                        <span class="input-group-text bg-light rounded-start border-0 text-secondary px-3"><i class="bi bi-building"></i></span>
                                        {{ form_widget(registrationForm.department, {'attr': {'class': 'form-control border-0 bg-light rounded-end ps-1', 'placeholder': 'e.g., IT, HR, Sales'}}) }}
                                    </div>
                                    {{ form_errors(registrationForm.department) }}
                                </div>
                            </div>

                            <!-- Collaborator Fields -->
                            <div id="collaborator-fields" style="display: none;">
                                <div class="mb-4">
                                    {{ form_label(registrationForm.enterpriseCode, 'Enterprise Code', {'label_attr': {'class': 'form-label'}}) }}
                                    <div class="input-group input-group-lg">
                                        <span class="input-group-text bg-light rounded-start border-0 text-secondary px-3"><i class="bi bi-key-fill"></i></span>
                                        {{ form_widget(registrationForm.enterpriseCode, {'attr': {'class': 'form-control border-0 bg-light rounded-end ps-1', 'placeholder': 'Enter enterprise code'}}) }}
                                    </div>
                                    {{ form_errors(registrationForm.enterpriseCode) }}
                                    <div class="form-text">Enter the enterprise code provided by your manager.</div>
                                </div>
                                <div class="mb-4">
                                    {{ form_label(registrationForm.post, null, {'label_attr': {'class': 'form-label'}}) }}
                                    <div class="input-group input-group-lg">
                                        <span class="input-group-text bg-light rounded-start border-0 text-secondary px-3"><i class="bi bi-briefcase-fill"></i></span>
                                        {{ form_widget(registrationForm.post, {'attr': {'class': 'form-control border-0 bg-light rounded-end ps-1', 'placeholder': 'e.g., Developer, Designer'}}) }}
                                    </div>
                                    {{ form_errors(registrationForm.post) }}
                                </div>
                                <div class="mb-4">
                                    {{ form_label(registrationForm.team, null, {'label_attr': {'class': 'form-label'}}) }}
                                    <div class="input-group input-group-lg">
                                        <span class="input-group-text bg-light rounded-start border-0 text-secondary px-3"><i class="bi bi-people-fill"></i></span>
                                        {{ form_widget(registrationForm.team, {'attr': {'class': 'form-control border-0 bg-light rounded-end ps-1', 'placeholder': 'e.g., Backend, Frontend'}}) }}
                                    </div>
                                    {{ form_errors(registrationForm.team) }}
                                </div>
                            </div>

                            <!-- Terms -->
                            <div class="mb-4">
                                {{ form_widget(registrationForm.terms, {'attr': {'class': 'form-check-input'}}) }}
                                {{ form_label(registrationForm.terms, 'I agree to the terms of service', {'label_attr': {'class': 'form-check-label'}}) }}
                                {{ form_errors(registrationForm.terms) }}
                            </div>

                            <!-- Submit -->
                            <div class="d-grid mt-4">
                                <button class="btn btn-primary btn-lg mb-0" type="submit">Sign Up</button>
                            </div>

                        {{ form_end(registrationForm) }}

                        <div class="mt-4 text-center">
                            <span>Already have an account? <a href="{{ path('app_login') }}">Sign in here</a></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // --- Role Toggling Logic ---
    const roleToggles = document.querySelectorAll('.role-toggle');
    const managerFields = document.getElementById('manager-fields');
    const collaboratorFields = document.getElementById('collaborator-fields');

    const googleSignUpBtn = document.getElementById('googleSignUpBtn');
    const linkedinSignUpBtn = document.getElementById('linkedinSignUpBtn');

    function toggleFields() {
        const checkedToggle = document.querySelector('.role-toggle:checked');
        if (!checkedToggle) {
            console.warn('No role toggle checked');
            return;
        }

        const selectedRole = checkedToggle.value;
        if (selectedRole === 'manager') {
            managerFields.style.display = 'block';
            collaboratorFields.style.display = 'none';
        } else {
            managerFields.style.display = 'none';
            collaboratorFields.style.display = 'block';
        }

        // Update OAuth links
        if (googleSignUpBtn) {
            googleSignUpBtn.href = '{{ path('connect_google_start') }}?role=' + selectedRole;
        }
        if (linkedinSignUpBtn) {
            linkedinSignUpBtn.href = '{{ path('connect_linkedin_start') }}?role=' + selectedRole;
        }
    }

    roleToggles.forEach(toggle => {
        toggle.addEventListener('change', toggleFields);
    });

    // Initial toggle state - wait a bit to ensure Symfony form components are ready
    setTimeout(toggleFields, 50);

    // --- Password Strength Logic ---
    const passwordField = document.querySelector('.password-field');
    const strengthWrapper = document.querySelector('.password-strength-wrapper');
    const strengthBar = document.getElementById('strengthBar');
    const strengthLabel = document.getElementById('strengthLabel');
    const strengthSuggestions = document.getElementById('strengthSuggestions');

    let debounceTimer;

    if (passwordField) {
        passwordField.addEventListener('input', function() {
            const password = this.value;
            
            clearTimeout(debounceTimer);
            if (!password) {
                strengthWrapper.style.display = 'none';
                return;
            }

            strengthWrapper.style.display = 'block';
            
            debounceTimer = setTimeout(() => {
                checkPasswordStrength(password);
            }, 300);
        });
    }

    async function checkPasswordStrength(password) {
        try {
            const response = await fetch('{{ path('api_password_strength') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ password: password })
            });

            if (response.ok) {
                const data = await response.json();
                updateStrengthUI(data);
            }
        } catch (error) {
            console.error('Error checking password strength:', error);
        }
    }

    function updateStrengthUI(data) {
        const { score, label, suggestions } = data;
        
        let width = '0%';
        let colorClass = 'bg-danger';
        
        if (label === 'weak') {
            width = '33%';
            colorClass = 'bg-danger';
        } else if (label === 'medium') {
            width = '66%';
            colorClass = 'bg-warning';
        } else if (label === 'strong') {
            width = '100%';
            colorClass = 'bg-success';
        }

        strengthBar.style.width = width;
        strengthBar.className = 'progress-bar ' + colorClass;
        strengthLabel.textContent = label.charAt(0).toUpperCase() + label.slice(1);
        strengthLabel.className = 'fw-bold ' + colorClass.replace('bg-', 'text-');

        if (suggestions && suggestions.length > 0 && label !== 'strong') {
            strengthSuggestions.innerHTML = '';
            suggestions.forEach(suggestion => {
                const li = document.createElement('li');
                li.textContent = suggestion;
                strengthSuggestions.appendChild(li);
            });
            strengthSuggestions.style.display = 'block';
        } else {
            strengthSuggestions.style.display = 'none';
        }
    }
});
</script>
{% endblock %}
