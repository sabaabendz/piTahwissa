{% extends 'frontoffice/base.html.twig' %}

{% block title %}Nos Collaborateurs - SmartTask Manager{% endblock %}

{% block body %}
<div class="mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_front_users') }}">Équipe</a></li>
            <li class="breadcrumb-item active" aria-current="page">Collaborateurs</li>
        </ol>
    </nav>
    <h1 class="display-5 fw-bold">Nos Collaborateurs</h1>
    <p class="lead text-muted">Découvrez les experts qui font vivre nos projets au quotidien.</p>

    <div class="row mt-4">
        <div class="col-md-6 col-lg-4">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white border-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="collaboratorQuery" class="form-control border-0" placeholder="Rechercher un collaborateur..." aria-label="Search">
                <div class="position-absolute end-0 top-50 translate-middle-y me-3" id="searchSpinner" style="display: none; z-index: 10;">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4" id="collaboratorList">
    {% include 'frontoffice/users/_list.html.twig' with {'collaborators': collaborators} %}
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const queryInput = document.getElementById('collaboratorQuery');
        const collaboratorList = document.getElementById('collaboratorList');
        const spinner = document.getElementById('searchSpinner');
        let debounceTimer;

        queryInput.addEventListener('input', function() {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => {
                const query = this.value;
                spinner.style.display = 'block';
                
                fetch(`{{ path('app_front_users_search') }}?q=${query}&type=collaborator`)
                    .then(response => response.text())
                    .then(html => {
                        collaboratorList.innerHTML = html;
                        spinner.style.display = 'none';
                    });
            }, 300);
        });
    });
</script>
{% endblock %}
