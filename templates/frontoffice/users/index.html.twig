{% extends 'frontoffice/base.html.twig' %}

{% block title %}Nos Utilisateurs - SmartTask Manager{% endblock %}

{% block body %}
<div class="row align-items-center mb-5">
    <div class="col-lg-6">
        <h1 class="display-4 fw-bold">Notre Équipe</h1>
        <p class="lead text-muted">Découvrez les talents qui propulsent SmartTask Manager. De nos managers visionnaires à nos collaborateurs passionnés.</p>
        
        <div class="mt-4">
            <div class="input-group input-group-lg shadow-sm">
                <span class="input-group-text bg-white border-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="userQuery" class="form-control border-0" placeholder="Rechercher par nom, email..." aria-label="Search">
                <div class="position-absolute end-0 top-50 translate-middle-y me-3" id="searchSpinner" style="display: none;">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6 text-end d-none d-lg-block">
        <img src="https://illustrations.popsy.co/amber/team-work.svg" alt="Teamwork" class="img-fluid" style="max-height: 300px;">
    </div>
</div>

<div class="row g-4" id="userList">
    {% include 'frontoffice/users/_list.html.twig' with {'users': users} %}
</div>

<style>
    .hover-translate-y {
        transition: transform 0.3s ease-in-out, box-shadow 0.3s ease-in-out;
    }
    .hover-translate-y:hover {
        transform: translateY(-10px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important;
    }
    .transition {
        transition: all 0.3s ease;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const queryInput = document.getElementById('userQuery');
        const userList = document.getElementById('userList');
        const spinner = document.getElementById('searchSpinner');
        let debounceTimer;

        queryInput.addEventListener('input', function() {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => {
                const query = this.value;
                spinner.style.display = 'block';
                
                fetch(`{{ path('app_front_users_search') }}?q=${query}&type=all`)
                    .then(response => response.text())
                    .then(html => {
                        userList.innerHTML = html;
                        spinner.style.display = 'none';
                    });
            }, 300);
        });
    });
</script>
{% endblock %}
