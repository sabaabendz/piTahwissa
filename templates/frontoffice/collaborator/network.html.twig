{% extends 'frontoffice/base.html.twig' %}

{% block title %}My Team - SmartTask Manager{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5 fw-bold">My Team</h1>
            <p class="text-muted">Enterprise Code: <span class="badge bg-primary">{{ enterpriseCode }}</span></p>
        </div>
    </div>

    {% if manager %}
        <!-- Manager Card (Highlighted) -->
        <div class="row mb-5">
            <div class="col-12">
                <h2 class="h4 mb-3"><i class="bi bi-person-badge me-2"></i>Manager</h2>
                <div class="card border-primary shadow-sm">
                    <div class="card-body p-4">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <div class="avatar avatar-lg bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; font-size: 2rem;">
                                    {{ manager.name|first|upper }}
                                </div>
                            </div>
                            <div class="col">
                                <h3 class="h5 mb-1">{{ manager.name }}</h3>
                                <p class="text-muted mb-2">
                                    <i class="bi bi-envelope me-1"></i>{{ manager.email }}
                                </p>
                                <div class="d-flex gap-2">
                                    <span class="badge bg-primary">Manager</span>
                                    <span class="badge bg-info">{{ manager.department }}</span>
                                    <span class="badge bg-secondary">{{ manager.level }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>No manager found for your enterprise code.
        </div>
    {% endif %}

    <!-- Collaborators Grid -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="h4 mb-3"><i class="bi bi-people me-2"></i>Team Members</h2>
        </div>
    </div>

    {% if collaborators|length > 0 %}
        <div class="row g-4">
            {% for collaborator in collaborators %}
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm hover-shadow">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <div class="avatar avatar-md bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px; font-size: 1.25rem;">
                                    {{ collaborator.name|first|upper }}
                                </div>
                                <div>
                                    <h5 class="card-title mb-0">{{ collaborator.name }}</h5>
                                    <span class="badge bg-success-soft text-success">Collaborator</span>
                                </div>
                            </div>
                            <div class="mb-2">
                                <small class="text-muted"><i class="bi bi-envelope me-1"></i></small>
                                <small>{{ collaborator.email }}</small>
                            </div>
                            <div class="mb-2">
                                <small class="text-muted"><i class="bi bi-briefcase me-1"></i></small>
                                <small>{{ collaborator.post }}</small>
                            </div>
                            <div>
                                <small class="text-muted"><i class="bi bi-people me-1"></i></small>
                                <small>{{ collaborator.team }}</small>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>No other team members found.
        </div>
    {% endif %}
</div>

<style>
    .hover-shadow {
        transition: box-shadow 0.3s ease;
    }
    .hover-shadow:hover {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
    .bg-success-soft {
        background-color: rgba(25, 135, 84, 0.1);
    }
</style>
{% endblock %}
