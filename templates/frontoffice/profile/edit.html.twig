{% extends 'base_admin.html.twig' %}

{% block title %}Modifier mon Profil - SmartTask Manager{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-6">
        <div class="mb-4">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Mon Profil</li>
                </ol>
            </nav>
            <h1 class="display-6 fw-bold">Modifier mon Profil</h1>
            <p class="text-muted">Gérez vos informations personnelles et votre sécurité.</p>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 p-md-5">
                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                    <div class="mb-4 text-center">
                        {% set avatarPath = app.user and app.user.avatarName ? vich_uploader_asset(app.user, 'avatarFile') : asset('assets/images/avatar/01.jpg') %}
                        <img src="{{ avatarPath }}" alt="avatar" class="rounded-circle shadow avatar-hover" width="110" height="110">
                        <div class="small text-muted mt-2">Votre photo actuelle</div>
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.name) }}
                        {{ form_widget(form.name) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.email) }}
                        {{ form_widget(form.email) }}
                        {{ form_errors(form.email) }}
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.avatarFile) }}
                        {{ form_widget(form.avatarFile) }}
                        {{ form_errors(form.avatarFile) }}
                        <div class="form-text mt-2">Formats accepts: JPG or PNG. Max 2MB.</div>
                    </div>

                    <hr class="my-4 text-muted opacity-25">

                    <h5 class="mb-3 fw-bold"><i class="bi bi-person-bounding-box me-2"></i>Face ID</h5>
                    <p class="text-muted">Capture your face here. Only the embedding is stored, never the raw image.</p>

                    {% set faceConfigured = app.user and app.user.faceEmbedding is not empty %}
                    <div class="mb-3">
                        {% if faceConfigured %}
                            <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle">
                                <i class="bi bi-check-circle me-1"></i>Face ID already configured
                            </span>
                        {% else %}
                            <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle">
                                <i class="bi bi-exclamation-circle me-1"></i>Face ID not configured yet
                            </span>
                        {% endif %}
                    </div>

                    <div class="mb-3">
                        <video id="faceEnrollVideo" class="w-100 rounded border" autoplay playsinline style="max-height: 260px; object-fit: cover;"></video>
                        <canvas id="faceEnrollCanvas" class="d-none"></canvas>
                        <input type="hidden" id="faceImageBase64" name="face_image_base64" data-face-configured="{{ faceConfigured ? '1' : '0' }}">
                    </div>

                    <div class="d-flex gap-2 mb-2">
                        <button type="button" id="faceEnrollStart" class="btn btn-outline-primary btn-sm">Start Camera</button>
                        <button type="button" id="faceEnrollCapture" class="btn btn-outline-success btn-sm" disabled>Capture Face</button>
                    </div>
                    <div id="faceEnrollStatus" class="small text-muted mb-3">Face ID not captured yet.</div>

                    <hr class="my-4 text-muted opacity-25">

                    <h5 class="mb-4 fw-bold"><i class="bi bi-shield-lock me-2"></i>Changer le mot de passe</h5>

                    <div class="mb-4">
                        {{ form_label(form.plainPassword.first) }}
                        {{ form_widget(form.plainPassword.first) }}
                        {{ form_errors(form.plainPassword.first) }}
                        <div class="form-text mt-2">
                            Laissez vide si vous ne souhaitez pas modifier votre mot de passe actuel.
                        </div>
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.plainPassword.second) }}
                        {{ form_widget(form.plainPassword.second) }}
                        {{ form_errors(form.plainPassword.second) }}
                    </div>

                    <div class="d-grid gap-2 mt-5">
                        <button type="submit" class="btn btn-primary btn-lg px-5">
                            <i class="bi bi-check2-circle me-2"></i>Enregistrer les modifications
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="mt-4 text-center">
            <a href="{{ path('app_dashboard_index') }}" class="text-muted text-decoration-none small">
                <i class="bi bi-arrow-left me-1"></i> Retour au tableau de bord
            </a>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (() => {
            const video = document.getElementById('faceEnrollVideo');
            const canvas = document.getElementById('faceEnrollCanvas');
            const input = document.getElementById('faceImageBase64');
            const startButton = document.getElementById('faceEnrollStart');
            const captureButton = document.getElementById('faceEnrollCapture');
            const status = document.getElementById('faceEnrollStatus');

            if (!video || !canvas || !input || !startButton || !captureButton || !status) {
                return;
            }

            let stream;
            const alreadyConfigured = input.dataset.faceConfigured === '1';
            if (alreadyConfigured) {
                status.textContent = 'Face ID already configured. Capture again to update it.';
                status.className = 'small text-success mb-3';
            }

            startButton.addEventListener('click', async () => {
                try {
                    stream = await navigator.mediaDevices.getUserMedia({ video: true });
                    video.srcObject = stream;
                    captureButton.disabled = false;
                    status.textContent = 'Camera ready. Capture your face.';
                    status.className = 'small text-success mb-3';
                } catch (error) {
                    status.textContent = 'Unable to access camera.';
                    status.className = 'small text-danger mb-3';
                }
            });

            captureButton.addEventListener('click', () => {
                if (!video.videoWidth || !video.videoHeight) {
                    status.textContent = 'Camera is not ready yet.';
                    status.className = 'small text-danger mb-3';
                    return;
                }

                canvas.width = video.videoWidth;
                canvas.height = video.videoHeight;
                const ctx = canvas.getContext('2d');
                ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

                input.value = canvas.toDataURL('image/jpeg', 0.92);
                status.textContent = 'Face captured. Save profile to enroll Face ID.';
                status.className = 'small text-success mb-3';
            });
        })();
    </script>
{% endblock %}
