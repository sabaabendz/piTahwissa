<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}SmartTask Manager{% endblock %}</title>
        <link rel="icon" href="{{ asset('assets/images/favicon.ico') }}">

        {% block stylesheets %}
            <link rel="preconnect" href="https://fonts.googleapis.com/">
            <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
            <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap">

            <link rel="stylesheet" href="{{ asset('assets/vendor/font-awesome/css/all.min.css') }}">
            <link rel="stylesheet" href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}">
            <link rel="stylesheet" href="{{ asset('assets/vendor/overlay-scrollbar/css/overlayscrollbars.min.css') }}">
            <link rel="stylesheet" href="{{ asset('assets/css/style.css') }}">
            <link rel="stylesheet" href="{{ asset('assets/css/branding.css') }}">
            <link rel="stylesheet" href="{{ asset('css/tahwissa-auth.css') }}">

            <style>
                :root {
                    --sidebar-width: 260px;
                }
                body {
                    background-color: #f6f7fb;
                    font-family: 'Heebo', 'Roboto', sans-serif;
                }
                .app-shell {
                    padding-top: 72px;
                    min-height: 100vh;
                }
                .app-content {
                    padding: 24px;
                }
                .app-sidebar {
                    width: var(--sidebar-width);
                }
                @media (min-width: 992px) {
                    .app-shell {
                        padding-left: var(--sidebar-width);
                    }
                    .offcanvas-lg {
                        position: fixed;
                        top: 72px;
                        bottom: 0;
                        border-right: 1px solid #edf0f7;
                        transform: none;
                        visibility: visible !important;
                    }
                }
            </style>
        {% endblock %}
    </head>
    <body>
        {% block topnav %}
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom fixed-top shadow-sm">
                <div class="container-fluid">
                    <button class="btn btn-outline-secondary d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#backofficeSidebar" aria-controls="backofficeSidebar">
                        <i class="bi bi-list"></i>
                    </button>
                    <a class="navbar-brand fw-bold ms-2" href="{{ path('app_dashboard_index') }}">SmartTask</a>

                    <div class="ms-auto d-flex align-items-center gap-3">
                        <button class="btn btn-light btn-icon rounded-circle" type="button">
                            <i class="bi bi-bell"></i>
                        </button>

                        <div class="dropdown">
                            {% set avatarPath = app.user and app.user.avatarUrl ? app.user.avatarUrl : asset('assets/images/avatar/01.jpg') %}
                            <a class="d-flex align-items-center text-decoration-none" href="#" role="button" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <img src="{{ avatarPath }}" alt="avatar" class="rounded-circle avatar-hover" width="40" height="40">
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="profileDropdown">
                                <li><a class="dropdown-item" href="{{ path('app_front_profile_edit') }}">Edit Profile</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_front_profile_edit') }}">Settings</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}">Sign Out</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>
        {% endblock %}

        {% block sidebar %}
            <div class="offcanvas offcanvas-start offcanvas-lg bg-white app-sidebar" tabindex="-1" id="backofficeSidebar" aria-labelledby="backofficeSidebarLabel">
                <div class="offcanvas-header border-bottom">
                    <h5 class="offcanvas-title" id="backofficeSidebarLabel">Navigation</h5>
                    <button type="button" class="btn-close text-reset d-lg-none" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                </div>
                <div class="offcanvas-body px-0">
                    <nav class="navbar-nav">
                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_AGENT') %}
                            <div class="px-3 text-uppercase text-muted small fw-semibold mt-2">Core</div>
                            <a class="nav-link px-3 py-2 {{ app.request.pathInfo starts with '/dashboard' ? 'active' : '' }}" href="{{ path('app_dashboard_index') }}">
                                <i class="bi bi-speedometer2 me-2"></i>Dashboard
                            </a>

                            <div class="px-3 text-uppercase text-muted small fw-semibold mt-4">User Management</div>
                            <a class="nav-link px-3 py-2 {{ app.request.pathInfo starts with '/admin/users' ? 'active' : '' }}" href="{{ path('app_admin_users_index') }}">
                                <i class="bi bi-people me-2"></i>Users
                            </a>

                            <div class="px-3 text-uppercase text-muted small fw-semibold mt-4">Insights</div>
                            <a class="nav-link px-3 py-2 {{ app.request.pathInfo starts with '/dashboard' ? 'active' : '' }}" href="{{ path('app_dashboard_index') }}">
                                <i class="bi bi-bar-chart me-2"></i>Reports & Statistics
                            </a>
                            <a class="nav-link px-3 py-2 {{ app.request.pathInfo starts with '/profile' ? 'active' : '' }}" href="{{ path('app_front_profile_edit') }}">
                                <i class="bi bi-gear me-2"></i>Settings
                            </a>
                        {% else %}
                            <div class="px-3 text-uppercase text-muted small fw-semibold mt-2">Reports</div>
                            <a class="nav-link px-3 py-2 {{ app.request.pathInfo starts with '/dashboard' ? 'active' : '' }}" href="{{ path('app_dashboard_index') }}">
                                <i class="bi bi-bar-chart me-2"></i>Reports & Statistics
                            </a>
                            <a class="nav-link px-3 py-2 {{ app.request.pathInfo starts with '/profile' ? 'active' : '' }}" href="{{ path('app_front_profile_edit') }}">
                                <i class="bi bi-gear me-2"></i>Settings
                            </a>
                        {% endif %}
                    </nav>
                </div>
            </div>
        {% endblock %}

        <div class="app-shell">
            <main class="app-content">
                {% block content %}{% endblock %}
            </main>
        </div>

        {% block javascripts %}
            <script src="{{ asset('assets/vendor/bootstrap/dist/js/bootstrap.bundle.min.js') }}"></script>
            <script src="{{ asset('assets/vendor/overlay-scrollbar/js/overlayscrollbars.min.js') }}"></script>
            <script src="{{ asset('assets/js/functions.js') }}"></script>
            <script src="{{ asset('js/tahwissa-auth.js') }}"></script>
        {% endblock %}
    </body>
</html>