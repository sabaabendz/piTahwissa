<div class="top-bar">
    <div>
        <h1>{{ title|default('Tableau de bord') }}</h1>
        {% if subtitle is defined and subtitle is not empty %}
            <p style="color:var(--text-muted);font-size:0.9rem;">{{ subtitle }}</p>
        {% endif %}
    </div>
    <div class="top-bar-right">
        <div class="search-box">
            <i class="fas fa-search" style="color:var(--text-muted);"></i>
            <input type="text" placeholder="Rechercher..." id="globalSearchInput">
        </div>
        {% if actions is defined and actions is not empty %}
            {{ actions|raw }}
        {% endif %}
        <a class="btn btn-outline btn-sm" href="{{ path('app_front_profile_edit') }}">
            <i class="fas fa-user"></i> Profil
        </a>
    </div>
</div>
