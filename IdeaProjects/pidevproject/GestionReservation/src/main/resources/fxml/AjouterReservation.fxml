<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<DialogPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.tahwissa.controllers.AjouterReservationController"
            prefWidth="500" prefHeight="300">
    <headerText>
        <Label text="Créer une nouvelle réservation" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
    </headerText>
    <content>
        <GridPane hgap="10" vgap="10">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Label text="Client ID :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="clientIdField" promptText="Saisir l'ID du client" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Voyage :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <ComboBox fx:id="voyageCombo" promptText="Choisir un voyage" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Nombre de personnes :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <Spinner fx:id="personnesSpinner" editable="true" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Prix unitaire :" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <Label fx:id="prixUnitaireLabel" text="-" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="Montant total :" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <Label fx:id="totalLabel" text="-" style="-fx-font-weight: bold; -fx-text-fill: #0f766e;" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
        </GridPane>
    </content>
    <ButtonType text="OK" buttonData="OK_DONE" />
    <ButtonType text="Annuler" buttonData="CANCEL_CLOSE" />
</DialogPane>
