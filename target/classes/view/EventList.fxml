<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.tahwissa.controller.EventListController"
      spacing="20" stylesheets="@../css/styles.css"
      style="-fx-padding: 24px;">

    <!-- Header Section -->
    <VBox spacing="16">
        <Label text="Gestion des Événements" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: -fx-text-primary;"/>
        
        <!-- Action Bar -->
        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-wrap-text: true;">
            <Button fx:id="btnCreate" text="+ Nouvel Événement" styleClass="btn, btn-primary" onAction="#handleCreate"
                   style="-fx-min-width: 160px;"/>
            <Button fx:id="btnEdit" text="✏️ Modifier" styleClass="btn, btn-tertiary" onAction="#handleEdit" 
                   disable="true" style="-fx-min-width: 110px;"/>
            <Button fx:id="btnDelete" text="🗑️ Supprimer" styleClass="btn, btn-danger" onAction="#handleDelete" 
                   disable="true" style="-fx-min-width: 110px;"/>
            
            <Region HBox.hgrow="ALWAYS"/>
            
            <HBox spacing="8" alignment="CENTER_RIGHT">
                <TextField fx:id="txtSearch" promptText="🔍 Rechercher des événements..." 
                          styleClass="form-field" style="-fx-min-width: 250px;"/>
                <Button text="Rechercher" styleClass="btn, btn-secondary" onAction="#handleSearch"
                       style="-fx-min-width: 120px;"/>
                <Button fx:id="btnRefresh" text="🔄 Actualiser" styleClass="btn, btn-outline" onAction="#handleRefresh"
                       style="-fx-min-width: 110px;"/>
            </HBox>
        </HBox>
    </VBox>

    <!-- Table Container -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS" style="-fx-padding: 0;">
        <TableView fx:id="tableEvenements" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60" sortable="true"/>
                <TableColumn fx:id="colTitre" text="Titre" prefWidth="180" sortable="true"/>
                <TableColumn fx:id="colLieu" text="Lieu" prefWidth="140" sortable="true"/>
                <TableColumn fx:id="colDate" text="Date" prefWidth="110" sortable="true"/>
                <TableColumn fx:id="colHeure" text="Heure" prefWidth="90" sortable="false"/>
                <TableColumn fx:id="colPrix" text="Prix (DT)" prefWidth="90" sortable="true"/>
                <TableColumn fx:id="colPlaces" text="Places" prefWidth="80" sortable="false"/>
                <TableColumn fx:id="colCategorie" text="Catégorie" prefWidth="110" sortable="true"/>
                <TableColumn fx:id="colStatut" text="Statut" prefWidth="110" sortable="true"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
