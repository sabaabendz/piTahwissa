<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.tahwissa.controller.MapViewController"
      VBox.vgrow="ALWAYS" style="-fx-background-color: -fx-background;">
    <VBox style="-fx-padding: 16px;" spacing="12">
        <Label text="Carte des événements" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: -fx-text-primary;"/>
        <ProgressIndicator fx:id="progressIndicator" visible="false" maxWidth="40" maxHeight="40"/>
        <Label fx:id="statusLabel" text="Chargement des lieux..." style="-fx-text-fill: -fx-text-secondary; -fx-font-size: 13px;"/>
    </VBox>
    <StackPane VBox.vgrow="ALWAYS" style="-fx-padding: 0 16px 16px 16px;">
        <WebView fx:id="webView" maxWidth="Infinity" maxHeight="Infinity" minWidth="200" minHeight="200"/>
    </StackPane>
</VBox>
