<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.tahwissa.controller.ReclamationListController"
      spacing="20" stylesheets="@../css/styles.css"
      style="-fx-padding: 24px;">

    <!-- Header Section -->
    <VBox spacing="16">
        <Label text="Gestion des Réclamations" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: -fx-text-primary;"/>
        
        <!-- Action Bar -->
        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-wrap-text: true;">
            <Button fx:id="btnCreate" text="+ Nouvelle réclamation" styleClass="btn, btn-primary" 
                   onAction="#handleCreate" style="-fx-min-width: 180px;"/>
            <Button fx:id="btnEdit" text="✏️ Modifier" styleClass="btn, btn-tertiary" 
                   onAction="#handleEdit" disable="true" style="-fx-min-width: 110px;"/>
            <Button fx:id="btnDelete" text="🗑️ Supprimer" styleClass="btn, btn-danger" 
                   onAction="#handleDelete" disable="true" style="-fx-min-width: 110px;"/>
            
            <Region HBox.hgrow="ALWAYS"/>
            
            <HBox spacing="8" alignment="CENTER_RIGHT">
                <ComboBox fx:id="cmbFilterStatut" promptText="Filtrer par statut" 
                         styleClass="form-field" style="-fx-min-width: 160px;"/>
                <TextField fx:id="txtSearch" promptText="🔍 Rechercher..." 
                          styleClass="form-field" style="-fx-min-width: 200px;"/>
                <Button text="Rechercher" styleClass="btn, btn-secondary" onAction="#handleSearch"
                       style="-fx-min-width: 120px;"/>
                <Button fx:id="btnRefresh" text="🔄" styleClass="btn, btn-outline" onAction="#handleRefresh"
                       style="-fx-min-width: 100px;"/>
            </HBox>
        </HBox>
    </VBox>

    <!-- Table Container -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS" style="-fx-padding: 0;">
        <TableView fx:id="tableReclamations" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60" sortable="true"/>
                <TableColumn fx:id="colTitre" text="Titre de la réclamation" prefWidth="240" sortable="true"/>
                <TableColumn fx:id="colType" text="Type" prefWidth="130" sortable="true"/>
                <TableColumn fx:id="colStatut" text="Statut" prefWidth="130" sortable="true"/>
                <TableColumn fx:id="colDate" text="Date de création" prefWidth="140" sortable="true"/>
                <TableColumn fx:id="colUtilisateur" text="Client" prefWidth="140" sortable="true"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
