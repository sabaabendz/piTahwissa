<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700" prefWidth="1000"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.tahwissa.controllers.GestionReservationsController"
            style="-fx-font-family: 'Segoe UI';">

    <!-- ═══════════════════════ TOP: HEADER ═══════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #3B82F6; -fx-padding: 15;">
            <Label text="🎫 TAHWISSA - Gestion Réservations"
                   style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" />

            <Region HBox.hgrow="ALWAYS" />

            <Button text="🚪 Déconnexion"
                    style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-padding: 8 16; -fx-border-radius: 4; -fx-background-radius: 4;" />
        </HBox>
    </top>

    <!-- ═══════════════════════ LEFT: SIDEBAR ═══════════════════════ -->
    <left>
        <VBox prefWidth="180" spacing="10"
              style="-fx-background-color: #F8FAFC; -fx-padding: 20; -fx-border-right: 1px solid #E5E7EB;">
            <Label text="MENU" style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: bold;" />
            <Separator />

            <Button fx:id="dashboardBtn" text="📊 Dashboard"
                    style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-padding: 10;"
                    wrapText="true" maxWidth="Infinity" />

            <Button fx:id="reservationsBtn" text="📋 Reservations"
                    style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-padding: 10; -fx-font-weight: bold;"
                    wrapText="true" maxWidth="Infinity" />

            <Button fx:id="clientsBtn" text="👥 Clients"
                    style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-padding: 10;"
                    wrapText="true" maxWidth="Infinity" />

            <Button fx:id="destinationsBtn" text="🏝️ Destinations"
                    style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-padding: 10;"
                    wrapText="true" maxWidth="Infinity" />
        </VBox>
    </left>

    <!-- ═══════════════════════ CENTER: MAIN CONTENT ═══════════════════════ -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <!-- Title -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Liste des Réservations"
                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1E293B;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="statsLabel" text="Total: 0"
                       style="-fx-text-fill: #6B7280; -fx-font-weight: bold;" />
            </HBox>

            <!-- Filters -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: #F3F4F6; -fx-padding: 15; -fx-border-radius: 6; -fx-background-radius: 6;">
                <Label text="🔍 Filtres:" style="-fx-text-fill: #475569; -fx-font-weight: bold;" />
                <ComboBox fx:id="statutFilter" prefWidth="140" promptText="Tous les statuts"
                          style="-fx-padding: 6; -fx-border-radius: 4;" />
                <TextField fx:id="searchField" prefWidth="250" promptText="Chercher par client ou voyage..."
                           style="-fx-padding: 6; -fx-border-radius: 4;" />
                <Button fx:id="filterBtn" text="Filtrer"
                        style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-padding: 6 16; -fx-border-radius: 4; -fx-background-radius: 4;" />
                <Button fx:id="resetBtn" text="Réinitialiser"
                        style="-fx-background-color: #E5E7EB; -fx-text-fill: #475569; -fx-padding: 6 16; -fx-border-radius: 4; -fx-background-radius: 4;" />
            </HBox>

            <!-- Action Buttons -->
            <HBox spacing="10">
                <Button fx:id="nouveauBtn" text="➕ Nouvelle Réservation"
                        style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-padding: 10 20; -fx-font-weight: bold; -fx-border-radius: 4; -fx-background-radius: 4;" />

                <Button fx:id="modifierBtn" text="✏️ Modifier"
                        style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-padding: 10 20; -fx-border-radius: 4; -fx-background-radius: 4;" />

                <Button fx:id="supprimerBtn" text="🗑️ Supprimer"
                        style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-padding: 10 20; -fx-border-radius: 4; -fx-background-radius: 4;" />

                <Button fx:id="refreshBtn" text="🔄 Actualiser"
                        style="-fx-background-color: #E5E7EB; -fx-text-fill: #475569; -fx-padding: 10 20; -fx-border-radius: 4; -fx-background-radius: 4;" />
            </HBox>


            <TableView fx:id="reservationsTable" prefHeight="450"
                       style="-fx-background-color: white; -fx-border-color: #E5E7EB;">
                <columns>
                    <TableColumn fx:id="idCol" prefWidth="50" text="ID" />
                    <TableColumn fx:id="clientCol" prefWidth="100" text="Client" />
                    <TableColumn fx:id="destCol" prefWidth="150" text="Voyage" />
                    <TableColumn fx:id="personnesCol" prefWidth="80" text="Personnes" />
                    <TableColumn fx:id="montantCol" prefWidth="100" text="Montant (DT)" />
                    <TableColumn fx:id="statutCol" prefWidth="100" text="Statut" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>

        </VBox>
    </center>

    <!-- ═══════════════════════ BOTTOM: FOOTER ═══════════════════════ -->
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #F1F5F9; -fx-padding: 10; -fx-border-top: 1px solid #E5E7EB;">
            <Label text="© 2026 Tahwissa - Travel Made Simple" style="-fx-text-fill: #6B7280;" />
        </HBox>
    </bottom>

</BorderPane>
