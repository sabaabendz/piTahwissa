<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.LoginController"
            prefHeight="650.0" prefWidth="1000.0"
            style="-fx-background: linear-gradient(from 0% 0% to 100% 100%, #1e3c72 0%, #2a5298 100%);">

    <!-- Effet de flou sur l'arrière-plan -->
    <effect>
        <Blend mode="SRC_OVER"/>
    </effect>

    <!-- Conteneur principal centré -->
    <VBox alignment="CENTER" spacing="30.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0">

        <!-- Carte de connexion -->
        <VBox spacing="25.0"
              style="-fx-background-color: rgba(255,255,255,0.95);
                     -fx-background-radius: 20;
                     -fx-padding: 40;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 10);"
              maxWidth="450.0" maxHeight="600.0">

            <!-- Effet de bordure lumineuse -->
            <effect>
                <InnerShadow color="#4CAF50" radius="2" width="2" height="2"/>
            </effect>

            <!-- Logo et Titre -->
            <VBox alignment="CENTER" spacing="10.0">
                <Circle radius="50.0" fill="linear-gradient(from 0% 0% to 100% 100%, #1e3c72, #2a5298)">
                    <effect>
                        <DropShadow color="rgba(0,0,0,0.3)" radius="10" offsetX="0" offsetY="5"/>
                    </effect>
                </Circle>
                <Label text="🌍" style="-fx-font-size: 48px; -fx-translate-y: -50; -fx-translate-x: 0;"/>

                <Label text="Tahwissa Voyage">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                    <textFill>
                        <LinearGradient startX="0.0" startY="0.0" endX="1.0" endY="0.0">
                            <stops>
                                <Stop offset="0.0" color="#1e3c72" />
                                <Stop offset="1.0" color="#2a5298" />
                            </stops>
                        </LinearGradient>
                    </textFill>
                </Label>

                <Label text="Plateforme de voyage collaborative"
                       style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d; -fx-font-style: italic;">
                    <font>
                        <Font name="System Italic" size="14.0" />
                    </font>
                </Label>
            </VBox>

            <!-- Séparateur décoratif -->
            <HBox alignment="CENTER" spacing="10.0">
                <Line startX="0" startY="0" endX="100" endY="0"
                      style="-fx-stroke: linear-gradient(to right, transparent, #3498db, transparent);"/>
                <Label text="✈️" style="-fx-font-size: 20px;"/>
                <Line startX="0" startY="0" endX="100" endY="0"
                      style="-fx-stroke: linear-gradient(to right, transparent, #3498db, transparent);"/>
            </HBox>

            <!-- Formulaire de connexion -->
            <VBox spacing="20.0">

                <!-- Champ Email avec icône -->
                <HBox spacing="15.0" alignment="CENTER_LEFT"
                      style="-fx-background-color: #f8f9fa;
                             -fx-background-radius: 30;
                             -fx-padding: 5 20;
                             -fx-border-color: #e0e0e0;
                             -fx-border-radius: 30;">
                    <Label text="📧" style="-fx-font-size: 18px;"/>
                    <TextField fx:id="emailField"
                               promptText="Entrez votre email"
                               style="-fx-background-color: transparent;
                                      -fx-border-width: 0;
                                      -fx-prompt-text-fill: #95a5a6;
                                      -fx-font-size: 14px;"
                               prefWidth="280.0"
                               HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Champ Mot de passe avec icône -->
                <HBox spacing="15.0" alignment="CENTER_LEFT"
                      style="-fx-background-color: #f8f9fa;
                             -fx-background-radius: 30;
                             -fx-padding: 5 20;
                             -fx-border-color: #e0e0e0;
                             -fx-border-radius: 30;">
                    <Label text="🔒" style="-fx-font-size: 18px;"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Entrez votre mot de passe"
                                   style="-fx-background-color: transparent;
                                          -fx-border-width: 0;
                                          -fx-prompt-text-fill: #95a5a6;
                                          -fx-font-size: 14px;"
                                   prefWidth="280.0"
                                   HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Options de connexion -->
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <CheckBox fx:id="rememberMeCheck" text="Se souvenir de moi"
                              style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Hyperlink text="Mot de passe oublié ?"
                               style="-fx-text-fill: #3498db; -fx-font-size: 12px;"
                               onAction="#handleForgotPassword"/>
                </HBox>

                <!-- Boutons d'action -->
                <VBox spacing="15.0" alignment="CENTER">

                    <!-- Bouton Connexion -->
                    <Button fx:id="loginButton"
                            text="Se connecter"
                            onAction="#handleLogin"
                            prefWidth="350.0" prefHeight="45.0"
                            style="-fx-background-color: linear-gradient(to right, #1e3c72, #2a5298);
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-font-size: 16px;
                                   -fx-background-radius: 30;
                                   -fx-cursor: hand;">
                        <effect>
                            <DropShadow color="rgba(30,60,114,0.5)" radius="10" offsetX="0" offsetY="5"/>
                        </effect>
                    </Button>

                    <!-- Lien d'inscription -->
                    <HBox alignment="CENTER" spacing="5.0">
                        <Label text="Vous n'avez pas de compte ?"
                               style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;"/>
                        <Button fx:id="registerButton"
                                text="S'inscrire"
                                onAction="#handleRegisterToggle"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #e67e22;
                                       -fx-font-weight: bold;
                                       -fx-font-size: 13px;
                                       -fx-underline: true;
                                       -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Formulaire d'inscription (caché par défaut) -->
            <VBox fx:id="registerForm" spacing="20.0" managed="false" visible="false">

                <!-- Séparateur -->
                <HBox alignment="CENTER" spacing="10.0">
                    <Line startX="0" startY="0" endX="150" endY="0"
                          style="-fx-stroke: linear-gradient(to right, transparent, #e67e22, transparent);"/>
                    <Label text="📝 Inscription" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
                    <Line startX="0" startY="0" endX="150" endY="0"
                          style="-fx-stroke: linear-gradient(to right, transparent, #e67e22, transparent);"/>
                </HBox>

                <!-- Champs d'inscription -->
                <GridPane hgap="15" vgap="15">
                    <Label text="Prénom:" GridPane.columnIndex="0" GridPane.rowIndex="0"
                           style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;"/>
                    <TextField fx:id="firstNameField"
                               promptText="Votre prénom"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"
                               prefWidth="250"/>

                    <Label text="Nom:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                           style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;"/>
                    <TextField fx:id="lastNameField"
                               promptText="Votre nom"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"
                               prefWidth="250"/>

                    <Label text="Rôle:" GridPane.columnIndex="0" GridPane.rowIndex="2"
                           style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;"/>
                    <ChoiceBox fx:id="roleChoiceBox"
                               prefWidth="250"
                               GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Voyageur" />
                                <String fx:value="Guide" />
                                <String fx:value="Agent" />
                            </FXCollections>
                        </items>
                    </ChoiceBox>
                </GridPane>

                <!-- Bouton Créer compte -->
                <Button text="Créer mon compte"
                        onAction="#handleRegister"
                        prefWidth="350.0" prefHeight="40.0"
                        style="-fx-background-color: linear-gradient(to right, #e67e22, #d35400);
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 14px;
                               -fx-background-radius: 30;"/>
            </VBox>

            <!-- Message d'état -->
            <Label fx:id="statusLabel"
                   style="-fx-font-size: 12px; -fx-text-fill: #666; -fx-padding: 10 0 0 0;"
                   wrapText="true"
                   alignment="CENTER"/>

            <!-- Status DB -->
            <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 20 0 0 0;">
                <Label fx:id="dbStatusLabel" text="🔌 Connexion à la base de données..."
                       style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;"/>
            </HBox>
        </VBox>

        <!-- Footer -->
        <HBox alignment="CENTER" spacing="20.0"
              style="-fx-padding: 20 0 0 0;">
            <Label text="Support 24/7" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;">
                <graphic>
                    <Label text="📞" style="-fx-font-size: 14px; -fx-padding: 0 5 0 0;"/>
                </graphic>
            </Label>
            <Label text="•" style="-fx-text-fill: rgba(255,255,255,0.5);"/>
            <Label text="Français" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
            <Label text="•" style="-fx-text-fill: rgba(255,255,255,0.5);"/>
            <Label text="English" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
            <Label text="•" style="-fx-text-fill: rgba(255,255,255,0.5);"/>
            <Label text="العربية" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
        </HBox>
    </VBox>

</AnchorPane>