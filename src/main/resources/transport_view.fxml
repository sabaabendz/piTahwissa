<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.TransportController"
      spacing="20" styleClass="view-container"
      stylesheets="@styles.css"
      prefWidth="450" prefHeight="550">
    
    <padding>
        <Insets top="25" right="30" bottom="25" left="30"/>
    </padding>

    <!-- Titre -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="👁" styleClass="view-icon">
            <font>
                <Font size="32"/>
            </font>
        </Label>
        <Label text="Détails du Transport" styleClass="view-title">
            <font>
                <Font name="System Bold" size="24"/>
            </font>
        </Label>
    </HBox>

    <Separator/>

    <!-- Détails -->
    <VBox spacing="20" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <!-- ID -->
        <HBox spacing="10" styleClass="detail-row">
            <Label text="ID:" styleClass="detail-label" minWidth="140">
                <font>
                    <Font name="System Bold" size="14"/>
                </font>
            </Label>
            <Label fx:id="viewIdLabel" text="-" styleClass="detail-value">
                <font>
                    <Font size="14"/>
                </font>
            </Label>
        </HBox>

        <!-- Type -->
        <HBox spacing="10" styleClass="detail-row">
            <Label text="Type de Transport:" styleClass="detail-label" minWidth="140">
                <font>
                    <Font name="System Bold" size="14"/>
                </font>
            </Label>
            <Label fx:id="viewTypeLabel" text="-" styleClass="detail-value">
                <font>
                    <Font size="14"/>
                </font>
            </Label>
        </HBox>

        <!-- Ville de Départ -->
        <HBox spacing="10" styleClass="detail-row">
            <Label text="Ville de Départ:" styleClass="detail-label" minWidth="140">
                <font>
                    <Font name="System Bold" size="14"/>
                </font>
            </Label>
            <Label fx:id="viewVilleDepartLabel" text="-" styleClass="detail-value">
                <font>
                    <Font size="14"/>
                </font>
            </Label>
        </HBox>

        <!-- Ville d'Arrivée -->
        <HBox spacing="10" styleClass="detail-row">
            <Label text="Ville d'Arrivée:" styleClass="detail-label" minWidth="140">
                <font>
                    <Font name="System Bold" size="14"/>
                </font>
            </Label>
            <Label fx:id="viewVilleArriveeLabel" text="-" styleClass="detail-value">
                <font>
                    <Font size="14"/>
                </font>
            </Label>
        </HBox>

        <!-- Date de Départ -->
        <HBox spacing="10" styleClass="detail-row">
            <Label text="Date de Départ:" styleClass="detail-label" minWidth="140">
                <font>
                    <Font name="System Bold" size="14"/>
                </font>
            </Label>
            <Label fx:id="viewDateDepartLabel" text="-" styleClass="detail-value">
                <font>
                    <Font size="14"/>
                </font>
            </Label>
        </HBox>

        <!-- Heure de Départ -->
        <HBox spacing="10" styleClass="detail-row">
            <Label text="Heure de Départ:" styleClass="detail-label" minWidth="140">
                <font>
                    <Font name="System Bold" size="14"/>
                </font>
            </Label>
            <Label fx:id="viewHeureDepartLabel" text="-" styleClass="detail-value">
                <font>
                    <Font size="14"/>
                </font>
            </Label>
        </HBox>

        <!-- Durée -->
        <HBox spacing="10" styleClass="detail-row">
            <Label text="Durée:" styleClass="detail-label" minWidth="140">
                <font>
                    <Font name="System Bold" size="14"/>
                </font>
            </Label>
            <Label fx:id="viewDureeLabel" text="-" styleClass="detail-value">
                <font>
                    <Font size="14"/>
                </font>
            </Label>
        </HBox>

        <!-- Prix -->
        <HBox spacing="10" styleClass="detail-row">
            <Label text="Prix:" styleClass="detail-label" minWidth="140">
                <font>
                    <Font name="System Bold" size="14"/>
                </font>
            </Label>
            <Label fx:id="viewPrixLabel" text="-" styleClass="detail-value-highlight">
                <font>
                    <Font name="System Bold" size="16"/>
                </font>
            </Label>
        </HBox>

        <!-- Nombre de Places -->
        <HBox spacing="10" styleClass="detail-row">
            <Label text="Nombre de Places:" styleClass="detail-label" minWidth="140">
                <font>
                    <Font name="System Bold" size="14"/>
                </font>
            </Label>
            <Label fx:id="viewNbPlacesLabel" text="-" styleClass="detail-value">
                <font>
                    <Font size="14"/>
                </font>
            </Label>
        </HBox>

    </VBox>

    <Separator/>

    <!-- Bouton Retour -->
    <HBox alignment="CENTER_RIGHT">
        <Button text="← Retour à la liste" onAction="#handleBackToList" 
                styleClass="secondary-button" prefWidth="160">
            <font>
                <Font size="14"/>
            </font>
        </Button>
    </HBox>

</VBox>
