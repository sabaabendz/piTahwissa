<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.tahwisa.controllers.MainLayoutController"
            stylesheets="@../css/styles.css">

    <left>
        <VBox styleClass="sidebar" prefWidth="250">
            <VBox styleClass="logo-container" spacing="5">
                <Label text="🌍 Tahwissa" styleClass="logo-title"/>
                <Label text="Travel Management" styleClass="logo-subtitle"/>
            </VBox>

            <Separator style="-fx-background-color: rgba(255,255,255,0.2);"/>

            <VBox VBox.vgrow="ALWAYS" spacing="5">
                <Label text="MODULES DE GESTION" styleClass="menu-section-title"/>

                <Button fx:id="btnDestinations" text="📍 Destinations" styleClass="menu-button active"
                        onAction="#showDestinations" maxWidth="Infinity"/>

                <Button fx:id="btnPointsInteret" text="🏖️ Points d'Intérêt" styleClass="menu-button"
                        onAction="#showPointsInteret" maxWidth="Infinity"/>

                <Region VBox.vgrow="ALWAYS"/>

                <Label text="PARAMÈTRES" styleClass="menu-section-title"/>
                <Button text="⚙️ Paramètres" styleClass="menu-button" maxWidth="Infinity"/>
            </VBox>

            <VBox styleClass="user-profile" spacing="8">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <StackPane styleClass="user-avatar">
                        <Label text="A" styleClass="user-avatar-text"/>
                    </StackPane>
                    <VBox>
                        <Label text="Administrateur" styleClass="user-name"/>
                        <Label text="admin@tahwissa.com" styleClass="user-email"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area"/>
    </center>

    <bottom>
        <HBox styleClass="status-bar" spacing="15" alignment="CENTER_LEFT">
            <HBox spacing="5" alignment="CENTER_LEFT">
                <Region styleClass="status-indicator"/>
                <Label text="Connecté" styleClass="status-text"/>
            </HBox>
            <Separator orientation="VERTICAL"/>
            <Label fx:id="lblStatus" text="Base: tahwisa_db" styleClass="status-text"/>
            <Separator orientation="VERTICAL"/>
            <Label text="Mode: Liste" styleClass="status-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblDate" styleClass="status-text"/>
        </HBox>
    </bottom>
</BorderPane>