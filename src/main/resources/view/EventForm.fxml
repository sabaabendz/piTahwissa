<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.tahwissa.controller.EventFormController"
           stylesheets="@../css/styles.css"
           fitToWidth="true" style="-fx-background-color: -fx-background;">
    
    <VBox spacing="24" style="-fx-padding: 24px;">

        <!-- Header Section -->
        <VBox spacing="12">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Button text="← Retour" styleClass="btn, btn-ghost" onAction="#handleBackToList"
                       style="-fx-font-size: 13px;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
            <Label fx:id="formTitle" text="Créer un nouvel événement" 
                  style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: -fx-text-primary;"/>
            <Label text="Remplissez tous les champs obligatoires pour créer un événement" 
                  styleClass="subtitle-text"/>
        </VBox>

        <!-- Card avec le formulaire -->
        <VBox styleClass="card" spacing="24">

            <!-- Message Label -->
            <Label fx:id="messageLabel" visible="false" wrapText="true" maxWidth="Infinity"
                  style="-fx-padding: 12; -fx-background-radius: 10;"/>

            <!-- Formulaire Grid - Responsive -->
            <GridPane hgap="20" vgap="18">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50" minWidth="250"/>
                    <ColumnConstraints percentWidth="50" minWidth="250"/>
                </columnConstraints>

                <!-- Row 0: Titre et Lieu -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="🎯 Titre de l'événement *" styleClass="form-label"/>
                    <TextField fx:id="txtTitre" promptText="Ex: Concert Live Jazz" 
                              styleClass="form-field" style="-fx-font-size: 14px;"/>
                </VBox>

                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="📍 Lieu *" styleClass="form-label"/>
                    <TextField fx:id="txtLieu" promptText="Ex: Carthage Theatre" 
                              styleClass="form-field" style="-fx-font-size: 14px;"/>
                </VBox>

                <!-- Row 1: Description -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                    <Label text="📝 Description détaillée *" styleClass="form-label"/>
                    <TextArea fx:id="txtDescription" promptText="Décrivez l'événement en détail..." 
                             styleClass="form-field" prefRowCount="4" wrapText="true"
                             style="-fx-font-size: 14px; -fx-control-inner-background: -fx-surface;"/>
                </VBox>

                <!-- Row 2: Date et Heure -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <Label text="📅 Date de l'événement *" styleClass="form-label"/>
                    <DatePicker fx:id="dateEvent" promptText="jj/mm/aaaa" 
                               styleClass="form-field" maxWidth="Infinity" style="-fx-font-size: 14px;"/>
                </VBox>

                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <Label text="⏰ Heure de l'événement (HH:MM) *" styleClass="form-label"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Spinner fx:id="spnHeure" prefWidth="100" styleClass="form-field"
                                style="-fx-font-size: 14px;"/>
                        <Label text=":" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-text-secondary;"/>
                        <Spinner fx:id="spnMinute" prefWidth="100" styleClass="form-field"
                                style="-fx-font-size: 14px;"/>
                    </HBox>
                </VBox>

                <!-- Row 3: Prix et Places -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="3">
                    <Label text="💰 Prix (DT) *" styleClass="form-label"/>
                    <TextField fx:id="txtPrix" promptText="0.00" 
                              styleClass="form-field" style="-fx-font-size: 14px;"/>
                </VBox>

                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <Label text="👥 Nombre de places disponibles *" styleClass="form-label"/>
                    <Spinner fx:id="spnPlaces" styleClass="form-field" maxWidth="Infinity" 
                            editable="true" style="-fx-font-size: 14px;"/>
                </VBox>

                <!-- Row 4: Catégorie et Statut -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="4">
                    <Label text="🏷️ Catégorie *" styleClass="form-label"/>
                    <ComboBox fx:id="cmbCategorie" promptText="Sélectionner une catégorie"
                             styleClass="form-field" maxWidth="Infinity" style="-fx-font-size: 14px;"/>
                </VBox>

                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="4">
                    <Label text="✅ Statut *" styleClass="form-label"/>
                    <ComboBox fx:id="cmbStatut" promptText="Sélectionner un statut"
                             styleClass="form-field" maxWidth="Infinity" style="-fx-font-size: 14px;"/>
                </VBox>

                <!-- Row 5: Image -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="2">
                    <Label text="🖼️ Image de l'événement" styleClass="form-label"/>
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <StackPane style="-fx-background-color: #E2E8F0; -fx-background-radius: 8; -fx-min-width: 140; -fx-min-height: 100; -fx-pref-width: 140; -fx-pref-height: 100;">
                            <ImageView fx:id="imgEvent" fitWidth="140" fitHeight="100" preserveRatio="true" pickOnBounds="true"/>
                        </StackPane>
                        <VBox spacing="8">
                            <Button fx:id="btnChooseImage" text="Choisir une image" styleClass="btn, btn-secondary" onAction="#handleChooseImage"
                                   style="-fx-min-width: 160px;"/>
                            <Label fx:id="lblImageName" styleClass="text-muted" style="-fx-font-size: 12px;" wrapText="true" maxWidth="240"/>
                        </VBox>
                    </HBox>
                </VBox>
            </GridPane>

            <Separator/>

            <!-- Boutons d'action -->
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="Annuler" styleClass="btn, btn-outline" onAction="#handleCancel"
                       style="-fx-min-width: 120px;"/>
                <Button fx:id="btnSubmit" text="✓ Enregistrer l'événement" styleClass="btn, btn-primary" 
                       onAction="#handleSave" style="-fx-min-width: 200px;"/>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>
