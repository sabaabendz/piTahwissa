<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.DashboardController"
            prefHeight="720.0" prefWidth="1080.0"
            style="-fx-background-color: #f7f9fb;">

    <top>
        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 20 24; -fx-background-color: white; -fx-border-color: #e6ecf1; -fx-border-width: 0 0 1 0;">
            <Label text="🌍 Tahwissa Dashboard" style="-fx-text-fill: #4F46E5;">
                <font><Font size="22" name="System Bold"/></font>
            </Label>
            <Label fx:id="roleLabel" text="Role: N/A" style="-fx-background-color: #9333EA; -fx-text-fill: white; -fx-padding: 6 12; -fx-background-radius: 12; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🚪 Déconnexion"
                    onAction="#handleLogout"
                    style="-fx-background-color: #9333EA; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" hbarPolicy="NEVER">
            <VBox spacing="20" style="-fx-padding: 24;" fx:id="mainContent">

                <HBox spacing="20">
                    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 12, 0, 0, 6);" HBox.hgrow="ALWAYS">
                        <Label text="👥 Gestion des utilisateurs" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #4F46E5;"/>
                        <Label text="Créer, modifier et désactiver des comptes" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
                        <HBox spacing="10">
                            <Button text="📋 Ouvrir la liste"
                                    onAction="#handleOpenUserList"
                                    style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                            <Button text="➕ Nouveau"
                                    style="-fx-background-color: #9333EA; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 12, 0, 0, 6);" HBox.hgrow="ALWAYS">
                        <Label text="🎫 Tickets et Support" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #4F46E5;"/>
                        <Label text="Suivre les demandes et escalades" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
                        <HBox spacing="10">
                            <Button text="📋 Voir les tickets" style="-fx-background-color: #4F46E5; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20;"/>
                            <Button text="📊 Rapport" style="-fx-background-color: #9333EA; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20;"/>
                        </HBox>
                    </VBox>
                </HBox>

                <HBox spacing="20">
                    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 12, 0, 0, 6);" HBox.hgrow="ALWAYS">
                        <Label text="Statistiques" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #4F46E5;"/>
                        <GridPane hgap="12" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>
                            <Label text="Utilisateurs actifs" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #7f8c8d;"/>
                            <Label text="42" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #4F46E5;"/>
                            <Label text="Agents connectés" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #7f8c8d;"/>
                            <Label text="7" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-text-fill: #4F46E5;"/>
                            <Label text="Tickets ouverts" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #7f8c8d;"/>
                            <Label text="15" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-text-fill: #4F46E5;"/>
                        </GridPane>
                    </VBox>

                    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 12, 0, 0, 6);" HBox.hgrow="ALWAYS">
                        <Label text="📈 Activité récente" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #4F46E5;"/>
                        <VBox spacing="8" style="-fx-padding: 10; -fx-background-color: #f8f9fa; -fx-background-radius: 8;">
                            <Label text="✅ Admin a ajouté un utilisateur" style="-fx-text-fill: #3B82F6; -fx-font-size: 12px;"/>
                            <Label text="✅ Agent a fermé un ticket" style="-fx-text-fill: #3B82F6; -fx-font-size: 12px;"/>
                            <Label text="✏️ Admin a mis à jour un rôle" style="-fx-text-fill: #4F46E5; -fx-font-size: 12px;"/>
                        </VBox>
                    </VBox>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox style="-fx-padding: 12 20; -fx-background-color: white; -fx-border-color: #e6ecf1; -fx-border-width: 1 0 0 0;" alignment="CENTER_LEFT">
            <Label fx:id="warningLabel" text="Accès réservé aux rôles ADMIN et AGENT" style="-fx-text-fill: #9333EA; -fx-font-size: 12px;"/>
        </HBox>
    </bottom>
</BorderPane>

