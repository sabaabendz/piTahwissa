<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.LoginController"
            prefHeight="650.0" prefWidth="700.0"
            style="-fx-background: linear-gradient(from 0% 0% to 100% 100%, #9333EA 0%, #4F46E5 50%, #3B82F6 100%);">

    <!-- Conteneur principal centré -->
    <VBox alignment="CENTER" spacing="10.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0">

        <!-- Carte de connexion -->
        <VBox spacing="12.0"
              style="-fx-background-color: rgba(255,255,255,0.95);
                     -fx-background-radius: 20;
                     -fx-padding: 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 10);"
              maxWidth="380.0" maxHeight="600.0">

            <!-- ================ LOGO MODERNE TAHWISSA ================ -->
            <VBox alignment="CENTER" spacing="8.0">
                <!-- Conteneur du logo -->
                <StackPane prefWidth="120" prefHeight="120">
                    <!-- Carré arrondi fond gris clair -->
                    <Rectangle width="120" height="120" arcWidth="25" arcHeight="25"
                               fill="linear-gradient(to bottom, #e8eef2, #d5dce1)">
                        <effect>
                            <DropShadow color="rgba(0,0,0,0.15)" radius="15" offsetX="0" offsetY="8"/>
                        </effect>
                    </Rectangle>

                    <!-- Cercle central légèrement plus clair -->
                    <Circle radius="48" fill="linear-gradient(to bottom, #f0f4f7, #e0e7ec)">
                        <effect>
                            <InnerShadow color="rgba(255,255,255,0.8)" radius="5" offsetX="0" offsetY="-2"/>
                        </effect>
                    </Circle>

                    <!-- Groupe des éléments principaux -->
                    <StackPane>
                        <!-- Trajectoire en pointillés (chemin de l'avion) -->
                        <Line startX="-25" startY="15" endX="20" endY="-20"
                              stroke="#3498db" strokeWidth="2.5"
                              strokeDashArray="4, 6" opacity="0.7"
                              translateX="0" translateY="5"/>

                        <!-- Avion stylisé bleu -->
                        <Label text="✈️"
                               style="-fx-font-size: 32px; -fx-rotate: -45;"
                               translateX="15" translateY="-12">
                            <effect>
                                <DropShadow color="#2980b9" radius="5" offsetX="1" offsetY="1"/>
                            </effect>
                        </Label>

                        <!-- Épingle de localisation violette -->
                        <Label text="📍"
                               style="-fx-font-size: 28px;"
                               translateX="-18" translateY="8">
                            <effect>
                                <ColorAdjust hue="0.7" saturation="0.8"/>
                            </effect>
                        </Label>

                        <!-- Bulle de discussion violette -->
                        <StackPane translateX="22" translateY="18">
                            <!-- Fond bulle -->
                            <Circle radius="13" fill="linear-gradient(to bottom, #9b59b6, #8e44ad)">
                                <effect>
                                    <DropShadow color="rgba(142,68,173,0.4)" radius="6" offsetX="0" offsetY="3"/>
                                </effect>
                            </Circle>
                            <!-- Icône message -->
                            <Label text="💬" style="-fx-font-size: 16px;"/>
                        </StackPane>
                    </StackPane>
                </StackPane>

                <!-- ✅ Titre principal -->
                <Label text="Tahwissa Voyage"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #9333EA;"/>

                <!-- Sous-titre -->
                <Label text="Plateforme de voyage collaborative"
                       style="-fx-font-size: 11px; -fx-text-fill: #6B7280; -fx-font-style: italic;"/>
            </VBox>

            <!-- Séparateur décoratif -->
            <HBox alignment="CENTER" spacing="10.0">
                <Line startX="0" startY="0" endX="100" endY="0"
                      style="-fx-stroke: linear-gradient(to right, transparent, #4F46E5, transparent);"/>
                <Label text="✈️" style="-fx-font-size: 20px;"/>
                <Line startX="0" startY="0" endX="100" endY="0"
                      style="-fx-stroke: linear-gradient(to right, transparent, #4F46E5, transparent);"/>
            </HBox>

            <!-- ================ FORMULAIRE DE CONNEXION ================ -->
            <VBox spacing="12.0">

                <!-- Champ Email -->
                <VBox spacing="3.0">
                    <Label text="Email" style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <HBox spacing="10.0" alignment="CENTER_LEFT"
                          style="-fx-background-color: #f8f9fa;
                                 -fx-background-radius: 30;
                                 -fx-padding: 3 15;
                                 -fx-border-color: #e0e0e0;
                                 -fx-border-radius: 30;">
                        <Label text="📧" style="-fx-font-size: 16px;"/>
                        <TextField fx:id="emailField"
                                   promptText="Entrez votre email"
                                   style="-fx-background-color: transparent;
                                          -fx-border-width: 0;
                                          -fx-prompt-text-fill: #95a5a6;
                                          -fx-font-size: 13px;"
                                   HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Champ Mot de passe -->
                <VBox spacing="3.0">
                    <Label text="Mot de passe" style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <HBox spacing="10.0" alignment="CENTER_LEFT"
                          style="-fx-background-color: #f8f9fa;
                                 -fx-background-radius: 30;
                                 -fx-padding: 3 15;
                                 -fx-border-color: #e0e0e0;
                                 -fx-border-radius: 30;">
                        <Label text="🔒" style="-fx-font-size: 16px;"/>
                        <PasswordField fx:id="passwordField"
                                       promptText="Entrez votre mot de passe"
                                       style="-fx-background-color: transparent;
                                              -fx-border-width: 0;
                                              -fx-prompt-text-fill: #95a5a6;
                                              -fx-font-size: 13px;"
                                       HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Options -->
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <CheckBox fx:id="rememberMeCheck" text="Se souvenir de moi"
                              style="-fx-text-fill: #6B7280; -fx-font-size: 11px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Hyperlink text="Mot de passe oublié ?"
                               style="-fx-text-fill: #4F46E5; -fx-font-size: 11px;"
                               onAction="#handleForgotPassword"/>
                </HBox>

                <!-- Boutons -->
                <VBox spacing="10.0" alignment="CENTER">
                    <!-- Bouton Connexion -->
                    <Button fx:id="loginButton"
                            text="Se connecter"
                            onAction="#handleLogin"
                            prefWidth="300.0" prefHeight="40.0"
                            style="-fx-background-color: linear-gradient(to right, #9333EA, #4F46E5, #3B82F6);
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-font-size: 15px;
                                   -fx-background-radius: 30;
                                   -fx-cursor: hand;">
                        <effect>
                            <DropShadow color="rgba(79,70,229,0.5)" radius="10" offsetX="0" offsetY="5"/>
                        </effect>
                    </Button>

                    <!-- Lien inscription -->
                    <HBox alignment="CENTER" spacing="5.0">
                        <Label text="Vous n'avez pas de compte ?"
                               style="-fx-text-fill: #6B7280; -fx-font-size: 12px;"/>
                        <Button fx:id="registerButton"
                                text="S'inscrire"
                                onAction="#handleRegisterToggle"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #3B82F6;
                                       -fx-font-weight: bold;
                                       -fx-font-size: 12px;
                                       -fx-underline: true;
                                       -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- ================ FORMULAIRE D'INSCRIPTION ================ -->
            <VBox fx:id="registerForm" spacing="20.0" managed="false" visible="false">
                <!-- Séparateur -->
                <HBox alignment="CENTER" spacing="10.0">
                    <Line startX="0" startY="0" endX="150" endY="0"
                          style="-fx-stroke: linear-gradient(to right, transparent, #3B82F6, transparent);"/>
                    <Label text="📝 Inscription" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3B82F6;"/>
                    <Line startX="0" startY="0" endX="150" endY="0"
                          style="-fx-stroke: linear-gradient(to right, transparent, #3B82F6, transparent);"/>
                </HBox>

                <!-- Champs d'inscription -->
                <GridPane hgap="10" vgap="12">
                    <Label text="Prénom:" GridPane.columnIndex="0" GridPane.rowIndex="0"
                           style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <TextField fx:id="firstNameField"
                               promptText="Votre prénom"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"
                               prefWidth="200"/>

                    <Label text="Nom:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                           style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <TextField fx:id="lastNameField"
                               promptText="Votre nom"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"
                               prefWidth="200"/>

                    <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2"
                           style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <TextField fx:id="registerEmailField"
                               promptText="votre.email@exemple.com"
                               GridPane.columnIndex="1" GridPane.rowIndex="2"
                               prefWidth="200"/>

                    <Label text="Téléphone:" GridPane.columnIndex="0" GridPane.rowIndex="3"
                           style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <TextField fx:id="phoneNumberField"
                               promptText="+216 XX XXX XXX"
                               GridPane.columnIndex="1" GridPane.rowIndex="3"
                               prefWidth="200"/>

                    <Label text="Ville:" GridPane.columnIndex="0" GridPane.rowIndex="4"
                           style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <TextField fx:id="cityField"
                               promptText="Votre ville"
                               GridPane.columnIndex="1" GridPane.rowIndex="4"
                               prefWidth="200"/>

                    <Label text="Pays:" GridPane.columnIndex="0" GridPane.rowIndex="5"
                           style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <TextField fx:id="countryField"
                               promptText="Votre pays"
                               GridPane.columnIndex="1" GridPane.rowIndex="5"
                               prefWidth="200"/>

                    <Label text="Mot de passe:" GridPane.columnIndex="0" GridPane.rowIndex="6"
                           style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <PasswordField fx:id="registerPasswordField"
                                   promptText="Choisissez un mot de passe"
                                   GridPane.columnIndex="1" GridPane.rowIndex="6"
                                   prefWidth="200"/>

                    <Label text="Rôle:" GridPane.columnIndex="0" GridPane.rowIndex="7"
                           style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <ChoiceBox fx:id="roleChoiceBox"
                               prefWidth="200"
                               GridPane.columnIndex="1" GridPane.rowIndex="7">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Voyageur" />
                                <String fx:value="Guide" />
                                <String fx:value="Agent" />
                            </FXCollections>
                        </items>
                    </ChoiceBox>
                </GridPane>

                <!-- Bouton Créer compte -->
                <Button text="Créer mon compte"
                        onAction="#handleRegister"
                        prefWidth="300.0" prefHeight="40.0"
                        style="-fx-background-color: linear-gradient(to right, #3B82F6, #2563EB);
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 14px;
                               -fx-background-radius: 30;"/>
            </VBox>

            <!-- Message d'état -->
            <Label fx:id="statusLabel"
                   style="-fx-font-size: 12px; -fx-text-fill: #666; -fx-padding: 10 0 0 0;"
                   wrapText="true"
                   alignment="CENTER"/>

            <!-- Statut DB -->
            <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 20 0 0 0;">
                <Label fx:id="dbStatusLabel" text="🔌 Connexion à la base de données..."
                       style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;"/>
            </HBox>
        </VBox>

        <!-- Footer -->
        <HBox alignment="CENTER" spacing="20.0"
              style="-fx-padding: 20 0 0 0;">
            <Label text="Support 24/7" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;">
                <graphic>
                    <Label text="📞" style="-fx-font-size: 14px; -fx-padding: 0 5 0 0;"/>
                </graphic>
            </Label>
            <Label text="•" style="-fx-text-fill: rgba(255,255,255,0.5);"/>
            <Label text="Français" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
            <Label text="•" style="-fx-text-fill: rgba(255,255,255,0.5);"/>
            <Label text="English" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
            <Label text="•" style="-fx-text-fill: rgba(255,255,255,0.5);"/>
            <Label text="العربية" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
        </HBox>
    </VBox>
</AnchorPane>