<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Line?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.RegisterController"
            prefHeight="650.0" prefWidth="700.0"
            style="-fx-background: linear-gradient(from 0% 0% to 100% 100%, #9333EA 0%, #4F46E5 50%, #3B82F6 100%);">

    <VBox alignment="CENTER" spacing="12.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0">

        <VBox spacing="14.0"
              style="-fx-background-color: rgba(255,255,255,0.95);
                     -fx-background-radius: 20;
                     -fx-padding: 22;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 10);"
              maxWidth="430.0">

            <VBox alignment="CENTER" spacing="6.0">
                <Label text="Créer un compte"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #4F46E5;"/>
                <Label text="Rejoignez Tahwissa en quelques secondes"
                       style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
            </VBox>

            <HBox alignment="CENTER" spacing="10.0">
                <Line startX="0" startY="0" endX="140" endY="0"
                      style="-fx-stroke: linear-gradient(to right, transparent, #4F46E5, transparent);"/>
                <Label text="📝" style="-fx-font-size: 16px;"/>
                <Line startX="0" startY="0" endX="140" endY="0"
                      style="-fx-stroke: linear-gradient(to right, transparent, #4F46E5, transparent);"/>
            </HBox>

            <GridPane hgap="12" vgap="12">
                <columnConstraints>
                    <ColumnConstraints minWidth="120" halignment="RIGHT"/>
                    <ColumnConstraints minWidth="240" hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Prénom:" GridPane.columnIndex="0" GridPane.rowIndex="0"
                       style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="firstNameField"
                           promptText="Votre prénom"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Nom:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                       style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="lastNameField"
                           promptText="Votre nom"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2"
                       style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="emailField"
                           promptText="votre.email@exemple.com"
                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="Téléphone:" GridPane.columnIndex="0" GridPane.rowIndex="3"
                       style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="phoneField"
                           promptText="+216 XX XXX XXX"
                           GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Ville:" GridPane.columnIndex="0" GridPane.rowIndex="4"
                       style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="cityField"
                           promptText="Votre ville"
                           GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                <Label text="Pays:" GridPane.columnIndex="0" GridPane.rowIndex="5"
                       style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="countryField"
                           promptText="Votre pays"
                           GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                <Label text="Mot de passe:" GridPane.columnIndex="0" GridPane.rowIndex="6"
                       style="-fx-text-fill: #1F2937; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <PasswordField fx:id="passwordField"
                               promptText="Choisissez un mot de passe"
                               GridPane.columnIndex="1" GridPane.rowIndex="6"/>
            </GridPane>

            <VBox spacing="10.0" alignment="CENTER">
                <Button fx:id="registerButton"
                        text="Créer mon compte"
                        onAction="#handleRegister"
                        prefWidth="300.0" prefHeight="40.0"
                        style="-fx-background-color: linear-gradient(to right, #3B82F6, #2563EB);
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 14px;
                               -fx-background-radius: 30;">
                    <effect>
                        <DropShadow color="rgba(37,99,235,0.45)" radius="10" offsetX="0" offsetY="4"/>
                    </effect>
                </Button>

                <Button fx:id="backButton"
                        text="Retour à la connexion"
                        onAction="#handleBackToLogin"
                        prefWidth="300.0" prefHeight="36.0"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #4F46E5;
                               -fx-font-weight: bold;
                               -fx-font-size: 12px;
                               -fx-underline: true;
                               -fx-cursor: hand;"/>
            </VBox>

            <Label fx:id="statusLabel"
                   style="-fx-font-size: 12px; -fx-text-fill: #666; -fx-padding: 6 0 0 0;"
                   wrapText="true"
                   alignment="CENTER"/>
        </VBox>
    </VBox>
</AnchorPane>

