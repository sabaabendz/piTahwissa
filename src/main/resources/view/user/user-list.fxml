<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.UserListController"
            prefHeight="700.0" prefWidth="1000.0"
            style="-fx-background-color: #F8F9FA;">

    <top>
        <VBox spacing="0">
            <HBox style="-fx-background-color: #2C3E50; -fx-padding: 20 30;"
                  alignment="CENTER_LEFT">
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="👥" style="-fx-font-size: 28px; -fx-text-fill: white;"/>
                    <VBox spacing="5">
                        <Label text="Gestion des Utilisateurs"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Module CRUD - Tahwissa Travel Platform"
                               style="-fx-font-size: 12px; -fx-text-fill: #ECF0F1;"/>
                    </VBox>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="backToDashboardBtn" text="← Dashboard"
                        style="-fx-background-color: #34495E; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-background-radius: 20; -fx-padding: 10 20;
                               -fx-cursor: hand;"
                        prefHeight="40.0"/>
                <Button fx:id="addUserBtn" text="➕ Nouvel Utilisateur"
                        style="-fx-background-color: #27AE60; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 14px;
                               -fx-background-radius: 20; -fx-padding: 10 25;
                               -fx-cursor: hand;"
                        prefHeight="40.0"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="25" style="-fx-padding: 30; -fx-background-color: #F8F9FA;">

            <!-- Barre de recherche -->
            <HBox spacing="20" alignment="CENTER_LEFT">
                <HBox spacing="0" HBox.hgrow="ALWAYS">
                    <TextField fx:id="searchField"
                               promptText="Rechercher par email, nom ou prénom..."
                               prefWidth="350" prefHeight="40"
                               style="-fx-background-radius: 20 0 0 20;
                                      -fx-border-radius: 20 0 0 20;
                                      -fx-padding: 0 15;
                                      -fx-border-color: #BDC3C7;
                                      -fx-border-width: 1;
                                      -fx-background-color: white;"/>
                    <Button fx:id="searchBtn" text="🔍 Rechercher"
                            prefHeight="40" prefWidth="120"
                            style="-fx-background-color: #3498DB;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 0 20 20 0;
                                   -fx-cursor: hand;"/>
                </HBox>

                <!-- Filtres -->
                <HBox spacing="10" alignment="CENTER">
                    <Label text="Rôle:" style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                    <ChoiceBox fx:id="roleFilter" prefWidth="150" prefHeight="40"
                               style="-fx-background-radius: 20; -fx-border-radius: 20;
                                      -fx-border-color: #BDC3C7; -fx-border-width: 1;">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Tous les rôles" />
                                <String fx:value="USER" />
                                <String fx:value="AGENT" />
                                <String fx:value="ADMIN" />
                            </FXCollections>
                        </items>
                    </ChoiceBox>
                </HBox>

                <HBox spacing="10" alignment="CENTER">
                    <Label text="Statut:" style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                    <ChoiceBox fx:id="statusFilter" prefWidth="150" prefHeight="40"
                               style="-fx-background-radius: 20; -fx-border-radius: 20;
                                      -fx-border-color: #BDC3C7; -fx-border-width: 1;">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Tous" />
                                <String fx:value="Actif" />
                                <String fx:value="Inactif" />
                            </FXCollections>
                        </items>
                    </ChoiceBox>
                </HBox>
            </HBox>

            <!-- Tableau -->
            <VBox spacing="15">
                <Label text="📋 Liste des utilisateurs"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>

                <TableView fx:id="userTable" prefHeight="400" VBox.vgrow="ALWAYS"
                           style="-fx-background-radius: 10; -fx-border-radius: 10;
                                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="emailColumn" text="Email" prefWidth="200"/>
                        <TableColumn fx:id="firstNameColumn" text="Prénom" prefWidth="120"/>
                        <TableColumn fx:id="lastNameColumn" text="Nom" prefWidth="120"/>
                        <TableColumn fx:id="roleColumn" text="Rôle" prefWidth="100"/>
                        <TableColumn fx:id="statusColumn" text="Statut" prefWidth="100"/>
                        <TableColumn fx:id="verifiedColumn" text="Vérifié" prefWidth="80"/>
                        <TableColumn fx:id="createdAtColumn" text="Créé le" prefWidth="150"/>
                        <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="200"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Statistiques -->
            <HBox alignment="CENTER_RIGHT" spacing="30">
                <Label fx:id="totalUsersLabel" text="Total: 0 utilisateurs"
                       style="-fx-font-size: 13px; -fx-text-fill: #2C3E50; -fx-font-weight: bold;"/>
                <Label fx:id="activeUsersLabel" text="Actifs: 0"
                       style="-fx-font-size: 13px; -fx-text-fill: #27AE60; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox style="-fx-background-color: #34495E; -fx-padding: 15 30;"
              alignment="CENTER_RIGHT">
            <Label fx:id="dbStatusLabel" text="✅ Connecté à pidev"
                   style="-fx-text-fill: #27AE60; -fx-font-size: 12px;"/>
        </HBox>
    </bottom>

</BorderPane>