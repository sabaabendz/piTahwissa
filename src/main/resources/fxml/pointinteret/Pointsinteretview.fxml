<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.tahwissa.controllers.pointinteret.PointInteretViewController"
      spacing="0" VBox.vgrow="ALWAYS" maxHeight="Infinity" maxWidth="Infinity">

    <!-- TOP BAR BLANC -->
    <HBox style="-fx-background-color: white;
                 -fx-padding: 12px 20px;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);"
          spacing="12" alignment="CENTER_LEFT">

        <Label text="🏖️  Gestion des Points d'Intérêt"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1F2937;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <ComboBox fx:id="cmbTypeFilter" promptText="Filtrer par type..."
                  onAction="#handleTypeFilter"
                  style="-fx-background-color: #F3F4F6;
                         -fx-border-color: #E5E7EB;
                         -fx-border-radius: 6px;
                         -fx-background-radius: 6px;
                         -fx-font-size: 13px;
                         -fx-pref-height: 36px;
                         -fx-pref-width: 180px;"/>

        <HBox style="-fx-background-color: #F3F4F6;
                     -fx-background-radius: 6px;
                     -fx-border-color: #E5E7EB;
                     -fx-border-radius: 6px;
                     -fx-border-width: 1px;
                     -fx-padding: 0 12px;"
              alignment="CENTER_LEFT" spacing="6">
            <Label text="🔍" style="-fx-font-size: 13px; -fx-text-fill: #9CA3AF;"/>
            <TextField fx:id="txtSearch" promptText="Rechercher..."
                       onKeyReleased="#handleSearch"
                       style="-fx-background-color: transparent;
                              -fx-border-color: transparent;
                              -fx-font-size: 13px;
                              -fx-pref-width: 200px;
                              -fx-pref-height: 34px;"/>
        </HBox>

        <Button text="+ Créer" onAction="#showCreateForm"
                style="-fx-background-color: #3B82F6;
                       -fx-text-fill: white;
                       -fx-font-size: 13px;
                       -fx-font-weight: bold;
                       -fx-padding: 9px 20px;
                       -fx-background-radius: 6px;
                       -fx-cursor: hand;"/>

        <Button text="↺  Actualiser" onAction="#refreshTable"
                style="-fx-background-color: white;
                       -fx-text-fill: #4B5563;
                       -fx-font-size: 13px;
                       -fx-padding: 8px 16px;
                       -fx-background-radius: 6px;
                       -fx-cursor: hand;
                       -fx-border-color: #D1D5DB;
                       -fx-border-width: 1px;
                       -fx-border-radius: 6px;"/>
    </HBox>

    <!-- CONTENU -->
    <VBox spacing="20" VBox.vgrow="ALWAYS" maxHeight="Infinity" maxWidth="Infinity"
          style="-fx-padding: 20px; -fx-background-color: #F3F4F6;">

        <!-- STAT CARDS -->
        <HBox spacing="15">
            <VBox HBox.hgrow="ALWAYS" spacing="10" alignment="CENTER"
                  style="-fx-background-color: white; -fx-background-radius: 10px;
                         -fx-padding: 22px;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                <Label text="Total Points d'Intérêt"
                       style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
                <Label fx:id="lblTotalPoints" text="0"
                       style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #1F2937;"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="10" alignment="CENTER"
                  style="-fx-background-color: white; -fx-background-radius: 10px;
                         -fx-padding: 22px;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                <Label text="Monuments"
                       style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
                <Label fx:id="lblMonuments" text="0"
                       style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #4F46E5;"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="10" alignment="CENTER"
                  style="-fx-background-color: white; -fx-background-radius: 10px;
                         -fx-padding: 22px;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                <Label text="Plages"
                       style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
                <Label fx:id="lblPlages" text="0"
                       style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #3B82F6;"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="10" alignment="CENTER"
                  style="-fx-background-color: white; -fx-background-radius: 10px;
                         -fx-padding: 22px;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                <Label text="Musées"
                       style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
                <Label fx:id="lblMusees" text="0"
                       style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #9333EA;"/>
            </VBox>
        </HBox>

        <!-- TABLE CARD -->
        <VBox VBox.vgrow="ALWAYS" maxHeight="Infinity" maxWidth="Infinity"
              style="-fx-background-color: white; -fx-background-radius: 10px;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">

            <HBox style="-fx-padding: 16px 20px;
                         -fx-border-color: transparent transparent #F3F4F6 transparent;
                         -fx-border-width: 0 0 1px 0;"
                  alignment="CENTER_LEFT">
                <Label text="Liste des Points d'Intérêt"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1F2937;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblTableCount" text="0 point(s)"
                       style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;"/>
            </HBox>

            <TableView fx:id="tablePointsInteret" VBox.vgrow="ALWAYS" maxHeight="Infinity" maxWidth="Infinity"
                       style="-fx-background-color: white; -fx-border-color: transparent;">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="65"/>
                    <TableColumn fx:id="colNom" text="NOM" prefWidth="200"/>
                    <TableColumn fx:id="colType" text="TYPE" prefWidth="130"/>
                    <TableColumn fx:id="colDestination" text="DESTINATION" prefWidth="180"/>
                    <TableColumn fx:id="colDescription" text="DESCRIPTION" prefWidth="250"/>
                    <TableColumn fx:id="colActions" text="ACTIONS" prefWidth="130"/>
                </columns>
                <placeholder>
                    <Label text="Aucun point d'intérêt trouvé"
                           style="-fx-text-fill: #9CA3AF; -fx-font-size: 14px;"/>
                </placeholder>
            </TableView>
        </VBox>
    </VBox>
</VBox>