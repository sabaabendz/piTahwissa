<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.tahwissa.controllers.agent.ReservationFormController"
      spacing="20" styleClass="content-area" stylesheets="@/css/tahwissa-style.css">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="✏️ Modifier Réservation" styleClass="page-title"/>

    <GridPane hgap="10" vgap="10" styleClass="form-grid">
        <Label text="Client ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="userIdField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label fx:id="userIdError" text="" styleClass="error-label" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <!-- Voyage ID -->
        <Label text="Voyage ID:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="voyageIdField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Label fx:id="voyageIdError" text="" styleClass="error-label" GridPane.rowIndex="1" GridPane.columnIndex="2"/>

        <!-- Number of people -->
        <Label text="Nombre de personnes:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <Spinner fx:id="personnesSpinner" min="1" max="20" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <Label fx:id="personnesError" text="" styleClass="error-label" GridPane.rowIndex="2" GridPane.columnIndex="2"/>

        <!-- Date -->
        <Label text="Date de réservation:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <DatePicker fx:id="datePicker" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        <Label fx:id="dateError" text="" styleClass="error-label" GridPane.rowIndex="3" GridPane.columnIndex="2"/>

        <!-- Status (only in edit form) -->
        <Label text="Statut:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <ComboBox fx:id="statutCombo" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
        <!-- No error label needed for combo box, but you can add one if you want -->
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Mettre à jour" styleClass="btn-primary" onAction="#handleUpdate"/>
        <Button text="Annuler" styleClass="btn-secondary" onAction="#handleCancel"/>
    </HBox>
</VBox>
