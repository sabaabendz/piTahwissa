<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.tahwisa.controllers.CreateDestinationController"
      spacing="20"
      style="-fx-padding: 20;"
      styleClass="content-area">

    <!-- HEADER -->
    <HBox styleClass="top-bar" spacing="10" alignment="CENTER_LEFT">
        <Button text="← Liste" styleClass="btn-secondary" onAction="#returnToList"/>
        <Separator orientation="VERTICAL"/>
        <Label fx:id="lblFormTitle" text="Créer une nouvelle Destination" styleClass="page-title"/>
    </HBox>

    <!-- FORM CARD -->
    <VBox styleClass="card" spacing="0" VBox.vgrow="ALWAYS">
        <!-- Card Header -->
        <HBox styleClass="card-header">
            <Label text="Remplissez tous les champs requis" styleClass="card-subtitle"/>
        </HBox>

        <!-- Form Content -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: white;">
            <VBox spacing="20" style="-fx-padding: 20;">

                <!-- Client / Destination Name -->
                <VBox spacing="5">
                    <Label text="Nom de la Destination *" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtNom" promptText="Ex: Djerba"
                               style="-fx-pref-height: 35px;"/>
                    <Label fx:id="errNom" styleClass="error-label" managed="false" visible="false"/>
                </VBox>

                <!-- Pays et Ville -->
                <HBox spacing="15">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Pays *" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="txtPays" promptText="Ex: Tunisie"
                                   style="-fx-pref-height: 35px;"/>
                        <Label fx:id="errPays" styleClass="error-label" managed="false" visible="false"/>
                    </VBox>

                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Ville" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="txtVille" promptText="Ex: Houmt Souk"
                                   style="-fx-pref-height: 35px;"/>
                    </VBox>
                </HBox>

                <!-- Description -->
                <VBox spacing="5">
                    <Label text="Description" style="-fx-font-weight: bold;"/>
                    <TextArea fx:id="txtDescription" promptText="Description de la destination..."
                              prefRowCount="4" wrapText="true"/>
                </VBox>

                <!-- URL Image -->
                <VBox spacing="5">
                    <Label text="URL de l'image" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtImageUrl" promptText="Ex: djerba.jpg"
                               style="-fx-pref-height: 35px;"/>
                </VBox>

                <!-- Coordinates -->
                <HBox spacing="15">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Latitude" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="txtLatitude" promptText="33.8076"
                                   style="-fx-pref-height: 35px;"/>
                        <Label fx:id="errLatitude" styleClass="error-label" managed="false" visible="false"/>
                    </VBox>

                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Longitude" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="txtLongitude" promptText="10.8451"
                                   style="-fx-pref-height: 35px;"/>
                        <Label fx:id="errLongitude" styleClass="error-label" managed="false" visible="false"/>
                    </VBox>
                </HBox>

            </VBox>
        </ScrollPane>

        <!-- Card Footer with Buttons -->
        <HBox styleClass="card-footer" spacing="10" alignment="CENTER_RIGHT">
            <Button text="Annuler" styleClass="btn-secondary" onAction="#returnToList"/>
            <Button fx:id="btnSave" text="💾 Enregistrer" styleClass="btn-primary" onAction="#saveDestination"/>
        </HBox>
    </VBox>

</VBox>
