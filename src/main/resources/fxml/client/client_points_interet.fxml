<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.tahwissa.controllers.client.ClientPointsInteretController"
      spacing="0" VBox.vgrow="ALWAYS" maxHeight="Infinity" maxWidth="Infinity"
      style="-fx-background-color: #F3F4F6;">

    <!-- HEADER -->
    <HBox style="-fx-background-color: white; -fx-padding: 20px; -fx-spacing: 20px;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">

        <VBox spacing="5" HBox.hgrow="ALWAYS" alignment="CENTER">
            <Label text="🏖️" style="-fx-font-size: 32px;"/>
            <Label text="Points d'Intérêt" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

    <!-- FILTRES -->
    <HBox style="-fx-padding: 20px; -fx-spacing: 15px; -fx-background-color: white;
                 -fx-border-color: #E5E7EB; -fx-border-width: 1px 0 0 0;">

        <ComboBox fx:id="cmbTypeFilter" promptText="Filtrer par type"
                  prefWidth="200" style="-fx-background-radius: 8px;"/>

        <ComboBox fx:id="cmbDestinationFilter" promptText="Filtrer par destination"
                  prefWidth="250" style="-fx-background-radius: 8px;"/>

        <HBox style="-fx-background-color: #F3F4F6; -fx-background-radius: 8px;
                     -fx-border-color: #E5E7EB; -fx-border-radius: 8px;
                     -fx-border-width: 1px; -fx-padding: 0 12px;" HBox.hgrow="ALWAYS">
            <Label text="🔍" style="-fx-font-size: 14px; -fx-text-fill: #9CA3AF; -fx-padding: 0 8px 0 0;"/>
            <TextField fx:id="txtSearch" promptText="Rechercher un point d'intérêt..."
                       style="-fx-background-color: transparent; -fx-font-size: 13px; -fx-pref-height: 38px;"
                       HBox.hgrow="ALWAYS"/>
        </HBox>
    </HBox>

    <!-- GRILLE DES POINTS D'INTÉRÊT -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: transparent;">
        <FlowPane fx:id="pointsGrid" hgap="20" vgap="20" alignment="CENTER"
                  style="-fx-padding: 20px;">
            <!-- Les cartes seront ajoutées dynamiquement -->
        </FlowPane>
    </ScrollPane>
</VBox>