<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.tahwissa.controllers.client.ClientDestinationsController"
      spacing="0" VBox.vgrow="ALWAYS" maxHeight="Infinity" maxWidth="Infinity"
      style="-fx-background-color: #F3F4F6;">

    <!-- HEADER AVEC STATISTIQUES -->
    <HBox style="-fx-background-color: white; -fx-padding: 20px; -fx-spacing: 20px;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">

        <VBox spacing="5" HBox.hgrow="ALWAYS" alignment="CENTER">
            <Label text="🌍" style="-fx-font-size: 24px;"/>
            <Label text="Destinations" style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
            <Label fx:id="lblTotalDestinations" text="0"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #3B82F6;"/>
        </VBox>

        <VBox spacing="5" HBox.hgrow="ALWAYS" alignment="CENTER">
            <Label text="📍" style="-fx-font-size: 24px;"/>
            <Label text="Points d'Intérêt" style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
            <Label fx:id="lblTotalPoints" text="0"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #10B981;"/>
        </VBox>
    </HBox>

    <!-- FILTRES ET RECHERCHE -->
    <HBox style="-fx-padding: 20px; -fx-spacing: 15px; -fx-background-color: white;
                 -fx-border-color: #E5E7EB; -fx-border-width: 1px 0 0 0;">

        <ComboBox fx:id="cmbPaysFilter" promptText="Filtrer par pays"
                  prefWidth="200" style="-fx-background-radius: 8px;"/>

        <HBox style="-fx-background-color: #F3F4F6; -fx-background-radius: 8px;
                     -fx-border-color: #E5E7EB; -fx-border-radius: 8px;
                     -fx-border-width: 1px; -fx-padding: 0 12px;" HBox.hgrow="ALWAYS">
            <Label text="🔍" style="-fx-font-size: 14px; -fx-text-fill: #9CA3AF;
                                   -fx-padding: 0 8px 0 0;" alignment="CENTER"/>
            <TextField fx:id="txtSearch" promptText="Rechercher une destination..."
                       style="-fx-background-color: transparent; -fx-border-color: transparent;
                              -fx-font-size: 13px; -fx-pref-height: 38px;" HBox.hgrow="ALWAYS"/>
        </HBox>
    </HBox>

    <!-- CONTENU PRINCIPAL -->
    <HBox VBox.vgrow="ALWAYS" spacing="0" maxHeight="Infinity" maxWidth="Infinity">

        <!-- LISTE DES DESTINATIONS (GAUCHE) -->
        <VBox style="-fx-background-color: white; -fx-border-color: #E5E7EB;
                     -fx-border-width: 0 1px 0 0; -fx-pref-width: 350px;"
              maxHeight="Infinity">

            <Label text="Destinations disponibles"
                   style="-fx-font-weight: bold; -fx-padding: 15px; -fx-font-size: 14px;
                          -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1px 0;"/>

            <ListView fx:id="destinationsListView" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
        </VBox>

        <!-- DÉTAILS DE LA DESTINATION (DROITE) -->
        <VBox fx:id="detailsContainer" VBox.vgrow="ALWAYS" maxHeight="Infinity"
              style="-fx-padding: 20px; -fx-spacing: 20px;" visible="false">

            <Label text="Détails de la destination"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1F2937;"/>

            <!-- ImageView pour l'image de la destination -->
            <ImageView fx:id="destinationImageView"
                       fitWidth="300" fitHeight="200"
                       preserveRatio="true"
                       style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);
                              -fx-background-radius: 8px; -fx-border-radius: 8px;"/>

            <VBox style="-fx-background-color: white; -fx-background-radius: 12px;
                         -fx-padding: 20px; -fx-spacing: 15px;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">

                <Label fx:id="lblDestinationNom" text="Nom de la destination"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1F2937;"/>

                <GridPane hgap="20" vgap="10">
                    <Label text="Pays:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="lblDestinationPays" text="-" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Ville:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="lblDestinationVille" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Coordonnées:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="lblDestinationCoords" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                </GridPane>

                <Label text="Description" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <TextArea fx:id="txtDestinationDescription" editable="false" wrapText="true"
                          prefRowCount="4" style="-fx-background-color: #F9FAFB;"/>

                <Button text="🗺️ Voir sur la carte" onAction="#showOnMap"
                        style="-fx-background-color: #3B82F6; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-padding: 10px; -fx-background-radius: 8px;
                               -fx-cursor: hand; -fx-max-width: 200px;"/>
            </VBox>

            <!-- POINTS D'INTÉRÊT -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 12px;
                         -fx-padding: 20px; -fx-spacing: 15px;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);"
                  VBox.vgrow="ALWAYS">

                <Label text="Points d'intérêt à visiter"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1F2937;"/>

                <ListView fx:id="pointsInteretListView" VBox.vgrow="ALWAYS"
                          style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
            </VBox>
        </VBox>
    </HBox>
</VBox>