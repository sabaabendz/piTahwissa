<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="tn.esprit.tahwissa.controllers.client.PaymentDialogController"
           style="-fx-background-color: #F3F4F6; -fx-min-width: 490; -fx-max-width: 490; -fx-min-height: 680; -fx-max-height: 680;">

    <!-- ═══ MAIN FORM ═══ -->
    <VBox spacing="0" alignment="TOP_CENTER">

        <!-- ── Brand Header (matches sidebar gradient) ── -->
        <HBox alignment="CENTER_LEFT" spacing="14"
              style="-fx-background-color: linear-gradient(to right, #4F46E5, #9333EA);
                     -fx-padding: 16 22 16 22;">
            <!-- Logo -->
            <ImageView fitWidth="36" fitHeight="36" preserveRatio="true">
                <image>
                    <Image url="@/images/logo.png"/>
                </image>
            </ImageView>
            <VBox spacing="1">
                <Label text="Tahwissa" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Paiement Sécurisé  🔒" style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.8);"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label fx:id="amountLabel" text="0.00 DT"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label fx:id="voyageLabel" text="Voyage"
                       style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.75); -fx-text-alignment: right;"/>
            </VBox>
        </HBox>

        <!-- ── Live Card Preview ── -->
        <StackPane style="-fx-padding: 18 22 10 22; -fx-background-color: #F3F4F6;">
            <StackPane style="-fx-background-color: linear-gradient(to bottom right, #4F46E5, #9333EA);
                              -fx-background-radius: 14;
                              -fx-effect: dropshadow(gaussian, rgba(79,70,229,0.45), 18, 0, 0, 6);
                              -fx-min-height: 155; -fx-max-height: 155;
                              -fx-min-width: 445; -fx-max-width: 445;">
                <VBox spacing="0" alignment="TOP_LEFT" style="-fx-padding: 18 20 18 20;">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="💳" style="-fx-font-size: 26px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="VISA" style="-fx-font-size: 19px; -fx-font-weight: bold;
                                                  -fx-text-fill: white; -fx-font-style: italic;"/>
                    </HBox>
                    <Label fx:id="cardPreviewNumber" text="•••• •••• •••• ••••"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;
                                  -fx-padding: 12 0 7 0; -fx-font-family: 'Courier New';"/>
                    <HBox alignment="CENTER_LEFT">
                        <VBox spacing="1">
                            <Label text="TITULAIRE" style="-fx-font-size: 9px; -fx-text-fill: rgba(255,255,255,0.65);"/>
                            <Label fx:id="cardPreviewName" text="VOTRE NOM"
                                   style="-fx-font-size: 12px; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <VBox spacing="1" alignment="CENTER_RIGHT">
                            <Label text="EXPIRE" style="-fx-font-size: 9px; -fx-text-fill: rgba(255,255,255,0.65);"/>
                            <Label fx:id="cardPreviewExpiry" text="MM/YY"
                                   style="-fx-font-size: 12px; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </StackPane>
        </StackPane>

        <!-- ── Form Fields ── -->
        <VBox spacing="12" style="-fx-padding: 10 22 0 22; -fx-background-color: #F3F4F6;">

            <!-- Card Number -->
            <VBox spacing="5">
                <Label text="Numéro de carte" style="-fx-text-fill: #374151; -fx-font-size: 12px; -fx-font-weight: 600;"/>
                <TextField fx:id="cardNumberField" promptText="1234  5678  9012  3456"
                           style="-fx-background-color: white; -fx-text-fill: #1F2937;
                                  -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-border-width: 1.5; -fx-padding: 10 12; -fx-font-size: 15px;
                                  -fx-font-family: 'Courier New'; -fx-prompt-text-fill: #9CA3AF;
                                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 4, 0, 0, 1);"/>
            </VBox>

            <!-- Expiry + CVC -->
            <HBox spacing="12">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Date d'expiration" style="-fx-text-fill: #374151; -fx-font-size: 12px; -fx-font-weight: 600;"/>
                    <TextField fx:id="expiryField" promptText="MM/YY"
                               style="-fx-background-color: white; -fx-text-fill: #1F2937;
                                      -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-background-radius: 8;
                                      -fx-border-width: 1.5; -fx-padding: 10 12; -fx-font-size: 15px;
                                      -fx-font-family: 'Courier New'; -fx-prompt-text-fill: #9CA3AF;
                                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 4, 0, 0, 1);"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="CVC" style="-fx-text-fill: #374151; -fx-font-size: 12px; -fx-font-weight: 600;"/>
                    <TextField fx:id="cvcField" promptText="123"
                               style="-fx-background-color: white; -fx-text-fill: #1F2937;
                                      -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-background-radius: 8;
                                      -fx-border-width: 1.5; -fx-padding: 10 12; -fx-font-size: 15px;
                                      -fx-font-family: 'Courier New'; -fx-prompt-text-fill: #9CA3AF;
                                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 4, 0, 0, 1);"/>
                </VBox>
            </HBox>

            <!-- Cardholder name -->
            <VBox spacing="5">
                <Label text="Nom du titulaire" style="-fx-text-fill: #374151; -fx-font-size: 12px; -fx-font-weight: 600;"/>
                <TextField fx:id="cardholderNameField" promptText="Prénom NOM"
                           style="-fx-background-color: white; -fx-text-fill: #1F2937;
                                  -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-border-width: 1.5; -fx-padding: 10 12; -fx-font-size: 13px;
                                  -fx-prompt-text-fill: #9CA3AF;
                                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 4, 0, 0, 1);"/>
            </VBox>
        </VBox>

        <!-- Status / error message -->
        <Label fx:id="statusLabel" text="" wrapText="true"
               style="-fx-text-fill: #EF4444; -fx-font-size: 12px; -fx-padding: 6 22 0 22;"/>

        <!-- Progress spinner -->
        <ProgressIndicator fx:id="progressIndicator" visible="false"
                           prefWidth="34" prefHeight="34"
                           style="-fx-progress-color: #4F46E5; -fx-padding: 4 0 0 0;"/>

        <!-- Test badge -->
        <HBox alignment="CENTER" style="-fx-padding: 6 22 0 22;">
            <Label text="🧪 Mode Test — carte 4242 4242 4242 4242 · date future · CVC quelconque"
                   wrapText="true" style="-fx-background-color: #EEF2FF; -fx-text-fill: #4338CA;
                   -fx-padding: 5 12; -fx-background-radius: 6; -fx-font-size: 10px; -fx-font-weight: 600;"/>
        </HBox>

        <Region VBox.vgrow="ALWAYS"/>

        <!-- Divider line -->
        <Separator style="-fx-background-color: #E5E7EB; -fx-padding: 0 22;"/>

        <!-- Action Buttons -->
        <HBox spacing="12" alignment="CENTER" style="-fx-padding: 14 22 18 22; -fx-background-color: white;">
            <Button fx:id="cancelButton" text="Annuler" onAction="#handleCancel"
                    style="-fx-background-color: white; -fx-text-fill: #6B7280;
                           -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #D1D5DB;
                           -fx-border-width: 1.5; -fx-padding: 11 26; -fx-font-size: 13px; -fx-cursor: hand;"/>
            <Button fx:id="payButton" text="💳 Payer" onAction="#handlePayment"
                    style="-fx-background-color: linear-gradient(to right, #4F46E5, #9333EA);
                           -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 11 26;
                           -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(79,70,229,0.35), 8, 0, 0, 3);"
                    HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>

    <!-- ═══ RESULT OVERLAY ═══ -->
    <VBox fx:id="resultPane" visible="false" managed="false"
          alignment="CENTER" spacing="20"
          style="-fx-background-color: rgba(243,244,246,0.98);">

        <!-- Logo in result overlay -->
        <ImageView fitWidth="60" fitHeight="60" preserveRatio="true">
            <image><Image url="@/images/logo.png"/></image>
        </ImageView>

        <Label fx:id="resultIcon" text="✅" style="-fx-font-size: 64px;"/>
        <Label fx:id="resultTitle" text="Paiement réussi !"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1F2937;"/>
        <Label fx:id="resultMessage" text="" wrapText="true"
               style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-text-alignment: center; -fx-padding: 0 30;"/>
        <Button fx:id="closeButton" text="Fermer" onAction="#handleClose"
                style="-fx-background-color: linear-gradient(to right, #4F46E5, #9333EA);
                       -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 11 44;
                       -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(79,70,229,0.35), 8, 0, 0, 3);"/>
    </VBox>

</StackPane>
