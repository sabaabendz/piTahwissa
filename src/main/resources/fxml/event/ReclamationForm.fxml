<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.tahwissa.controllers.event.ReclamationFormController"
           stylesheets="@../../css/styles.css"
           fitToWidth="true" style="-fx-background-color: -fx-background;">
    
    <VBox spacing="24" style="-fx-padding: 24px;">

        <!-- Header Section -->
        <VBox spacing="12">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Button text="← Retour" styleClass="btn" onAction="#handleBackToList"
                       style="-fx-font-size: 13px;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
            <Label fx:id="formTitle" text="Créer une nouvelle réclamation" 
                  style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: -fx-text-primary;"/>
            <Label text="Décrire votre problème ou suggestion" 
                  styleClass="subtitle-text"/>
        </VBox>

        <!-- Card avec le formulaire -->
        <VBox styleClass="card" spacing="24">

            <!-- Message Label -->
            <Label fx:id="messageLabel" visible="false" wrapText="true" maxWidth="Infinity"
                  style="-fx-padding: 12; -fx-background-radius: 10;"/>

            <!-- Formulaire Grid -->
            <GridPane hgap="20" vgap="18">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50" minWidth="240"/>
                    <ColumnConstraints percentWidth="50" minWidth="240"/>
                </columnConstraints>

                <!-- Row 0: Titre et Type -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="📋 Titre de la réclamation *" styleClass="form-label"/>
                    <TextField fx:id="txtTitre" promptText="Ex: Problème de paiement" 
                              styleClass="form-field" style="-fx-font-size: 14px;"/>
                </VBox>

                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="🏷️ Type *" styleClass="form-label"/>
                    <ComboBox fx:id="cmbType" promptText="Sélectionner un type"
                             styleClass="form-field" maxWidth="Infinity" style="-fx-font-size: 14px;"/>
                </VBox>

                <!-- Row 1: Description -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                    <Label text="📝 Description détaillée *" styleClass="form-label"/>
                    <TextArea fx:id="txtDescription" promptText="Décrivez votre réclamation en détail..." 
                             styleClass="form-field" prefRowCount="6" wrapText="true"
                             style="-fx-font-size: 14px; -fx-control-inner-background: -fx-surface;"/>
                </VBox>

                <!-- Row 2 (Admin only) -->
                <VBox fx:id="statutBox" spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="2" 
                      visible="false" managed="false">
                    <Label text="✓ Statut *" styleClass="form-label"/>
                    <ComboBox fx:id="cmbStatut" promptText="Sélectionner un statut"
                             styleClass="form-field" maxWidth="Infinity" style="-fx-font-size: 14px;"/>
                </VBox>
            </GridPane>

            <Separator/>

            <!-- Boutons d'action -->
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="Annuler" styleClass="btn, btn-outline" onAction="#handleCancel"
                       style="-fx-min-width: 120px;"/>
                <Button fx:id="btnSubmit" text="✓ Soumettre la réclamation" styleClass="btn, btn-primary" 
                       onAction="#handleSave" style="-fx-min-width: 200px;"/>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>
