<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.tahwissa.controllers.agent.GestionReservationsController"
            stylesheets="@/css/tahwissa-style.css">

    <!-- Left Sidebar -->
    <left>
        <VBox styleClass="sidebar" spacing="0" minWidth="200" maxWidth="200">
            <VBox styleClass="logo-container" alignment="CENTER" spacing="5">
                <HBox alignment="CENTER" spacing="10">
                    <VBox spacing="2">
                        <Label text="Tahwissa" styleClass="logo-title"/>
                        <Label text="Travel Management" styleClass="logo-subtitle"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="5" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="10" bottom="10" left="10" right="10"/>
                </padding>
                <Label text="MODULES" styleClass="menu-section-title"/>
                <Button text="📋 Réservations" styleClass="menu-button,active" maxWidth="Infinity" fx:id="btnReservations"/>
                <Button text="📍 Destinations" styleClass="menu-button" maxWidth="Infinity" fx:id="btnDestinations"/>
                <Region VBox.vgrow="ALWAYS"/>
                <Button text="⚙️ Paramètres" styleClass="menu-button" maxWidth="Infinity" fx:id="btnParametres"/>
            </VBox>

            <VBox styleClass="user-profile" spacing="8">
                <padding>
                    <Insets top="15" bottom="15" left="15" right="15"/>
                </padding>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane styleClass="user-avatar" minWidth="40" minHeight="40">
                        <Label text="A" styleClass="user-avatar-text"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="Administrateur" styleClass="user-name"/>
                        <Label text="admin@tahwissa.com" styleClass="user-email"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <!-- Main Content Area -->
    <center>
        <VBox styleClass="content-area" spacing="20">
            <!-- Top Bar -->
            <HBox styleClass="top-bar" spacing="15" alignment="CENTER_LEFT">
                <Button text="📋 Liste" styleClass="btn-primary"/>
                <Button text="➕ Créer" styleClass="btn-secondary" fx:id="nouveauBtn"/>
                <Button text="🔄 Actualiser" styleClass="btn-secondary" fx:id="refreshBtn"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField promptText="🔍 Rechercher..." styleClass="search-field" fx:id="searchField" prefWidth="300"/>
                <ComboBox fx:id="statutFilter" prefWidth="150"/>
                <Button text="🔽 Filter" styleClass="btn-secondary" fx:id="filterBtn"/>
            </HBox>

            <!-- Card Container for Table -->
            <VBox styleClass="card" VBox.vgrow="ALWAYS">
                <VBox styleClass="card-header" spacing="5">
                    <Label text="Liste des Réservations" styleClass="card-title"/>
                    <Label fx:id="statsLabel" text="Total: 0 réservations" styleClass="card-subtitle"/>
                </VBox>

                <!-- Table View with Correct fx:ids -->
                <TableView fx:id="reservationsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn text="ID" prefWidth="50" fx:id="idCol"/>
                        <TableColumn text="CLIENT" prefWidth="100" fx:id="clientCol"/>
                        <TableColumn text="DESTINATION" prefWidth="140" fx:id="destinationCol"/>
                        <TableColumn text="PERSONNES" prefWidth="100" fx:id="personnesCol"/>
                        <TableColumn text="MONTANT" prefWidth="120" fx:id="montantCol"/>
                        <TableColumn text="STATUT" prefWidth="130" fx:id="statutCol"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Action Buttons -->
            <HBox spacing="10" style="-fx-padding: 10;">
                <Button text="✏️ Modifier" fx:id="modifierBtn" style="-fx-padding: 8 16;"/>
                <Button text="🗑️ Supprimer" fx:id="supprimerBtn" style="-fx-padding: 8 16;"/>
                <Button text="↻ Reset Filters" fx:id="resetBtn" style="-fx-padding: 8 16;"/>
            </HBox>
        </VBox>
    </center>

    <!-- Bottom Status Bar -->
    <bottom>
        <HBox styleClass="status-bar" spacing="15" alignment="CENTER_LEFT">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <StackPane styleClass="status-indicator"/>
                <Label text="✅ Connecté" styleClass="status-text"/>
            </HBox>
            <Separator orientation="VERTICAL"/>
            <Label text="Base: gestionreservation" styleClass="status-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="dateTimeLabel" text="15/02/2026 16:03" styleClass="status-text"/>
        </HBox>
    </bottom>

</BorderPane>