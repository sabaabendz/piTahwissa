<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.tahwissa.controllers.admin.UserFormController"
            prefWidth="600.0" prefHeight="550.0"
            style="-fx-background-color: transparent;">

    <VBox spacing="20"
          style="-fx-background-color: white;
                 -fx-background-radius: 15;
                 -fx-padding: 30;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 20, 0, 0, 10);"
          AnchorPane.bottomAnchor="20.0"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0"
          AnchorPane.topAnchor="20.0">

        <!-- En-tête avec icône -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label fx:id="formIcon" text="➕"
                   style="-fx-font-size: 32px; -fx-text-fill: #9333EA;"/>
            <VBox spacing="5">
                <Label fx:id="formTitle" text="Ajouter un utilisateur"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #4F46E5;"/>
                <Label fx:id="formSubtitle" text="Remplissez les informations ci-dessous"
                       style="-fx-font-size: 12px; -fx-text-fill: #7F8C8D;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="closeBtn" text="✕"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #7F8C8D;
                           -fx-font-size: 18px;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;"
                    onAction="#closeForm"/>
        </HBox>

        <Separator/>

        <!-- Formulaire -->
        <GridPane hgap="20" vgap="15">
            <columnConstraints>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="75"/>
            </columnConstraints>

            <!-- Email -->
            <Label text="Email *"
                   style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"
                   GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="emailField"
                       promptText="exemple@email.com"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"
                       style="-fx-background-radius: 5; -fx-border-radius: 5;
                              -fx-border-color: #BDC3C7; -fx-border-width: 1;
                              -fx-padding: 8 15;"/>

            <!-- Mot de passe -->
            <Label text="Mot de passe *"
                   style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"
                   GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <PasswordField fx:id="passwordField"
                           promptText="********"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"
                           style="-fx-background-radius: 5; -fx-border-radius: 5;
                                  -fx-border-color: #BDC3C7; -fx-border-width: 1;
                                  -fx-padding: 8 15;"/>

            <!-- Prénom -->
            <Label text="Prénom *"
                   style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"
                   GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="firstNameField"
                       promptText="Prénom"
                       GridPane.columnIndex="1" GridPane.rowIndex="2"
                       style="-fx-background-radius: 5; -fx-border-radius: 5;
                              -fx-border-color: #BDC3C7; -fx-border-width: 1;
                              -fx-padding: 8 15;"/>

            <!-- Nom -->
            <Label text="Nom *"
                   style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"
                   GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="lastNameField"
                       promptText="Nom"
                       GridPane.columnIndex="1" GridPane.rowIndex="3"
                       style="-fx-background-radius: 5; -fx-border-radius: 5;
                              -fx-border-color: #BDC3C7; -fx-border-width: 1;
                              -fx-padding: 8 15;"/>

            <!-- Téléphone -->
            <Label text="Téléphone"
                   style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"
                   GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <TextField fx:id="phoneField"
                       promptText="+216 XX XXX XXX"
                       GridPane.columnIndex="1" GridPane.rowIndex="4"
                       style="-fx-background-radius: 5; -fx-border-radius: 5;
                              -fx-border-color: #BDC3C7; -fx-border-width: 1;
                              -fx-padding: 8 15;"/>

            <!-- Rôle -->
            <Label text="Rôle *"
                   style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"
                   GridPane.columnIndex="0" GridPane.rowIndex="5"/>
            <ChoiceBox fx:id="roleField"
                       prefWidth="200"
                       GridPane.columnIndex="1" GridPane.rowIndex="5"
                       style="-fx-background-radius: 5; -fx-border-radius: 5;
                              -fx-border-color: #BDC3C7; -fx-border-width: 1;">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="USER" />
                        <String fx:value="AGENT" />
                        <String fx:value="ADMIN" />
                    </FXCollections>
                </items>
                <value>
                    <String fx:value="USER" />
                </value>
            </ChoiceBox>

            <!-- Statuts -->
            <Label text="Statut"
                   style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"
                   GridPane.columnIndex="0" GridPane.rowIndex="6"/>
            <HBox spacing="20" GridPane.columnIndex="1" GridPane.rowIndex="6">
                <CheckBox fx:id="verifiedCheckbox" text="Vérifié"
                          style="-fx-text-fill: #2C3E50;"/>
                <CheckBox fx:id="activeCheckbox" text="Actif" selected="true"
                          style="-fx-text-fill: #2C3E50;"/>
            </HBox>

            <!-- Ville -->
            <Label text="Ville"
                   style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"
                   GridPane.columnIndex="0" GridPane.rowIndex="7"/>
            <TextField fx:id="cityField"
                       promptText="Ville"
                       GridPane.columnIndex="1" GridPane.rowIndex="7"
                       style="-fx-background-radius: 5; -fx-border-radius: 5;
                              -fx-border-color: #BDC3C7; -fx-border-width: 1;
                              -fx-padding: 8 15;"/>

            <!-- Pays -->
            <Label text="Pays"
                   style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"
                   GridPane.columnIndex="0" GridPane.rowIndex="8"/>
            <TextField fx:id="countryField"
                       text="Tunisie"
                       GridPane.columnIndex="1" GridPane.rowIndex="8"
                       style="-fx-background-radius: 5; -fx-border-radius: 5;
                              -fx-border-color: #BDC3C7; -fx-border-width: 1;
                              -fx-padding: 8 15;"/>
        </GridPane>

        <!-- Message d'erreur -->
        <Label fx:id="errorLabel"
               style="-fx-text-fill: #E74C3C; -fx-font-size: 12px; -fx-font-weight: bold;"
               wrapText="true"
               managed="false" visible="false"/>

        <Separator/>

        <!-- Boutons d'action -->
        <HBox spacing="15" alignment="CENTER_RIGHT">
            <Button fx:id="cancelBtn" text="Annuler"
                    style="-fx-background-color: #95A5A6;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-background-radius: 5;
                           -fx-padding: 10 25;
                           -fx-cursor: hand;"
                    onAction="#closeForm"/>
            <Button fx:id="saveBtn" text="Ajouter"
                    style="-fx-background-color: #9333EA;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-background-radius: 5;
                           -fx-padding: 10 30;
                           -fx-cursor: hand;"
                    onAction="#handleSave"/>
        </HBox>

        <!-- Champ caché pour l'ID (en modification) -->
        <TextField fx:id="userIdField" managed="false" visible="false"/>

    </VBox>

</AnchorPane>
