<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.tahwissa.controllers.admin.VoyageFormController"
      spacing="20" styleClass="content-area" stylesheets="@/css/tahwissa-style.css">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label fx:id="formTitle" text="➕ Nouveau Voyage" styleClass="page-title"/>

    <GridPane hgap="10" vgap="10" styleClass="form-grid">
        <!-- Titre -->
        <Label text="Titre:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="titreField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label fx:id="titreError" text="" styleClass="error-label" GridPane.rowIndex="0" GridPane.columnIndex="2"/>

        <!-- Destination -->
        <Label text="Destination:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="destinationField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Label fx:id="destinationError" text="" styleClass="error-label" GridPane.rowIndex="1" GridPane.columnIndex="2"/>

        <!-- Catégorie -->
        <Label text="Catégorie:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="categorieField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <Label fx:id="categorieError" text="" styleClass="error-label" GridPane.rowIndex="2" GridPane.columnIndex="2"/>

        <!-- Prix unitaire -->
        <Label text="Prix unitaire:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="prixField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        <Label fx:id="prixError" text="" styleClass="error-label" GridPane.rowIndex="3" GridPane.columnIndex="2"/>

        <!-- Date départ -->
        <Label text="Date départ:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <DatePicker fx:id="departPicker" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
        <Label fx:id="departError" text="" styleClass="error-label" GridPane.rowIndex="4" GridPane.columnIndex="2"/>

        <!-- Date retour -->
        <Label text="Date retour:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <DatePicker fx:id="retourPicker" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
        <Label fx:id="retourError" text="" styleClass="error-label" GridPane.rowIndex="5" GridPane.columnIndex="2"/>

        <!-- Places disponibles -->
        <Label text="Places:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <TextField fx:id="placesField" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
        <Label fx:id="placesError" text="" styleClass="error-label" GridPane.rowIndex="6" GridPane.columnIndex="2"/>

        <!-- Statut -->
        <Label text="Statut:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
        <ComboBox fx:id="statutCombo" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
        <Label fx:id="statutError" text="" styleClass="error-label" GridPane.rowIndex="7" GridPane.columnIndex="2"/>

        <!-- Description -->
        <Label text="Description:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
        <TextArea fx:id="descriptionField" GridPane.rowIndex="8" GridPane.columnIndex="1" prefRowCount="3"/>
        <Label fx:id="descriptionError" text="" styleClass="error-label" GridPane.rowIndex="8" GridPane.columnIndex="2"/>

        <!-- Image URL -->
        <Label text="Image URL:" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
        <TextField fx:id="imageField" GridPane.rowIndex="9" GridPane.columnIndex="1"/>
        <Label fx:id="imageError" text="" styleClass="error-label" GridPane.rowIndex="9" GridPane.columnIndex="2"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Enregistrer" styleClass="btn-primary" onAction="#handleSave"/>
        <Button text="Annuler" styleClass="btn-secondary" onAction="#handleCancel"/>
    </HBox>
</VBox>