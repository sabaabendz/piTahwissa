<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.tahwissa.controllers.destination.CreateDestinationController"
      spacing="0" VBox.vgrow="ALWAYS" maxHeight="Infinity" maxWidth="Infinity">

    <!-- TOP BAR -->
    <HBox style="-fx-background-color: white;
                 -fx-padding: 12px 20px;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);"
          spacing="10" alignment="CENTER_LEFT">
        <Button text="☰ Liste" onAction="#returnToList"
                style="-fx-background-color: white; -fx-text-fill: #4B5563;
                       -fx-font-size: 13px; -fx-padding: 8px 16px;
                       -fx-background-radius: 6px; -fx-cursor: hand;
                       -fx-border-color: #D1D5DB; -fx-border-width: 1px;
                       -fx-border-radius: 6px;"/>
    </HBox>

    <!-- CONTENU -->
    <VBox spacing="20" VBox.vgrow="ALWAYS" maxHeight="Infinity" maxWidth="Infinity">
        <padding>
            <Insets top="20" right="80" bottom="20" left="80"/>
        </padding>

        <!-- FORM CARD -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 10px;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);"
              VBox.vgrow="ALWAYS" maxHeight="Infinity" maxWidth="Infinity">

            <!-- Card Header avec gradient -->
            <VBox style="-fx-background-color: linear-gradient(to right, #EEF2FF, #F5F3FF);
                         -fx-padding: 20px; -fx-background-radius: 10px 10px 0 0;">
                <Label fx:id="lblFormTitle" text="Créer une nouvelle Destination"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1F2937;"/>
                <Label text="Remplissez tous les champs requis"
                       style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
            </VBox>

            <!-- Formulaire -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" maxHeight="Infinity" maxWidth="Infinity"
                        style="-fx-background-color: white; -fx-background: white;">
                <VBox spacing="20" style="-fx-padding: 25px;">

                    <VBox spacing="6">
                        <Label text="Nom de la Destination *"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextField fx:id="txtNom" promptText="Ex: Djerba"
                                   style="-fx-background-color: white; -fx-border-color: #D1D5DB;
                                          -fx-border-width: 1px; -fx-border-radius: 6px;
                                          -fx-background-radius: 6px; -fx-padding: 8px 12px;
                                          -fx-font-size: 13px; -fx-pref-height: 38px;"/>
                        <Label fx:id="errNom" style="-fx-text-fill: #EF4444; -fx-font-size: 11px;"
                               managed="false" visible="false"/>
                    </VBox>

                    <HBox spacing="20">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Pays *"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <TextField fx:id="txtPays" promptText="Ex: Tunisie"
                                       style="-fx-background-color: white; -fx-border-color: #D1D5DB;
                                              -fx-border-width: 1px; -fx-border-radius: 6px;
                                              -fx-background-radius: 6px; -fx-padding: 8px 12px;
                                              -fx-font-size: 13px; -fx-pref-height: 38px;"/>
                            <Label fx:id="errPays" style="-fx-text-fill: #EF4444; -fx-font-size: 11px;"
                                   managed="false" visible="false"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Ville"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <TextField fx:id="txtVille" promptText="Ex: Houmt Souk"
                                       style="-fx-background-color: white; -fx-border-color: #D1D5DB;
                                              -fx-border-width: 1px; -fx-border-radius: 6px;
                                              -fx-background-radius: 6px; -fx-padding: 8px 12px;
                                              -fx-font-size: 13px; -fx-pref-height: 38px;"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="6">
                        <Label text="Description"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextArea fx:id="txtDescription"
                                  promptText="Description de la destination..."
                                  prefRowCount="3" wrapText="true" VBox.vgrow="ALWAYS"
                                  style="-fx-border-color: #D1D5DB; -fx-border-radius: 6px;
                                         -fx-background-radius: 6px; -fx-font-size: 13px;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="URL de l'image"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextField fx:id="txtImageUrl" promptText="Ex: djerba.jpg"
                                   style="-fx-background-color: white; -fx-border-color: #D1D5DB;
                                          -fx-border-width: 1px; -fx-border-radius: 6px;
                                          -fx-background-radius: 6px; -fx-padding: 8px 12px;
                                          -fx-font-size: 13px; -fx-pref-height: 38px;"/>
                    </VBox>

                    <HBox spacing="20">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Latitude"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <TextField fx:id="txtLatitude" promptText="33.8076"
                                       style="-fx-background-color: white; -fx-border-color: #D1D5DB;
                                              -fx-border-width: 1px; -fx-border-radius: 6px;
                                              -fx-background-radius: 6px; -fx-padding: 8px 12px;
                                              -fx-font-size: 13px; -fx-pref-height: 38px;"/>
                            <Label fx:id="errLatitude" style="-fx-text-fill: #EF4444; -fx-font-size: 11px;"
                                   managed="false" visible="false"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Longitude"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <TextField fx:id="txtLongitude" promptText="10.8451"
                                       style="-fx-background-color: white; -fx-border-color: #D1D5DB;
                                              -fx-border-width: 1px; -fx-border-radius: 6px;
                                              -fx-background-radius: 6px; -fx-padding: 8px 12px;
                                              -fx-font-size: 13px; -fx-pref-height: 38px;"/>
                            <Label fx:id="errLongitude" style="-fx-text-fill: #EF4444; -fx-font-size: 11px;"
                                   managed="false" visible="false"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER">
                        <Button fx:id="btnGenerateDescription" text="🤖 Générer Description IA"
                                onAction="#generateAIDescription"
                                style="-fx-background-color: #8B5CF6; -fx-text-fill: white;
                                       -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-padding: 10px 20px; -fx-background-radius: 6px;
                                       -fx-cursor: hand;" HBox.hgrow="ALWAYS"/>

                        <Button fx:id="btnGenerateImage" text="🎨 Générer Image IA"
                                onAction="#generateAIImage"
                                style="-fx-background-color: #EC4899; -fx-text-fill: white;
                                       -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-padding: 10px 20px; -fx-background-radius: 6px;
                                       -fx-cursor: hand;" HBox.hgrow="ALWAYS"/>

                        <Button fx:id="btnGetCoordinates" text="🗺️ Obtenir Coordonnées"
                                onAction="#getCoordinatesFromAddress"
                                style="-fx-background-color: #10B981; -fx-text-fill: white;
                                       -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-padding: 10px 20px; -fx-background-radius: 6px;
                                       -fx-cursor: hand;" HBox.hgrow="ALWAYS"/>

                        <Button fx:id="btnShowMap" text="📍 Voir sur carte"
                                onAction="#showOnMap"
                                style="-fx-background-color: #3B82F6; -fx-text-fill: white;
                                       -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-padding: 10px 20px; -fx-background-radius: 6px;
                                       -fx-cursor: hand;" HBox.hgrow="ALWAYS"/>
                    </HBox>

                </VBox>
            </ScrollPane>

            <!-- Card Footer avec boutons -->
            <HBox style="-fx-background-color: #F9FAFB; -fx-padding: 12px 20px;
                         -fx-border-color: #E5E7EB transparent transparent transparent;
                         -fx-border-width: 1px 0 0 0; -fx-background-radius: 0 0 10px 10px;"
                  spacing="10" alignment="CENTER_RIGHT">
                <Button text="Annuler" onAction="#returnToList"
                        style="-fx-background-color: white; -fx-text-fill: #4B5563;
                               -fx-font-size: 13px; -fx-padding: 8px 20px;
                               -fx-background-radius: 6px; -fx-cursor: hand;
                               -fx-border-color: #D1D5DB; -fx-border-width: 1px;
                               -fx-border-radius: 6px;"/>
                <Button fx:id="btnSave" text="💾 Enregistrer"
                        onAction="#saveDestination"
                        style="-fx-background-color: #3B82F6; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-padding: 9px 24px; -fx-background-radius: 6px;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </VBox>
</VBox>