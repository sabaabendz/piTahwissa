<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.tahwissa.controllers.destination.MapViewController"
      spacing="0" VBox.vgrow="ALWAYS" maxHeight="Infinity" maxWidth="Infinity"
      style="-fx-background-color: #F3F4F6;">

    <!-- TOP BAR -->
    <HBox style="-fx-background-color: white;
                 -fx-padding: 12px 20px;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);"
          spacing="10" alignment="CENTER_LEFT">

        <Button text="←  Retour" onAction="#returnToPrevious"
                style="-fx-background-color: #3B82F6;
                       -fx-text-fill: white;
                       -fx-font-size: 13px;
                       -fx-font-weight: bold;
                       -fx-padding: 8px 16px;
                       -fx-background-radius: 6px;
                       -fx-cursor: hand;"/>

        <Label fx:id="lblMapTitle" text="🗺️  Carte de la Destination"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1F2937;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Button text="↻  Rafraîchir" onAction="#refreshMap"
                style="-fx-background-color: white;
                       -fx-text-fill: #4B5563;
                       -fx-font-size: 13px;
                       -fx-padding: 8px 16px;
                       -fx-background-radius: 6px;
                       -fx-cursor: hand;
                       -fx-border-color: #D1D5DB;
                       -fx-border-width: 1px;
                       -fx-border-radius: 6px;"/>
    </HBox>

    <!-- CONTENU PRINCIPAL -->
    <VBox VBox.vgrow="ALWAYS" spacing="0" maxHeight="Infinity" maxWidth="Infinity"
          style="-fx-padding: 20px; -fx-background-color: #F3F4F6;">

        <!-- CARTE WEBVIEW -->
        <StackPane VBox.vgrow="ALWAYS" maxHeight="Infinity" maxWidth="Infinity"
                   style="-fx-background-color: white; -fx-background-radius: 12px;
                          -fx-border-radius: 12px; -fx-border-color: #E5E7EB;
                          -fx-border-width: 1px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">

            <WebView fx:id="webView" StackPane.alignment="CENTER"
                     style="-fx-background-color: white; -fx-background-radius: 12px;"/>

            <Label text="Chargement de la carte..." style="-fx-text-fill: #6B7280; -fx-font-size: 14px;"
                   StackPane.alignment="CENTER" visible="false" fx:id="loadingLabel"/>
        </StackPane>
    </VBox>
</VBox>